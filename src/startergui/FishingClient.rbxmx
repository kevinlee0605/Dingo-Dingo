	)
	controller.scrollbarThumb = scrollbarThumb
	scrollbarTrack.Active = true
	scrollbarThumb.Active = true

	-- Hide the track image itself. The invisible holder remains active,
	-- so track clicking and scrolling still work.
	local trackArtwork = getArtwork(scrollbarTrack)
	if trackArtwork then
		trackArtwork.Visible = false
	end

	-- The thin pale line is actually the clipped right edge of every
	-- QuestCard image, not the scrollbar track. Mask only that 4 px edge.
	local questCardRightEdgeMask = Instance.new("Frame")
	questCardRightEdgeMask.Name = "QuestCardRightEdgeMask"
	questCardRightEdgeMask.BackgroundColor3 = Color3.fromRGB(1, 28, 58)
	questCardRightEdgeMask.BorderSizePixel = 0
	questCardRightEdgeMask.Position = UDim2.fromOffset(
		LIST_X + LIST_WIDTH - 4,
		LIST_Y
	)
	questCardRightEdgeMask.Size = UDim2.fromOffset(5, LIST_HEIGHT)
	questCardRightEdgeMask.ZIndex = 252
	questCardRightEdgeMask.Parent = overlay
	controller.questCardRightEdgeMask = questCardRightEdgeMask

	-- Bottom-right decoration.
	-- This asset was supplied separately, so it is used without ImageRect cropping.
	local cornerDecoration = makeImage(
		overlay,
		"CornerDecoration",
		ASSETS.CornerDecoration,
		UDim2.fromOffset(1000, 1090),
		UDim2.fromOffset(185, 225),
		208,
		CROPS.CornerDecoration
	)
	controller.cornerDecoration = cornerDecoration

	local function updateScrollbar()
		local contentHeight = math.max(
			listLayout.AbsoluteContentSize.Y,
			list.AbsoluteCanvasSize.Y
		)
		local viewportHeight = math.max(1, list.AbsoluteWindowSize.Y)

		if contentHeight <= viewportHeight + 1 then
			scrollbarThumb.Visible = false
			setArtworkTransparency(scrollbarTrack, 0.45)
			return
		end

		scrollbarThumb.Visible = true
		setArtworkTransparency(scrollbarTrack, 0)

		local trackHeight = scrollbarTrack.AbsoluteSize.Y
		if trackHeight <= 0 then
			return
		end

		local ratio = math.clamp(viewportHeight / contentHeight, 0.08, 1)
		local thumbHeight = math.max(48, math.floor(trackHeight * ratio))
		local maxThumbTravel = math.max(0, trackHeight - thumbHeight)

		local maxCanvasY = math.max(1, contentHeight - viewportHeight)
		local scrollRatio = math.clamp(list.CanvasPosition.Y / maxCanvasY, 0, 1)
		local thumbY = math.floor(maxThumbTravel * scrollRatio)

		scrollbarThumb.Position = UDim2.fromOffset(
			1146,
			LIST_Y + thumbY
		)
		scrollbarThumb.Size = UDim2.fromOffset(14, thumbHeight)
	end

	controller.updateScrollbar = updateScrollbar

	local function getMaxCanvasY()
		return math.max(
			0,
			list.AbsoluteCanvasSize.Y - list.AbsoluteWindowSize.Y
		)
	end

	local function setCanvasY(newY)
		list.CanvasPosition = Vector2.new(
			0,
			math.clamp(newY, 0, getMaxCanvasY())
		)
	end

	local function updateCanvasForQuestCount(questCount)
		questCount = math.max(0, math.floor(tonumber(questCount) or 0))

		local contentHeight = 0
		if questCount > 0 then
			contentHeight = (questCount * CARD_HEIGHT)
				+ ((questCount - 1) * CARD_GAP)
				+ QUEST_SCROLL_BOTTOM_PADDING
		end

		list.CanvasSize = UDim2.fromOffset(0, contentHeight)
		task.defer(updateScrollbar)
	end

	controller.updateCanvasForQuestCount = updateCanvasForQuestCount

	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		task.defer(updateScrollbar)
	end)

	list:GetPropertyChangedSignal("CanvasPosition"):Connect(updateScrollbar)
	list:GetPropertyChangedSignal("AbsoluteWindowSize"):Connect(updateScrollbar)

	-- Mouse wheel: the transparent catcher guarantees the event is received
	-- even when the cursor is over a quest card.
	local wheelDirectionMultiplier = nil

	scrollInputCatcher.InputChanged:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseWheel then
			return
		end

		local delta = tonumber(input.Position.Z) or 0
		if delta == 0 then
			return
		end

		-- macOS natural scrolling can reverse the wheel sign.
		-- On the first wheel event at the top, assume the player is trying
		-- to move down and remember the correct direction for this session.
		if wheelDirectionMultiplier == nil then
			if list.CanvasPosition.Y <= 1 then
				wheelDirectionMultiplier = delta > 0 and 1 or -1
			else
				wheelDirectionMultiplier = -1
			end
		end

		setCanvasY(
			list.CanvasPosition.Y
				+ (delta * wheelDirectionMultiplier * QUEST_SCROLL_WHEEL_STEP)
		)
	end)

	-- Click/touch and drag anywhere inside the quest list.
	local activeListInput = nil
	local listDragStartY = 0
	local listDragStartCanvasY = 0

	scrollInputCatcher.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			activeListInput = input
			listDragStartY = input.Position.Y
			listDragStartCanvasY = list.CanvasPosition.Y
		end
	end)

	controller.listDragChangedConnection = UserInputService.InputChanged:Connect(function(input)
		if not activeListInput then
			return
		end

		local currentY = nil

		if activeListInput.UserInputType == Enum.UserInputType.Touch then
			if input ~= activeListInput then
				return
			end
			currentY = input.Position.Y
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			currentY = input.Position.Y
		end

		if currentY == nil then
			return
		end

		setCanvasY(
			listDragStartCanvasY
			- (currentY - listDragStartY)
		)
	end)

	controller.listDragEndedConnection = UserInputService.InputEnded:Connect(function(input)
		if input == activeListInput
			or input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeListInput = nil
		end
	end)

	-- Drag the blue scrollbar thumb.
	local activeThumbInput = nil
	local thumbDragStartY = 0
	local thumbDragStartCanvasY = 0

	scrollbarThumb.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			activeThumbInput = input
			thumbDragStartY = input.Position.Y
			thumbDragStartCanvasY = list.CanvasPosition.Y
		end
	end)

	controller.thumbDragChangedConnection = UserInputService.InputChanged:Connect(function(input)
		if not activeThumbInput then
			return
		end

		local currentY = nil

		if activeThumbInput.UserInputType == Enum.UserInputType.Touch then
			if input ~= activeThumbInput then
				return
			end
			currentY = input.Position.Y
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			currentY = input.Position.Y
		end

		if currentY == nil then
			return
		end

		local trackHeight = math.max(1, scrollbarTrack.AbsoluteSize.Y)
		local thumbHeight = math.max(1, scrollbarThumb.AbsoluteSize.Y)
		local maxThumbTravel = math.max(1, trackHeight - thumbHeight)

		setCanvasY(
			thumbDragStartCanvasY
				+ (
					(currentY - thumbDragStartY)
					/ maxThumbTravel
					* getMaxCanvasY()
				)
		)
	end)

	controller.thumbDragEndedConnection = UserInputService.InputEnded:Connect(function(input)
		if input == activeThumbInput
			or input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeThumbInput = nil
		end
	end)

	-- Clicking the scrollbar track jumps directly to that part of the list.
	scrollbarTrack.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end

		local localY = input.Position.Y - scrollbarTrack.AbsolutePosition.Y
		local ratio = math.clamp(
			localY / math.max(1, scrollbarTrack.AbsoluteSize.Y),
			0,
			1
		)

		setCanvasY(getMaxCanvasY() * ratio)
	end)

	local function refreshStateFromServer()
		local success, result = pcall(function()
			return getState:InvokeServer()
		end)

		if success and type(result) == "table" then
			controller.state = result
			controller:Render()
		end
	end

	controller.refreshStateFromServer = refreshStateFromServer

	function controller:SetState(newState)
		self.state = newState

		if self.root.Visible then
			self:Render()
		end
	end

	function controller:GetPeriod()
		local questTable = getQuestTable(self.state)
		return questTable and questTable[self.activePeriod] or nil
	end

	function controller:UpdateTabs()
		for _, periodName in ipairs(PERIODS) do
			local selected = periodName == self.activePeriod
			local button = self.tabButtons[periodName]
			local label = self.tabLabels[periodName]
			local tint = self.tabTints[periodName]

			setArtworkColor(
				button,
				selected
					and Color3.fromRGB(255, 255, 255)
					or Color3.fromRGB(150, 155, 165)
			)

			if tint then
				tint.Visible = selected
			end

			label.TextColor3 = selected
				and Color3.fromRGB(255, 255, 255)
				or Color3.fromRGB(225, 225, 228)

			label.TextStrokeTransparency = selected and 0.08 or 0.28
		end
	end

	function controller:UpdateHeader()
		local period = self:GetPeriod()
		local quests = period and period.quests or {}

		local completedCount = 0
		for _, quest in ipairs(quests) do
			if quest.completed == true
				or (tonumber(quest.progress) or 0) >= math.max(1, tonumber(quest.target) or 1) then
				completedCount += 1
			end
		end

		self.headerTitle.Text = PERIOD_TITLES[self.activePeriod]
		self.completedText.Text = string.format(
			"%d/%d complete",
			completedCount,
			#quests
		)
	end

	function controller:UpdateTimer()
		local now = DateTime.now().UnixTimestamp
		local resetAt = getNextResetTimestamp(self.activePeriod, now)
		local remaining = resetAt - now

		self.timerText.Text = formatRemainingTime(remaining)

		if remaining <= 0 and os.clock() - self.lastResetRefreshAt > 2 then
			self.lastResetRefreshAt = os.clock()
			task.defer(refreshStateFromServer)
		end
	end

	function controller:ClearCards()
		for _, child in ipairs(self.list:GetChildren()) do
			if child:IsA("GuiObject") then
				child:Destroy()
			end
		end
	end

	function controller:MakeRewardBox(card, x, iconKey, value, suffix)
		local rewardBox = makeImage(
			card,
			iconKey .. "RewardBox",
			ASSETS.RewardBox,
			UDim2.fromOffset(x, 134),
			UDim2.fromOffset(132, 70),
			204,
			CROPS.RewardBox
		)

		local icon = makeImage(
			rewardBox,
			"Icon",
			ASSETS[iconKey],
			UDim2.fromOffset(8, 10),
			UDim2.fromOffset(46, 48),
			206,
			CROPS[iconKey]
		)

		local valueText = makeText(
			rewardBox,
			"Value",
			tostring(math.floor(tonumber(value) or 0)),
			29,
			Color3.fromRGB(255, 255, 255)
		)
		valueText.Position = UDim2.fromOffset(54, 4)
		valueText.Size = UDim2.fromOffset(72, suffix and 34 or 60)
		valueText.TextXAlignment = Enum.TextXAlignment.Center
		valueText.ZIndex = 207

		if suffix then
			local suffixText = makeText(
				rewardBox,
				"Suffix",
				suffix,
				20,
				Color3.fromRGB(120, 216, 255),
				Enum.Font.GothamBold
			)
			suffixText.Position = UDim2.fromOffset(54, 35)
			suffixText.Size = UDim2.fromOffset(72, 24)
			suffixText.TextXAlignment = Enum.TextXAlignment.Center
			suffixText.TextStrokeTransparency = 0.15
			suffixText.ZIndex = 207
		end
	end

	function controller:MakeQuestCard(quest, index, period)
		local card = makeImage(
			self.list,
			"QuestCard_" .. tostring(quest.id or index),
			ASSETS.QuestCard,
			UDim2.fromOffset(0, 0),
			UDim2.fromOffset(LIST_WIDTH, CARD_HEIGHT),
			200
		)
		card.LayoutOrder = index

		local iconKey = getObjectiveIconKey(quest, index)
		local icon = makeImage(
			card,
			"QuestIcon",
			ASSETS[iconKey],
			UDim2.fromOffset(24, 26),
			UDim2.fromOffset(166, 166),
			203,
			CROPS[iconKey]
		)

		local title = makeText(
			card,
			"QuestTitle",
			quest.title or "Quest",
			38,
			Color3.fromRGB(255, 255, 255)
		)
		title.Position = UDim2.fromOffset(220, 24)
		title.Size = UDim2.fromOffset(535, 52)
		title.TextTruncate = Enum.TextTruncate.AtEnd
		title.ZIndex = 204

		local description = makeText(
			card,
			"QuestDescription",
			quest.description or "",
			25,
			Color3.fromRGB(78, 205, 255),
			Enum.Font.GothamBold
		)
		description.Position = UDim2.fromOffset(220, 74)
		description.Size = UDim2.fromOffset(535, 52)
		description.TextWrapped = true
		description.TextStrokeTransparency = 0.4
		description.ZIndex = 204

		local target = math.max(1, math.floor(tonumber(quest.target) or 1))
		local progress = math.clamp(
			math.floor(tonumber(quest.progress) or 0),
			0,
			target
		)
		local complete = quest.completed == true or progress >= target

		local track = makeImage(
			card,
			"ProgressTrack",
			ASSETS.ProgressTrack,
			UDim2.fromOffset(220, 145),
			UDim2.fromOffset(516, 52),
			203
		)
		track.ClipsDescendants = true

		local fillHolder = Instance.new("Frame")
		fillHolder.Name = "FillHolder"
		fillHolder.BackgroundTransparency = 1
		fillHolder.Position = UDim2.fromOffset(4, 4)
		fillHolder.Size = UDim2.new(1, -8, 1, -8)
		fillHolder.ClipsDescendants = true
		fillHolder.ZIndex = 204
		fillHolder.Parent = track
		addCorner(fillHolder, 20)

		local ratio = math.clamp(progress / target, 0, 1)

		if complete then
			local greenFill = makeImage(
				fillHolder,
				"GreenFill",
				ASSETS.ProgressGreenFill,
				UDim2.fromOffset(0, 0),
				UDim2.fromScale(1, 1),
				204
			)
		else
			local blueFill = Instance.new("Frame")
			blueFill.Name = "BlueFill"
			blueFill.BackgroundColor3 = Color3.fromRGB(0, 139, 255)
			blueFill.BorderSizePixel = 0
			blueFill.Size = UDim2.new(ratio, 0, 1, 0)
			blueFill.ZIndex = 204
			blueFill.Parent = fillHolder
			addCorner(blueFill, 20)

			local gradient = Instance.new("UIGradient")
			gradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 221, 255)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 106, 255)),
			})
			gradient.Rotation = 90
			gradient.Parent = blueFill
		end

		local progressText = makeText(
			track,
			"ProgressText",
			string.format("%d/%d", progress, target),
			31,
			Color3.fromRGB(255, 255, 255)
		)
		progressText.Size = UDim2.fromScale(1, 1)
		progressText.TextXAlignment = Enum.TextXAlignment.Center
		progressText.TextStrokeTransparency = 0
		progressText.ZIndex = 206

		local statusImage = complete and ASSETS.StatusGreen or ASSETS.StatusBlue
		local status = makeImage(
			card,
			"StatusBadge",
			statusImage,
			UDim2.fromOffset(785, 24),
			UDim2.fromOffset(261, 62),
			203
		)

		local statusLabel = makeText(
			status,
			"StatusText",
			complete and "✓  Completed" or "In Progress",
			28,
			complete
				and Color3.fromRGB(85, 255, 35)
				or Color3.fromRGB(0, 224, 255),
			Enum.Font.GothamBold
		)
		statusLabel.Size = UDim2.fromScale(1, 1)
		statusLabel.TextXAlignment = Enum.TextXAlignment.Center
		statusLabel.TextStrokeTransparency = 0.15
		statusLabel.ZIndex = 205

		local rewardsLabel = makeText(
			card,
			"RewardsLabel",
			"Rewards",
			25,
			Color3.fromRGB(72, 210, 255),
			Enum.Font.GothamBold
		)
		rewardsLabel.Position = UDim2.fromOffset(785, 96)
		rewardsLabel.Size = UDim2.fromOffset(250, 34)
		rewardsLabel.TextStrokeTransparency = 0.35
		rewardsLabel.ZIndex = 204

		local reward = quest.reward or {}
		self:MakeRewardBox(
			card,
			785,
			"MoneyIcon",
			reward.coins or 0,
			nil
		)
		self:MakeRewardBox(
			card,
			925,
			"XPIcon",
			reward.xp or 0,
			"XP"
		)

		if complete
			and not quest.claimed
			and AUTO_CLAIM_COMPLETED_QUESTS then
			local periodKey = period and period.periodKey or "unknown"
			local claimKey = table.concat({
				self.activePeriod,
				tostring(periodKey),
				tostring(quest.id),
			}, ":")

			if not self.claimRequests[claimKey] then
				self.claimRequests[claimKey] = true

				task.delay(0.25, function()
					questAction:FireServer(
						"Claim",
						self.activePeriod,
						quest.id
					)
				end)

				task.delay(5, function()
					self.claimRequests[claimKey] = nil
				end)
			end
		end

		return card
	end

	function controller:RenderCards()
		self:ClearCards()

		local period = self:GetPeriod()
		local quests = period and period.quests or {}

		if #quests == 0 then
			local empty = makeText(
				self.list,
				"EmptyText",
				"Loading quests...",
				34,
				Color3.fromRGB(220, 235, 255)
			)
			empty.Size = UDim2.fromOffset(LIST_WIDTH, 100)
			empty.TextXAlignment = Enum.TextXAlignment.Center
			empty.LayoutOrder = 1
			self.updateCanvasForQuestCount(1)
			return
		end

		for index, quest in ipairs(quests) do
			self:MakeQuestCard(quest, index, period)
		end

		self.updateCanvasForQuestCount(#quests)
	end

	function controller:Render()
		if not self.root.Parent then
			return
		end

		self:UpdateTabs()
		self:UpdateHeader()
		self:UpdateTimer()
		self:RenderCards()
	end

	function controller:SetVisible(visible)
		visible = visible == true
		self.root.Visible = visible
		self.setQuestBlurVisible(visible)

		-- The game's custom hotbar is used instead of Roblox's default Backpack UI.
		-- Keep CoreGui Backpack disabled both while opening and closing Quest UI.
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
		end)

		self.backpackWasEnabled = false

		if visible then
			self.startLegacyQuestSuppression()

			self:Render()
			task.defer(self.updateScrollbar)
		else
			self.stopLegacyQuestSuppression()
			restoreLegacyQuestUi(self.hiddenLegacyQuestGuis)
		end
	end

	function controller:IsVisible()
		return self.root.Visible
	end

	function controller:Destroy()
		self.stopLegacyQuestSuppression()

		if self.blurTween then
			self.blurTween:Cancel()
			self.blurTween = nil
		end

		if self.questBlur then
			self.questBlur.Size = 0
			self.questBlur.Enabled = false
		end

		-- Never restore Roblox's default Backpack UI.
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
		end)
		self.backpackWasEnabled = false

		restoreLegacyQuestUi(self.hiddenLegacyQuestGuis)

		if self.stateConnection then
			self.stateConnection:Disconnect()
		end

		if self.timerConnection then
			self.timerConnection:Disconnect()
		end

		if self.viewportConnection then
			self.viewportConnection:Disconnect()
		end

		if self.listDragChangedConnection then
			self.listDragChangedConnection:Disconnect()
		end

		if self.listDragEndedConnection then
			self.listDragEndedConnection:Disconnect()
		end

		if self.thumbDragChangedConnection then
			self.thumbDragChangedConnection:Disconnect()
		end

		if self.thumbDragEndedConnection then
			self.thumbDragEndedConnection:Disconnect()
		end

		if self.root then
			self.root:Destroy()
		end
	end

	controller.stateConnection = stateUpdated.OnClientEvent:Connect(function(newState)
		controller.state = newState

		if controller.root.Visible then
			controller:Render()
		end
	end)

	controller.timerConnection = RunService.RenderStepped:Connect(function()
		if not controller.root.Visible then
			return
		end

		controller.clockHand.Rotation = (os.clock() * 120) % 360

		local second = math.floor(os.clock())
		if controller.lastTimerSecond ~= second then
			controller.lastTimerSecond = second
			controller:UpdateTimer()
		end
	end)

	task.spawn(refreshStateFromServer)

	return controller
end

return QuestModernUI
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="13">
      <Properties>
        <string name="Name">BagModernUI</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{46c5acac-56d7-432e-8169-2e6d17ef7105}</string>
        <string name="Source"><![CDATA[local BagModernUI = {}

local BASE_WIDTH = 1448
local BASE_HEIGHT = 1086

local ASSETS = {
	Backbone = "rbxassetid://108283623894606",
	TabNormal = "rbxassetid://101135473927300",
	TabSelected = "rbxassetid://106120450577925",
	RodTabIcon = "rbxassetid://77887294460644",
	BaitTabIcon = "rbxassetid://126189479051414",
	FishTabIcon = "rbxassetid://116369556818073",
	CloseButton = "rbxassetid://74437026548245",
	EquippedButton = "rbxassetid://97877042422133",
	SelectedOutline = "rbxassetid://78993001328940",
	ItemRowBackground = "rbxassetid://78930126580653",
	FishStorageHeader = "rbxassetid://94190047330110",
	BaitItemFrame = "rbxassetid://131578062209953",
	LeftDecoration = "rbxassetid://94493748436318",
	RightDecoration = "rbxassetid://107757008760729",

	FishFrames = {
		Common = "rbxassetid://82476012961179",
		Uncommon = "rbxassetid://109344755835178",
		Rare = "rbxassetid://134980793266582",
		Epic = "rbxassetid://78420747823288",
		Legendary = "rbxassetid://108344811627544",
		Mythic = "rbxassetid://128483019144117",
	},

	RodFrames = {
		WoodenRod = "rbxassetid://115934227658772",
		IronRod = "rbxassetid://71831440264510",
		GoldenRod = "rbxassetid://76246999880343",
		EmeraldRod = "rbxassetid://110828755102690",
		OceanRod = "rbxassetid://130788881686757",
	},

	BaitImages = {
		BasicBait = "rbxassetid://87143554943451",
		FreshBait = "rbxassetid://114397365249536",
		TastyBait = "rbxassetid://89693745580563",
		LuckyBait = "rbxassetid://90876615894262",
		GlowBait = "rbxassetid://140507231143381",
		MysticBait = "rbxassetid://91652408607528",
		PondGuardianBait = "rbxassetid://117293437837187",
	},
}

local ui = {
	root = nil,
	canvas = nil,
	scale = nil,
	content = nil,
	selectedTab = "Rods",
	context = nil,
	viewportConnection = nil,
}

local function makeImage(parent, name, image, position, size, zIndex, scaleType)
	local object = Instance.new("ImageLabel")
	object.Name = name
	object.BackgroundTransparency = 1
	object.Position = position
	object.Size = size
	object.Image = image or ""
	object.ScaleType = scaleType or Enum.ScaleType.Fit
	object.ZIndex = zIndex or 302
	object.Parent = parent
	return object
end

local function makeImageButton(parent, name, image, position, size, zIndex, scaleType)
	local object = Instance.new("ImageButton")
	object.Name = name
	object.BackgroundTransparency = 1
	object.Position = position
	object.Size = size
	object.Image = image or ""
	object.ScaleType = scaleType or Enum.ScaleType.Fit
	object.AutoButtonColor = false
	object.ZIndex = zIndex or 304
	object.Parent = parent
	return object
end

local function makeLabel(parent, name, text, position, size, textSize, zIndex, color, alignment)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Position = position
	label.Size = size
	label.Font = Enum.Font.FredokaOne
	label.Text = text or ""
	label.TextColor3 = color or Color3.new(1, 1, 1)
	label.TextSize = textSize or 28
	label.TextScaled = false
	label.TextWrapped = false
	label.TextXAlignment = alignment or Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.TextStrokeColor3 = Color3.new(0, 0, 0)
	label.TextStrokeTransparency = 0.35
	label.ZIndex = zIndex or 306
	label.Parent = parent
	return label
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function addStroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or 0
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	stroke.Parent = parent
	return stroke
end

local function addTextConstraint(label, minSize, maxSize)
	local constraint = Instance.new("UITextSizeConstraint")
	constraint.MinTextSize = minSize
	constraint.MaxTextSize = maxSize
	constraint.Parent = label
	return constraint
end

local function clear(parent)
	for _, child in ipairs(parent:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function updateScale()
	if not ui.scale then
		return
	end

	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)
	-- Keep the Bag clearly smaller than the full screen.
	local widthScale = viewport.X * 0.80 / BASE_WIDTH
	local heightScale = viewport.Y * 0.76 / BASE_HEIGHT
	ui.scale.Scale = math.clamp(math.min(widthScale, heightScale), 0.28, 0.82)
end

local function buildBase(parent)
	if ui.root and ui.root.Parent == parent then
		return
	end

	if ui.viewportConnection then
		ui.viewportConnection:Disconnect()
		ui.viewportConnection = nil
	end

	if ui.root then
		ui.root:Destroy()
	end

	local root = Instance.new("Frame")
	root.Name = "ModernBagRoot"
	root.BackgroundTransparency = 1
	root.Size = UDim2.fromScale(1, 1)
	root.Active = true
	root.Visible = false
	root.ZIndex = 300
	root.Parent = parent
	ui.root = root

	local canvas = Instance.new("Frame")
	canvas.Name = "Canvas"
	canvas.AnchorPoint = Vector2.new(0.5, 0.5)
	canvas.Position = UDim2.fromScale(0.5, 0.5)
	canvas.Size = UDim2.fromOffset(BASE_WIDTH, BASE_HEIGHT)
	canvas.BackgroundTransparency = 1
	canvas.ZIndex = 301
	canvas.Parent = root
	ui.canvas = canvas

	local scale = Instance.new("UIScale")
	scale.Name = "ResponsiveScale"
	scale.Parent = canvas
	ui.scale = scale

	makeImage(
		canvas,
		"Backbone",
		ASSETS.Backbone,
		UDim2.fromOffset(0, 0),
		UDim2.fromOffset(BASE_WIDTH, BASE_HEIGHT),
		301,
		Enum.ScaleType.Stretch
	)

	makeImage(
		canvas,
		"BagDecoration",
		ASSETS.LeftDecoration,
		UDim2.fromOffset(72, 18),
		UDim2.fromOffset(195, 165),
		305,
		Enum.ScaleType.Fit
	)

	local title = makeLabel(
		canvas,
		"Title",
		"Bag",
		UDim2.fromOffset(305, 42),
		UDim2.fromOffset(300, 105),
		70,
		306,
		Color3.new(1, 1, 1),
		Enum.TextXAlignment.Left
	)
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = Color3.fromRGB(14, 20, 30)

	local closeButton = makeImageButton(
		canvas,
		"CloseButton",
		ASSETS.CloseButton,
		UDim2.fromOffset(1278, 42),
		UDim2.fromOffset(92, 92),
		310,
		Enum.ScaleType.Fit
	)
	closeButton.MouseButton1Click:Connect(function()
		BagModernUI.hide()
		if ui.context and ui.context.onClose then
			ui.context.onClose()
		end
	end)

	local content = Instance.new("ScrollingFrame")
	content.Name = "ItemList"
	content.Position = UDim2.fromOffset(62, 286)
	content.Size = UDim2.fromOffset(1316, 712)
	content.BackgroundTransparency = 1
	content.BorderSizePixel = 0
	content.CanvasSize = UDim2.new(0, 0, 0, 0)
	content.AutomaticCanvasSize = Enum.AutomaticSize.Y
	content.ScrollBarThickness = 18
	content.ScrollBarImageColor3 = Color3.fromRGB(0, 112, 255)
	content.ScrollBarImageTransparency = 0
	content.ScrollingDirection = Enum.ScrollingDirection.Y
	content.VerticalScrollBarInset = Enum.ScrollBarInset.Always
	content.ZIndex = 304
	content.Parent = canvas
	ui.content = content

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 2)
	padding.PaddingRight = UDim.new(0, 30)
	padding.PaddingTop = UDim.new(0, 2)
	padding.PaddingBottom = UDim.new(0, 18)
	padding.Parent = content

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Vertical
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 12)
	layout.Parent = content

	local camera = workspace.CurrentCamera
	if camera then
		ui.viewportConnection = camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
	end
	updateScale()
end

local function makeTab(id, labelText, icon, x)
	local selected = ui.selectedTab == id
	local button = makeImageButton(
		ui.canvas,
		id .. "Tab",
		selected and ASSETS.TabSelected or ASSETS.TabNormal,
		UDim2.fromOffset(x, 170),
		UDim2.fromOffset(350, 110),
		306,
		Enum.ScaleType.Stretch
	)

	makeImage(
		button,
		"Icon",
		icon,
		UDim2.fromOffset(24, 10),
		UDim2.fromOffset(88, 90),
		308,
		Enum.ScaleType.Fit
	)

	local label = makeLabel(
		button,
		"Label",
		labelText,
		UDim2.fromOffset(108, 10),
		UDim2.fromOffset(224, 88),
		36,
		309,
		Color3.new(1, 1, 1),
		Enum.TextXAlignment.Center
	)
	label.TextScaled = true
	addTextConstraint(label, 18, 36)

	button.MouseButton1Click:Connect(function()
		if ui.selectedTab ~= id then
			ui.selectedTab = id
			BagModernUI.refresh()
		end
	end)
end

local function makeNormalButton(parent, text, enabled, callback)
	local button = Instance.new("TextButton")
	button.Name = "ActionButton"
	button.AnchorPoint = Vector2.new(1, 0.5)
	button.Position = UDim2.new(1, -34, 0.5, 0)
	button.Size = UDim2.fromOffset(206, 72)
	button.BackgroundColor3 = enabled and Color3.fromRGB(4, 35, 78) or Color3.fromRGB(45, 55, 70)
	button.AutoButtonColor = enabled
	button.Font = Enum.Font.FredokaOne
	button.Text = text
	button.TextColor3 = Color3.new(1, 1, 1)
	button.TextSize = 28
	button.TextStrokeColor3 = Color3.new(0, 0, 0)
	button.TextStrokeTransparency = 0.35
	button.ZIndex = 310
	button.Parent = parent
	addCorner(button, 14)
	addStroke(button, enabled and Color3.fromRGB(0, 112, 255) or Color3.fromRGB(90, 105, 125), 2, 0.08)

	if enabled and callback then
		button.MouseButton1Click:Connect(callback)
	end

	return button
end

local function makeEquippedButton(parent)
	local button = makeImage(
		parent,
		"EquippedButton",
		ASSETS.EquippedButton,
		UDim2.new(1, -240, 0.5, -36),
		UDim2.fromOffset(206, 72),
		310,
		Enum.ScaleType.Stretch
	)

	local label = makeLabel(
		button,
		"Label",
		"Equipped",
		UDim2.fromScale(0, 0),
		UDim2.fromScale(1, 1),
		27,
		311,
		Color3.new(1, 1, 1),
		Enum.TextXAlignment.Center
	)
	label.TextScaled = true
	addTextConstraint(label, 18, 28)
end

local function makeRow(height, equipped)
	local wrapper = Instance.new("Frame")
	wrapper.Name = "ItemRow"
	wrapper.Size = UDim2.new(1, -4, 0, height)
	wrapper.BackgroundTransparency = 1
	wrapper.ZIndex = 304
	wrapper.Parent = ui.content

	local background = makeImage(
		wrapper,
		"Background",
		ASSETS.ItemRowBackground,
		UDim2.fromScale(0, 0),
		UDim2.fromScale(1, 1),
		305,
		Enum.ScaleType.Stretch
	)

	if equipped then
		makeImage(
			background,
			"SelectedOutline",
			ASSETS.SelectedOutline,
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			306,
			Enum.ScaleType.Stretch
		)
	end

	return background
end

local function renderRods(context)
	local state = context.state or {}
	local gameConfig = context.GameConfig
	local ownedRods = state.OwnedRods or {}
	local rendered = 0

	for _, rodId in ipairs(gameConfig.RodOrder or {}) do
		if ownedRods[rodId] then
			rendered += 1
			local rod = gameConfig.Rods[rodId]
			local equipped = state.EquippedRod == rodId
			local row = makeRow(142, equipped)

			local frame = makeImage(
				row,
				"RodFrame",
				ASSETS.RodFrames[rodId] or ASSETS.RodFrames.WoodenRod,
				UDim2.fromOffset(28, 7),
				UDim2.fromOffset(128, 128),
				307,
				Enum.ScaleType.Fit
			)

			local rodImage = gameConfig.getRodImage and gameConfig.getRodImage(rodId) or ""
			makeImage(
				frame,
				"RodIcon",
				rodImage,
				UDim2.fromScale(0.10, 0.10),
				UDim2.fromScale(0.80, 0.80),
				308,
				Enum.ScaleType.Fit
			)

			makeLabel(
				row,
				"RodName",
				rod and rod.displayName or rodId,
				UDim2.fromOffset(190, 18),
				UDim2.fromOffset(650, 52),
				34,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)

			local speedPercent = math.floor((1 / math.max(tonumber(rod and rod.speed) or 1, 0.001)) * 100 + 0.5)
			local luckPercent = math.floor((tonumber(rod and rod.luck) or 0) * 100 + 0.5)

			makeLabel(
				row,
				"Speed",
				"Speed: " .. tostring(speedPercent) .. "%",
				UDim2.fromOffset(190, 79),
				UDim2.fromOffset(260, 38),
				25,
				309,
				Color3.fromRGB(0, 230, 255),
				Enum.TextXAlignment.Left
			)

			makeLabel(
				row,
				"Luck",
				"Luck: +" .. tostring(luckPercent) .. "%",
				UDim2.fromOffset(470, 79),
				UDim2.fromOffset(270, 38),
				25,
				309,
				Color3.fromRGB(180, 255, 0),
				Enum.TextXAlignment.Left
			)

			if equipped then
				makeEquippedButton(row)
			else
				makeNormalButton(row, "Equip", true, function()
					if context.equipRod then
						context.equipRod(rodId)
					end
				end)
			end
		end
	end

	if rendered == 0 then
		local row = makeRow(142, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No fishing rods owned.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
	end
end

local function renderBait(context)
	local state = context.state or {}
	local gameConfig = context.GameConfig
	local rendered = 0

	for _, baitId in ipairs(gameConfig.BaitOrder or {}) do
		local bait = gameConfig.Baits and gameConfig.Baits[baitId]
		local count = context.getBaitCount and context.getBaitCount(baitId) or 0
		local isBasic = baitId == gameConfig.BasicBaitId
		local owned = isBasic or count > 0

		if bait and owned then
			rendered += 1
			local equipped = state.EquippedBait == baitId
			local row = makeRow(142, equipped)

			local frame = Instance.new("Frame")
			frame.Name = "BaitFrame"
			frame.BackgroundColor3 = Color3.fromRGB(3, 18, 49)
			frame.BackgroundTransparency = 0.05
			frame.Position = UDim2.fromOffset(28, 7)
			frame.Size = UDim2.fromOffset(128, 128)
			frame.ClipsDescendants = true
			frame.ZIndex = 307
			frame.Parent = row
			addCorner(frame, 10)
			addStroke(frame, Color3.fromRGB(0, 103, 255), 2, 0.05)

			local baitImage = ""
			if gameConfig.getBaitImage then
				baitImage = gameConfig.getBaitImage(baitId) or ""
			end
			if baitImage == "" then
				baitImage = ASSETS.BaitImages[baitId] or ""
			end

			local baitIcon = makeImage(
				frame,
				"BaitIcon",
				baitImage,
				UDim2.fromScale(0.06, 0.06),
				UDim2.fromScale(0.88, 0.88),
				308,
				Enum.ScaleType.Fit
			)
			baitIcon.ClipsDescendants = true

			makeLabel(
				row,
				"BaitName",
				bait.displayName,
				UDim2.fromOffset(190, 18),
				UDim2.fromOffset(650, 52),
				34,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)

			local quantity = isBasic and "Unlimited" or tostring(count)
			makeLabel(
				row,
				"Quantity",
				"Quantity: " .. quantity,
				UDim2.fromOffset(190, 77),
				UDim2.fromOffset(320, 38),
				25,
				309,
				equipped and Color3.fromRGB(112, 255, 156) or Color3.fromRGB(190, 204, 220),
				Enum.TextXAlignment.Left
			)

			makeLabel(
				row,
				"Description",
				bait.description or "",
				UDim2.fromOffset(500, 77),
				UDim2.fromOffset(410, 38),
				21,
				309,
				Color3.fromRGB(150, 175, 205),
				Enum.TextXAlignment.Left
			)

			if equipped then
				makeEquippedButton(row)
			else
				makeNormalButton(row, "Equip", true, function()
					if context.equipBait then
						context.equipBait(baitId)
					end
				end)
			end
		end
	end

	if rendered == 0 then
		local row = makeRow(142, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No bait owned.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
	end
end

local function renderFish(context)
	local state = context.state or {}
	local gameConfig = context.GameConfig
	local inventory = state.Inventory or {}
	local canEdit = state.AquariumView and state.AquariumView.CanEdit == true

	local header = Instance.new("Frame")
	header.Name = "FishStorageHeader"
	header.Size = UDim2.new(1, -4, 0, 104)
	header.BackgroundTransparency = 1
	header.ZIndex = 304
	header.Parent = ui.content

	local headerImage = makeImage(
		header,
		"Background",
		ASSETS.FishStorageHeader,
		UDim2.fromScale(0, 0),
		UDim2.fromScale(1, 1),
		305,
		Enum.ScaleType.Stretch
	)

	makeLabel(
		headerImage,
		"Storage",
		string.format("Fish Storage: %d / %d", #inventory, tonumber(state.BackpackSize) or 0),
		UDim2.fromOffset(34, 10),
		UDim2.fromOffset(600, 84),
		31,
		307,
		Color3.new(1, 1, 1),
		Enum.TextXAlignment.Left
	)

	makeLabel(
		headerImage,
		"Value",
		string.format("Bag Value: %d Coins", tonumber(state.InventoryValue) or 0),
		UDim2.new(1, -600, 0, 10),
		UDim2.fromOffset(550, 84),
		29,
		307,
		Color3.fromRGB(255, 220, 80),
		Enum.TextXAlignment.Right
	)

	if #inventory == 0 then
		local row = makeRow(142, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No fish stored in your bag.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
		return
	end

	for index = #inventory, 1, -1 do
		local fish = inventory[index]
		local rarity = fish.rarity or "Common"
		if rarity == "Mythical" then
			rarity = "Mythic"
		end
		local rarityColor = (gameConfig.RarityColors and gameConfig.RarityColors[rarity]) or Color3.new(1, 1, 1)
		local row = makeRow(142, false)

		local frame = makeImage(
			row,
			"FishFrame",
			ASSETS.FishFrames[rarity] or ASSETS.FishFrames.Common,
			UDim2.fromOffset(28, 7),
			UDim2.fromOffset(128, 128),
			307,
			Enum.ScaleType.Fit
		)

		local fishImage = gameConfig.getFishImage and gameConfig.getFishImage(fish.imageKey or fish.id) or ""
		makeImage(
			frame,
			"FishIcon",
			fishImage,
			UDim2.fromScale(0.12, 0.12),
			UDim2.fromScale(0.76, 0.76),
			308,
			Enum.ScaleType.Fit
		)

		makeLabel(
			row,
			"FishName",
			fish.name or tostring(fish.id),
			UDim2.fromOffset(190, 18),
			UDim2.fromOffset(650, 52),
			34,
			309,
			Color3.new(1, 1, 1),
			Enum.TextXAlignment.Left
		)

		makeLabel(
			row,
			"Rarity",
			rarity,
			UDim2.fromOffset(190, 79),
			UDim2.fromOffset(220, 38),
			25,
			309,
			rarityColor,
			Enum.TextXAlignment.Left
		)

		makeLabel(
			row,
			"Value",
			"Value: " .. tostring(tonumber(fish.value) or 0),
			UDim2.fromOffset(430, 79),
			UDim2.fromOffset(280, 38),
			25,
			309,
			Color3.fromRGB(255, 220, 80),
			Enum.TextXAlignment.Left
		)

		makeNormalButton(
			row,
			canEdit and "Display" or "View Only",
			canEdit,
			function()
				if canEdit and context.displayFish then
					context.displayFish(fish, index)
				end
			end
		)
	end
end

function BagModernUI.refresh()
	if not ui.root or not ui.content or not ui.context then
		return
	end

	clear(ui.content)

	for _, name in ipairs({ "RodsTab", "BaitTab", "FishTab" }) do
		local old = ui.canvas:FindFirstChild(name)
		if old then
			old:Destroy()
		end
	end

	-- 350px tabs with only 16px between them, centered on the 1448px canvas.
	makeTab("Rods", "Fishing Rods", ASSETS.RodTabIcon, 183)
	makeTab("Bait", "Bait", ASSETS.BaitTabIcon, 549)
	makeTab("Fish", "Fish", ASSETS.FishTabIcon, 915)

	if ui.selectedTab == "Rods" then
		renderRods(ui.context)
	elseif ui.selectedTab == "Bait" then
		renderBait(ui.context)
	else
		renderFish(ui.context)
	end

	ui.content.CanvasPosition = Vector2.new(0, 0)
end

function BagModernUI.show(context)
	assert(type(context) == "table", "BagModernUI.show requires a context table")
	assert(context.parent, "BagModernUI.show requires context.parent")
	assert(context.GameConfig, "BagModernUI.show requires context.GameConfig")

	buildBase(context.parent)
	ui.context = context
	ui.root.Visible = true

	-- Never fall back to the old Bag panel if one malformed item causes a
	-- rendering error. Keep the modern window open and show the error in Output.
	local ok, err = xpcall(BagModernUI.refresh, debug.traceback)
	if not ok then
		warn("[BagModernUI] Modern Bag render failed:\n" .. tostring(err))
		clear(ui.content)

		local errorRow = Instance.new("Frame")
		errorRow.Name = "ModernBagError"
		errorRow.Size = UDim2.new(1, -4, 0, 130)
		errorRow.BackgroundColor3 = Color3.fromRGB(35, 15, 24)
		errorRow.BackgroundTransparency = 0.08
		errorRow.ZIndex = 304
		errorRow.Parent = ui.content
		addCorner(errorRow, 16)
		addStroke(errorRow, Color3.fromRGB(255, 80, 100), 2, 0.08)

		local errorLabel = makeLabel(
			errorRow,
			"ErrorText",
			"Modern Bag could not render. Check Output for [BagModernUI].",
			UDim2.fromOffset(24, 18),
			UDim2.new(1, -48, 1, -36),
			24,
			309,
			Color3.fromRGB(255, 210, 220),
			Enum.TextXAlignment.Center
		)
		errorLabel.TextWrapped = true
	end
end

function BagModernUI.hide()
	if ui.root then
		ui.root.Visible = false
	end
end

return BagModernUI
]]></string>
