        <string name="Source"><![CDATA[local ToolHotbarBinder = {}

local function bindContainerTools(container, connectTool)
	if not container then
		return
	end

	for _, child in ipairs(container:GetChildren()) do
		connectTool(child)
	end
	container.ChildAdded:Connect(connectTool)
end

function ToolHotbarBinder.start(deps)
	local player = deps.player
	local setTab = deps.setTab
	local hasPanel = deps.hasPanel
	local watchLegacyAquariumViewerTools = deps.watchLegacyAquariumViewerTools

	task.spawn(function()
		local connectedHudTools = {}

		local function unequipHudTool()
			local character = player.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:UnequipTools()
			end
		end

		local function panelExists(tabName)
			if not hasPanel then
				return true
			end

			return hasPanel(tabName)
		end

		local function connectHudTool(tool)
			if not tool:IsA("Tool") then
				return
			end

			if connectedHudTools[tool] then
				return
			end

			local tabName = nil
			local foundMessage = nil
			local equippedMessage = nil
			local openingMessage = nil
			local missingMessage = nil
			local activatedMessage = nil
			local shouldUnequipAfterOpen = false
			if tool.Name == "Bag" or tool.Name == "Backpack" then
				tabName = "Bag"
				foundMessage = "Bag tool found"
				equippedMessage = "Bag tool equipped"
				openingMessage = "Opening Bag UI"
				missingMessage = "BagPanel not found"
				activatedMessage = "Bag tool activated"
				shouldUnequipAfterOpen = true
			elseif tool.Name == "Fishdex" then
				tabName = "Fishdex"
				foundMessage = "Fishdex tool found"
				equippedMessage = "Fishdex tool equipped"
				openingMessage = "Opening Fishdex UI"
				missingMessage = "FishdexPanel not found"
				activatedMessage = "Fishdex tool activated"
				shouldUnequipAfterOpen = true
			elseif tool.Name == "Aquarium Viewer" then
				tabName = "Aquarium"
			end

			if not tabName then
				return
			end

			connectedHudTools[tool] = true
			if shouldUnequipAfterOpen then
				tool.RequiresHandle = false
				tool.CanBeDropped = false
			end
			if foundMessage then
				print(foundMessage)
			end

			local lastActivatedAt = 0
			local function activateTool(source)
				local now = os.clock()
				if now - lastActivatedAt < 0.2 then
					return
				end
				lastActivatedAt = now

				if source == "Equipped" and equippedMessage then
					print(equippedMessage)
					if tabName == "Bag" then
						print("Bag tool equipped/opening Bag UI")
					elseif tabName == "Fishdex" then
						print("Fishdex tool equipped/opening Fishdex UI")
					end
				elseif source == "Activated" and activatedMessage then
					print(activatedMessage)
				end

				if not panelExists(tabName) then
					if missingMessage then
						warn(missingMessage)
					end
					if shouldUnequipAfterOpen then
						unequipHudTool()
					end
					return
				end

				if openingMessage then
					print(openingMessage)
				end
				setTab(tabName)

				if shouldUnequipAfterOpen then
					unequipHudTool()
				end
			end

			-- Bag/Fishdex are opened from the numbered Roblox hotbar.
			-- A single slot press can fire both Equipped and Activated.
			-- Calling setTab from both events toggles the same panel twice,
			-- which is why Fishdex required another press to close.
			if tabName == "Bag" or tabName == "Fishdex" then
				tool.Equipped:Connect(function()
					activateTool("Equipped")
				end)
			else
				-- Preserve the existing behavior for other tools.
				tool.Equipped:Connect(function()
					activateTool("Equipped")
				end)
				tool.Activated:Connect(function()
					activateTool("Activated")
				end)
			end

			tool.Destroying:Connect(function()
				connectedHudTools[tool] = nil
			end)
		end

		local function bindContainer(container)
			if watchLegacyAquariumViewerTools then
				watchLegacyAquariumViewerTools(container)
			end
			bindContainerTools(container, connectHudTool)
		end

		local backpack = player:WaitForChild("Backpack", 10)
		bindContainer(backpack)
		bindContainer(player.Character)

		player.CharacterAdded:Connect(bindContainer)
	end)
end

return ToolHotbarBinder
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="3">
      <Properties>
        <string name="Name">RemoteActions</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{67278f64-0e6c-4552-8dbe-657d91dda482}</string>
        <string name="Source"><![CDATA[local RemoteActions = {}

function RemoteActions.create(deps)
	local Remotes = deps.Remotes
	local BaitAction = deps.BaitAction
	local QuestAction = deps.QuestAction
	local ShopAction = deps.ShopAction

	local actions = {}

	function actions.fireBaitAction(action, baitId)
		if not BaitAction then
			BaitAction = Remotes:FindFirstChild("BaitAction")
		end

		if BaitAction then
			BaitAction:FireServer(action, baitId)
		else
			warn("BaitAction remote was not available; bait shop actions are disabled until remotes resync.")
		end
	end

	function actions.fireQuestAction(action, periodName, questId)
		if not QuestAction then
			QuestAction = Remotes:FindFirstChild("QuestAction")
		end

		if QuestAction then
			QuestAction:FireServer(action, periodName, questId)
		else
			warn("QuestAction remote was not available; quest claiming is disabled until remotes resync.")
		end
	end

	function actions.fireShopAction(action, category, itemKey, payload)
		if not ShopAction then
			ShopAction = Remotes:FindFirstChild("ShopAction")
		end

		if ShopAction then
			ShopAction:FireServer(action, category, itemKey, payload)
		else
			warn("ShopAction remote was not available; shop actions are disabled until remotes resync.")
		end
	end

	return actions
end

return RemoteActions
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="4">
      <Properties>
        <string name="Name">PlayerGuiDebug</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{7b8e1493-ef67-4be8-8653-f7d17811ad03}</string>
        <string name="Source"><![CDATA[local PlayerGuiDebug = {}

local function getGuiVisibleState(instance)
	if instance:IsA("ScreenGui") then
		return instance.Enabled
	elseif instance:IsA("GuiObject") then
		return instance.Visible
	end

	return "n/a"
end

function PlayerGuiDebug.create(deps)
	local playerGui = deps.playerGui
	local screenGui = deps.screenGui

	local debugTools = {}

	function debugTools.printPlayerGuiChildren()
		for _, child in ipairs(playerGui:GetChildren()) do
			print("PlayerGui child:", child.Name, child.ClassName, getGuiVisibleState(child))
		end
	end

	function debugTools.printFishingGuiChildren()
		for _, child in ipairs(screenGui:GetChildren()) do
			print("FishingGui child:", child.Name, child.ClassName, getGuiVisibleState(child))
		end

		for _, descendant in ipairs(screenGui:GetDescendants()) do
			if descendant.Name == "CoinsHud"
				or descendant.Name == "FishingXPBar"
				or descendant.Name == "TopButtonsFrame"
				or descendant.Name == "SettingsButton"
				or descendant.Name == "QuestsButton"
				or descendant.Name == "ShopButton"
				or descendant.Name == "AutoFishButton"
				or descendant.Name == "TapButton"
			then
				print("FishingGui HUD descendant:", descendant.Name, descendant.ClassName, getGuiVisibleState(descendant))
			end
		end
	end

	function debugTools.printPlayerGuiScreenGuis(context)
		local names = {}
		for _, child in ipairs(playerGui:GetChildren()) do
			if child:IsA("ScreenGui") then
				table.insert(names, child.Name .. " [" .. child:GetFullName() .. "]")
			end
		end
		table.sort(names)
		print("PlayerGui ScreenGui children after spawn:", context, #names > 0 and table.concat(names, ", ") or "(none)")
	end

	return debugTools
end

return PlayerGuiDebug
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="5">
      <Properties>
        <string name="Name">LegacyRightUiCleanup</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{e860c08b-9acb-491a-8297-45cf2e58e9f2}</string>
        <string name="Source"><![CDATA[local LegacyRightUiCleanup = {}

local LEGACY_RIGHT_UI_NAMES = {
	RightSideUI = true,
	RightPanel = true,
	Sidebar = true,
	MainMenu = true,
	MenuPanel = true,
}

function LegacyRightUiCleanup.create(deps)
	local scriptFullName = deps.scriptFullName
	local oldRightUiDisabledPrinted = false
	local cleanup = {}

	function cleanup.printOldRightUiDisabled()
		if not oldRightUiDisabledPrinted then
			print("Old right UI disabled")
			oldRightUiDisabledPrinted = true
		end
	end

	function cleanup.findLegacyRightUiContainer(gui)
		local oldMainPanel = gui:FindFirstChild("MainPanel", true)
		if oldMainPanel and oldMainPanel:FindFirstChild("Tabs", true) then
			return oldMainPanel
		end

		for _, descendant in ipairs(gui:GetDescendants()) do
			if LEGACY_RIGHT_UI_NAMES[descendant.Name] and descendant:IsA("GuiObject") then
				return descendant
			end
		end

		return nil
	end

	function cleanup.isLegacyRightUi(gui)
		return gui:IsA("ScreenGui") and cleanup.findLegacyRightUiContainer(gui) ~= nil
	end

	function cleanup.disableLegacyRightUi(gui)
		if not cleanup.isLegacyRightUi(gui) then
			return
		end

		local legacyRightUi = cleanup.findLegacyRightUiContainer(gui)
		if not legacyRightUi then
			return
		end

		print("ACTIVE OLD RIGHT UI SCRIPT FOUND:", scriptFullName)
		pcall(function()
			legacyRightUi.Visible = false
		end)
		legacyRightUi:Destroy()
		cleanup.printOldRightUiDisabled()
	end

	function cleanup.removeLegacyAquariumViewerTool(instance)
		if instance:IsA("Tool") and instance.Name == "Aquarium Viewer" then
			instance:Destroy()
		end
	end

	function cleanup.watchLegacyAquariumViewerTools(container)
		if not container then
			return
		end

		for _, child in ipairs(container:GetChildren()) do
			cleanup.removeLegacyAquariumViewerTool(child)
		end

		container.ChildAdded:Connect(cleanup.removeLegacyAquariumViewerTool)
	end

	return cleanup
end

return LegacyRightUiCleanup
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="6">
      <Properties>
        <string name="Name">IslandState</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{9f9ff36d-c682-459b-bcb4-b7127e72e83a}</string>
        <string name="Source"><![CDATA[local IslandState = {}

function IslandState.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.normalizeIslandId(areaId)
		if areaId == "Home" or areaId == "AquariumArea" then
			return "AquariumHub"
		elseif areaId == "Lobby" or areaId == "SeasideIsland" then
			return areaId
		end

		local legacyMap = GameConfig.LegacyBiomeIdToIslandId or {}
		if legacyMap[areaId] then
			return legacyMap[areaId]
		elseif GameConfig.normalizeIslandId then
			return GameConfig.normalizeIslandId(areaId) or areaId
		end

		if areaId == "BeginnerPond" then
			return "LilyshoreIsland"
		elseif areaId == "River" then
			return "RiverbendIsland"
		elseif areaId == "Ocean" then
			return "CoralCoastIsland"
		end

		return areaId
	end

	function helpers.getUnlockedIslands()
		local state = getState()
		return (state and (state.UnlockedIslands or state.UnlockedBiomes)) or {}
	end

	function helpers.getCurrentIslandId()
		local state = getState()
		return helpers.normalizeIslandId(state and (state.CurrentIsland or state.CurrentBiome))
	end

	function helpers.getActualIslandId()
		local state = getState()
		return helpers.normalizeIslandId(state and (state.ActualIsland or state.ActualBiome))
	end

	return helpers
end

return IslandState
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">QuestHelpers</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{f7c7acc4-be96-411a-902b-600e2c93d34c}</string>
        <string name="Source"><![CDATA[local QuestHelpers = {}

function QuestHelpers.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.formatQuestReward(reward)
		local parts = {}
		reward = type(reward) == "table" and reward or {}

		if (tonumber(reward.coins) or 0) > 0 then
			table.insert(parts, tostring(reward.coins) .. " Coins")
		end
		if (tonumber(reward.xp) or 0) > 0 then
			table.insert(parts, tostring(reward.xp) .. " Fishing XP")
		end
		if type(reward.bait) == "table" then
			for _, baitId in ipairs(GameConfig.BaitOrder) do
				local amount = tonumber(reward.bait[baitId]) or 0
				if amount > 0 then
					local bait = GameConfig.Baits[baitId]
					table.insert(parts, tostring(amount) .. " " .. (bait and bait.displayName or baitId))
				end
			end
		end
		if type(reward.decorations) == "table" then
			for _, amount in pairs(reward.decorations) do
				amount = tonumber(amount) or 0
				if amount > 0 then
					table.insert(parts, amount > 1 and (tostring(amount) .. " Aquarium Decorations") or "Aquarium Decoration")
				end
			end
		end

		if #parts == 0 then
			return "Reward ready"
		end

		return table.concat(parts, " | ")
	end

	function helpers.getQuestPeriod(periodName)
		local state = getState()
		local quests = state and state.Quests
		return quests and quests[periodName] or nil
	end

	return helpers
end

return QuestHelpers
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="8">
      <Properties>
        <string name="Name">PanelMarkers</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{87168bc5-ecb8-4e61-a8fe-b959b9eb4fa2}</string>
        <string name="Source"><![CDATA[local PanelMarkers = {}

function PanelMarkers.setup(screenGui)
	local openPanelEvent = screenGui:FindFirstChild("OpenFishingPanel")
	if not openPanelEvent then
		openPanelEvent = Instance.new("BindableEvent")
		openPanelEvent.Name = "OpenFishingPanel"
		openPanelEvent.Parent = screenGui
	end

	local panelsFolder = screenGui:FindFirstChild("Panels")
	if not panelsFolder then
		panelsFolder = Instance.new("Folder")
		panelsFolder.Name = "Panels"
		panelsFolder.Parent = screenGui
	end

	local function ensurePanelMarker(panelName)
		local panel = panelsFolder:FindFirstChild(panelName)
		if not panel then
			panel = Instance.new("Frame")
			panel.Name = panelName
			panel.BackgroundTransparency = 1
			panel.Size = UDim2.fromScale(1, 1)
			panel.Visible = false
			panel.Parent = panelsFolder
		end

		return panel
	end

	ensurePanelMarker("BagPanel")
	ensurePanelMarker("FishdexPanel")

	return {
		openPanelEvent = openPanelEvent,
		panelsFolder = panelsFolder,
		ensurePanelMarker = ensurePanelMarker,
	}
end

return PanelMarkers
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="9">
      <Properties>
        <string name="Name">GuiPrimitives</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{3831de4a-c000-4b50-b4ce-786499f2bda3}</string>
        <string name="Source"><![CDATA[local GuiPrimitives = {}

function GuiPrimitives.create(deps)
	local GameConfig = deps.GameConfig
	local primitives = {}

	function primitives.clearChildren(instance)
		for _, child in ipairs(instance:GetChildren()) do
			if not child:IsA("UIGridLayout") and not child:IsA("UIListLayout") then
				child:Destroy()
			end
		end
	end

	function primitives.addCorner(parent, radius)
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, radius or 8)
		corner.Parent = parent
		return corner
	end

	function primitives.addStroke(parent, color, thickness)
		local stroke = Instance.new("UIStroke")
		stroke.Color = color or Color3.fromRGB(45, 52, 64)
		stroke.Thickness = thickness or 1
		stroke.Parent = parent
		return stroke
	end

	function primitives.addGradient(parent, topColor, bottomColor, rotation)
		local gradient = Instance.new("UIGradient")
		gradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, topColor),
			ColorSequenceKeypoint.new(1, bottomColor),
		})
		gradient.Rotation = rotation or 90
		gradient.Parent = parent
		return gradient
	end

	function primitives.setCornerRadius(parent, radius)
		local corner = parent:FindFirstChildOfClass("UICorner")
		if not corner then
			corner = Instance.new("UICorner")
			corner.Parent = parent
		end

		corner.CornerRadius = UDim.new(0, radius)
		return corner
	end

	function primitives.styleOutlinedText(label, size)
		label.Font = Enum.Font.FredokaOne
		label.TextSize = size or label.TextSize
		label.TextStrokeColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeTransparency = 1
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextTransparency = 0
		label.RichText = false
	end

	function primitives.forcePureWhiteText(label)
		label.TextColor3 = Color3.new(1, 1, 1)
		label.TextTransparency = 0
		label.TextStrokeColor3 = Color3.new(1, 1, 1)
		label.TextStrokeTransparency = 1
	end

	function primitives.limitTextSize(label, minSize, maxSize)
		local constraint = label:FindFirstChildOfClass("UITextSizeConstraint")
		if not constraint then
			constraint = Instance.new("UITextSizeConstraint")
			constraint.Parent = label
		end

		constraint.MinTextSize = minSize
		constraint.MaxTextSize = maxSize
		return constraint
	end

	function primitives.addGloss(parent, position, size)
		local gloss = Instance.new("Frame")
		gloss.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		gloss.BackgroundTransparency = 0.72
		gloss.Position = position
		gloss.Size = size
		gloss.ZIndex = (parent.ZIndex or 1) + 1
		gloss.Parent = parent
		primitives.addCorner(gloss, 24)

		local gradient = Instance.new("UIGradient")
		gradient.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.05),
			NumberSequenceKeypoint.new(0.45, 0.6),
			NumberSequenceKeypoint.new(1, 1),
		})
		gradient.Rotation = 18
		gradient.Parent = gloss

		return gloss
	end

	function primitives.makeText(parent, text, size, color, bold)
		local label = Instance.new("TextLabel")
		label.BackgroundTransparency = 1
		label.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
		label.Text = text
		label.TextColor3 = color or Color3.fromRGB(240, 244, 248)
		label.TextSize = size
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextYAlignment = Enum.TextYAlignment.Center
		label.Parent = parent
		return label
	end

	function primitives.makeButton(parent, text, color)
		local button = Instance.new("TextButton")
		button.AutoButtonColor = true
		button.BackgroundColor3 = color or Color3.fromRGB(48, 126, 230)
		button.Font = Enum.Font.GothamBold
		button.Text = text
		button.TextColor3 = Color3.fromRGB(255, 255, 255)
		button.TextSize = 14
		button.Parent = parent
		primitives.addCorner(button, 7)
		primitives.addStroke(button, Color3.fromRGB(255, 255, 255), 1).Transparency = 0.85
		return button
	end

	function primitives.makeFishIcon(parent, fishId, rarity, discovered)
		local color = GameConfig.RarityColors[rarity] or Color3.fromRGB(130, 146, 166)
		local frame = Instance.new("Frame")
		frame.BackgroundColor3 = Color3.fromRGB(21, 28, 38)
		frame.Parent = parent
		primitives.addCorner(frame, 6)
		primitives.addStroke(frame, color, 1).Transparency = discovered == false and 0.55 or 0.2

		local imageId = discovered == false and nil or GameConfig.getFishImage(fishId)
		if imageId then
			local image = Instance.new("ImageLabel")
			image.BackgroundTransparency = 1
			image.Image = imageId
			image.ScaleType = Enum.ScaleType.Fit
			image.Size = UDim2.fromScale(1, 1)
			image.Position = UDim2.fromScale(0, 0)
			image.Parent = frame
		else
			local label = primitives.makeText(frame, discovered == false and "?" or "FISH", 12, color, true)
			label.TextXAlignment = Enum.TextXAlignment.Center
			label.Size = UDim2.fromScale(1, 1)
		end

		return frame
	end

	function primitives.makeRodIcon(parent, rodId)
		local frame = Instance.new("Frame")
		frame.BackgroundColor3 = Color3.fromRGB(21, 28, 38)
		frame.Parent = parent
		primitives.addCorner(frame, 6)
		primitives.addStroke(frame, Color3.fromRGB(130, 146, 166), 1).Transparency = 0.2

		local imageId = GameConfig.getRodImage(rodId)
		if imageId then
			local image = Instance.new("ImageLabel")
			image.BackgroundTransparency = 1
			image.Image = imageId
			image.ScaleType = Enum.ScaleType.Fit
			image.Size = UDim2.fromScale(1, 1)
			image.Position = UDim2.fromScale(0, 0)
			image.Parent = frame
		else
			local label = primitives.makeText(frame, "NO IMAGE", 10, Color3.fromRGB(160, 174, 192), true)
			label.TextXAlignment = Enum.TextXAlignment.Center
			label.Size = UDim2.fromScale(1, 1)
		end

		return frame
	end

	return primitives
end

return GuiPrimitives
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="10">
      <Properties>
        <string name="Name">LeaderboardHelpers</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{df5d325d-ede5-4afa-acd4-db6cfe666825}</string>
        <string name="Source"><![CDATA[local LeaderboardHelpers = {}

function LeaderboardHelpers.getPlayerLeaderstat(targetPlayer, statName)
	local leaderstats = targetPlayer:FindFirstChild("leaderstats")
	local stat = leaderstats and leaderstats:FindFirstChild(statName)
	if stat and stat:IsA("ValueBase") then
		return stat.Value
	end

	return 0
end

function LeaderboardHelpers.formatCompactNumber(value)
	value = tonumber(value) or 0
	if value >= 1000000 then
		return string.format("%.1fM", value / 1000000):gsub("%.0M", "M")
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000):gsub("%.0K", "K")
	end

	return tostring(value)
end

return LeaderboardHelpers
]]></string>
        <int64 name="SourceAssetId">-1</int64>
        <BinaryString name="Tags"></BinaryString>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="11">
      <Properties>
        <string name="Name">BaitHelpers</string>
        <BinaryString name="AttributesSerialize"></BinaryString>
        <SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
        <ContentId name="LinkedSource">
          <null>
          </null>
        </ContentId>
        <bool name="DefinesCapabilities">false</bool>
        <string name="ScriptGuid">{0b156d09-8219-496c-b273-ab9ec228d624}</string>
        <string name="Source"><![CDATA[local BaitHelpers = {}

function BaitHelpers.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.getBaitData(baitId)
		return GameConfig.getBait(baitId)
	end

	function helpers.getBaitCount(baitId)
		local state = getState()
		if not state then
			return 0
		end

		baitId = baitId or GameConfig.BasicBaitId
		if baitId == GameConfig.BasicBaitId then
			return math.huge
		end

		local inventory = state.BaitInventory or {}
		return math.max(0, math.floor(tonumber(inventory[baitId]) or 0))
	end

	function helpers.getBaitCountText(baitId, count)
		if baitId == GameConfig.BasicBaitId or count == math.huge or count == -1 then
			return "Unlimited"
		end

		return tostring(count or helpers.getBaitCount(baitId)) .. " left"
	end

	function helpers.getEquippedBaitDisplay()
		local state = getState()
		local baitId = state and state.EquippedBait or GameConfig.BasicBaitId
		local bait = helpers.getBaitData(baitId)
		local remaining = state and state.EquippedBaitRemaining or -1

		return "Bait: " .. bait.displayName .. " (" .. helpers.getBaitCountText(baitId, remaining) .. ")"
	end

	function helpers.getBaitEffectText(bait)
		local parts = {}

		if (tonumber(bait.biteSpeedMultiplier) or 1) < 1 then
			table.insert(parts, "faster bites")
		end
		if (tonumber(bait.rareChanceBonus) or 0) > 0 then
			table.insert(parts, "+" .. tostring(math.floor((bait.rareChanceBonus or 0) * 100)) .. "% rare luck")
		end
		if (tonumber(bait.valueMultiplier) or 1) > 1 then
			table.insert(parts, "+" .. tostring(math.floor(((bait.valueMultiplier or 1) - 1) * 100 + 0.5)) .. "% value")
		end
		if (tonumber(bait.xpMultiplier) or 1) > 1 then
			table.insert(parts, "+" .. tostring(math.floor(((bait.xpMultiplier or 1) - 1) * 100 + 0.5)) .. "% XP")
		end

		if #parts == 0 then
			return bait.description or "Default fishing."
		end

		return table.concat(parts, " | ")
	end

	return helpers
end

return BaitHelpers
]]></string>
