	value.TextYAlignment = Enum.TextYAlignment.Center

	local actionButton = boundChild(holder, "ActionButton", "TextButton")
	actionButton.AnchorPoint = Vector2.new(1, 0.5)
	actionButton.Position = UDim2.new(1, -30, 0.5, 0)
	actionButton.Size = UDim2.fromOffset(238, 68)
	actionButton.BackgroundColor3 = Color3.fromRGB(20, 176, 102)
	actionButton.BackgroundTransparency = 0.02
	actionButton.BorderSizePixel = 0
	actionButton.AutoButtonColor = false
	actionButton.Active = true
	actionButton.Selectable = true
	actionButton.Text = "Buy"
	actionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	actionButton.TextStrokeColor3 = Color3.fromRGB(3, 18, 44)
	actionButton.TextStrokeTransparency = 0.12
	actionButton.TextScaled = true
	actionButton.Visible = true
