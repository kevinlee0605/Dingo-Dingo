            <Item class="ModuleScript" referent="717">
              <Properties>
                <string name="Name">CoinsHud</string>
                <string name="Source">local TweenService = game:GetService("TweenService")

local CoinsHud = {}

local COIN_ICON_IMAGE = "rbxassetid://99615681502772"

local NUMBER_AREA_WIDTH = 320
local DIGIT_WIDTH = 20
local COMMA_WIDTH = 9
local DIGIT_HEIGHT = 72
local ROLL_TIME = 0.65

local function requiredChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(
		child and child:IsA(className),
		string.format(
			"[CoinsHud] Expected %s.%s to be a %s",
			parent:GetFullName(),
			name,
			className
		)
	)
	return child
end

function CoinsHud.create(deps, refs, formatNumber)
	assert(deps.authoredUiV2, "[CoinsHud] AuthoredUiV2 is required")
	assert(deps.findAuthoredHost, "[CoinsHud] findAuthoredHost is required")

	local coinsHud = deps.findAuthoredHost("CoinsHud", "GuiObject")
	assert(coinsHud, "[CoinsHud] Missing authored CoinsHud")

	requiredChild(coinsHud, "LeftStatsScale", "UIScale")
	requiredChild(coinsHud, "CoinsSizeConstraint", "UISizeConstraint")
	local icon = requiredChild(coinsHud, "CoinIcon", "ImageLabel")
	local numberArea = requiredChild(coinsHud, "NumberArea", "Frame")
	local digitsHolder = requiredChild(numberArea, "DigitsHolder", "Frame")
	local digitsScale = requiredChild(digitsHolder, "DigitsScale", "UIScale")
	local previewSlot = requiredChild(digitsHolder, "PreviewDigitSlot", "Frame")
	local previewCharacter = requiredChild(previewSlot, "PreviewCharacter", "TextLabel")
	requiredChild(previewCharacter, "UITextSizeConstraint", "UITextSizeConstraint")
	requiredChild(previewCharacter, "NumberOutline", "UIStroke")
	local compatibilityCoinsText = requiredChild(coinsHud, "CoinsText", "TextLabel")
	local coinsTextConstraint = requiredChild(compatibilityCoinsText, "UITextSizeConstraint", "UITextSizeConstraint")
	local statsText = requiredChild(coinsHud, "LegacyStatsText", "TextLabel")
	local statusText = requiredChild(coinsHud, "LegacyStatusText", "TextLabel")

	icon.Image = COIN_ICON_IMAGE
	icon.Visible = true
	coinsHud.Visible = true
	previewSlot.Visible = false
	for _, child in ipairs(digitsHolder:GetChildren()) do
		if string.match(child.Name, "^EditorPreviewDigit") then
			child.Visible = false
		end
	end
	digitsHolder.Visible = true
	compatibilityCoinsText.Position = UDim2.fromOffset(80, 10)
	compatibilityCoinsText.Size = UDim2.fromOffset(320, 76)
	compatibilityCoinsText.TextScaled = false
	compatibilityCoinsText.TextSize = 30
	compatibilityCoinsText.TextTransparency = 1
	compatibilityCoinsText.Visible = false
	coinsTextConstraint.MinTextSize = 14
	coinsTextConstraint.MaxTextSize = 30
	statsText.Visible = false
	statusText.Visible = false

	local function createCharacterLabel(parent, name, character)
		-- Each slot clone already includes the authored preview character. The
		-- second rolling character is cloned from that same Explorer template.
		local label = parent:FindFirstChild("PreviewCharacter")
		if not (label and label:IsA("TextLabel")) then
			label = previewCharacter:Clone()
			label.Parent = parent
		end

		label.Name = name
		label.AnchorPoint = Vector2.new(0, 0)
		label.Position = UDim2.fromScale(0, 0)
		label.Size = UDim2.fromScale(1, 1)
		label.BackgroundTransparency = 1
		label.BorderSizePixel = 0
		label.Text = character
		label.TextScaled = false
		label.TextSize = 8
		label.TextXAlignment = Enum.TextXAlignment.Center
		label.TextTransparency = 0
		label.Visible = true
		label.ZIndex = 1004
		return label
	end

	local function getCharacterWidth(character)
		if character == "," then
			return COMMA_WIDTH
		end
		return DIGIT_WIDTH
	end

	local function getTotalWidth(text)
		local total = 0
		for index = 1, #text do
			total += getCharacterWidth(string.sub(text, index, index))
		end
		return total
	end

	local activeTweens = {}
	local animationSerial = 0
	local currentValue = 0
	local hasInitialized = false

	local function cancelActiveTweens()
		for _, tween in ipairs(activeTweens) do
			tween:Cancel()
		end
		table.clear(activeTweens)
	end

	local function clearDigitSlots()
		for _, child in ipairs(digitsHolder:GetChildren()) do
			if child.Name == "DigitSlot" then
				child:Destroy()
			end
		end
	end

	local function configureHolderWidth(formatted)
		local totalWidth = getTotalWidth(formatted)
		digitsHolder.Size = UDim2.fromOffset(totalWidth, DIGIT_HEIGHT)

		if totalWidth &gt; NUMBER_AREA_WIDTH then
			digitsScale.Scale = NUMBER_AREA_WIDTH / totalWidth
		else
			digitsScale.Scale = 1
		end
	end

	local function createSlot(xOffset, width)
		local slot = previewSlot:Clone()
		slot.Name = "DigitSlot"
		slot.Position = UDim2.fromOffset(xOffset, 0)
		slot.Size = UDim2.fromOffset(width, DIGIT_HEIGHT)
		slot.Visible = true
		slot.Parent = digitsHolder
		return slot
	end

	local function renderImmediate(value)
		cancelActiveTweens()
		clearDigitSlots()

		currentValue = math.floor(tonumber(value) or 0)
		local formatted = formatNumber(currentValue)
		configureHolderWidth(formatted)

		local xOffset = 0
		for index = 1, #formatted do
			local character = string.sub(formatted, index, index)
			local width = getCharacterWidth(character)
			local slot = createSlot(xOffset, width)
			createCharacterLabel(slot, "Character", character)
			xOffset += width
		end

		compatibilityCoinsText.Text = formatted
	end

	local function getOldCharacterForNewPosition(oldText, newText, newIndex)
		local distanceFromRight = #newText - newIndex
		local oldIndex = #oldText - distanceFromRight

		if oldIndex &lt; 1 or oldIndex &gt; #oldText then
			return ""
		end

		return string.sub(oldText, oldIndex, oldIndex)
	end

	local function animateTo(value)
		value = math.floor(tonumber(value) or 0)

		if not hasInitialized then
			hasInitialized = true
			renderImmediate(value)
			return
		end

		if value == currentValue then
			compatibilityCoinsText.Text = formatNumber(value)
			return
		end

		cancelActiveTweens()
		clearDigitSlots()

		animationSerial += 1
		local thisAnimation = animationSerial
		local oldValue = currentValue
		local oldFormatted = formatNumber(oldValue)
		local newFormatted = formatNumber(value)
		local increasing = value &gt; oldValue

		currentValue = value
		compatibilityCoinsText.Text = newFormatted
		configureHolderWidth(newFormatted)

		local xOffset = 0
		local changedDigitCount = 0

		for newIndex = 1, #newFormatted do
			local newCharacter = string.sub(newFormatted, newIndex, newIndex)
			local oldCharacter = getOldCharacterForNewPosition(oldFormatted, newFormatted, newIndex)
			local width = getCharacterWidth(newCharacter)
			local slot = createSlot(xOffset, width)
			local isDigit = string.match(newCharacter, "%d") ~= nil
			local changed = oldCharacter ~= newCharacter

			if not isDigit or not changed then
				createCharacterLabel(slot, "StaticCharacter", newCharacter)
			else
				changedDigitCount += 1

				local outgoing = createCharacterLabel(slot, "OutgoingCharacter", oldCharacter)
				if oldCharacter == "" or string.match(oldCharacter, "%d") == nil then
					outgoing.TextTransparency = 1
				end

				local incoming = createCharacterLabel(slot, "IncomingCharacter", newCharacter)
				incoming.Position = increasing
					and UDim2.fromScale(0, 1)
					or UDim2.fromScale(0, -1)
				incoming.TextTransparency = 0.08

				local tweenInfo = TweenInfo.new(
					ROLL_TIME,
					Enum.EasingStyle.Quint,
					Enum.EasingDirection.Out
				)
				local outgoingTween = TweenService:Create(outgoing, tweenInfo, {
					Position = increasing and UDim2.fromScale(0, -1) or UDim2.fromScale(0, 1),
					TextTransparency = 0.35,
				})
				local incomingTween = TweenService:Create(incoming, tweenInfo, {
					Position = UDim2.fromScale(0, 0),
					TextTransparency = 0,
				})

				table.insert(activeTweens, outgoingTween)
				table.insert(activeTweens, incomingTween)
				outgoingTween:Play()
				incomingTween:Play()
			end

			xOffset += width
		end

		if changedDigitCount == 0 then
			renderImmediate(value)
			return
		end

		task.delay(ROLL_TIME + 0.06, function()
			if thisAnimation ~= animationSerial then
				return
			end
			renderImmediate(value)
		end)
	end

	refs.coinsText = compatibilityCoinsText
	refs.coinsHud = coinsHud
	refs.coinIcon = icon
	refs.coinNumberArea = numberArea
	refs.statsText = statsText
	refs.statusText = statusText

	function refs.updateCoins(coins)
		animateTo(coins)
	end
end

return CoinsHud
</string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="718">
              <Properties>
                <string name="Name">SettingsPanelHud</string>
                <string name="Source">local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local SettingsPanelHud = {}

local BASE_WIDTH = 1448
local BASE_HEIGHT = 1086
local SETTINGS_SIZE_MULTIPLIER = 0.85

local MIN_SPEED = 8
local MAX_SPEED = 24
local DEFAULT_SPEED = 16

local TRACK_X = 0
local TRACK_Y = 22
local TRACK_WIDTH = 1088
local FILL_X = 4
local FILL_Y = 26
local FILL_HEIGHT = 30
local FILL_CAP_WIDTH = 15
local KNOB_SIZE = 76
local KNOB_HALF = KNOB_SIZE / 2

local TOGGLE_MOVE_TWEEN = TweenInfo.new(
	0.22,
	Enum.EasingStyle.Quint,
	Enum.EasingDirection.Out
)
local TOGGLE_FADE_TWEEN = TweenInfo.new(
	0.14,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)
local PRESS_TWEEN = TweenInfo.new(
	0.07,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)
local RELEASE_TWEEN = TweenInfo.new(
	0.16,
	Enum.EasingStyle.Back,
	Enum.EasingDirection.Out
)

local function requiredChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(child, string.format(
		"[SettingsPanelHud] Missing authored node %s.%s",
		parent:GetFullName(),
		name
	))
	assert(child:IsA(className), string.format(
		"[SettingsPanelHud] Authored node %s must be %s, got %s",
		child:GetFullName(),
		className,
		child.ClassName
	))
	return child
end

local function assertImage(container)
	requiredChild(container, "Image", "ImageLabel")
end

function SettingsPanelHud.create(deps, refs)
	assert(deps.authoredUiV2, "[SettingsPanelHud] AuthoredUiV2 is required")
	assert(deps.findAuthoredHost, "[SettingsPanelHud] Authored host lookup is required")

	local overlay = deps.findAuthoredHost("SettingsOverlay", "Frame")
	assert(overlay, "[SettingsPanelHud] SettingsOverlay is missing from FishingGui")

	-- Keep the saved overlay with the other modal surfaces after FishingGui is
	-- cloned. Its complete visual hierarchy remains authored in StarterGui.
	if deps.root and deps.root:IsA("GuiObject") and overlay.Parent ~= deps.root then
		overlay.Parent = deps.root
	end

	local canvas = requiredChild(overlay, "SettingsCanvas", "Frame")
	local responsiveScale = requiredChild(canvas, "UIScale", "UIScale")
	local closeButton = requiredChild(canvas, "CloseButton", "ImageButton")

	-- Validate the fixed art that the controller never modifies.
	assertImage(requiredChild(canvas, "BackboneTop", "Frame"))
	assertImage(requiredChild(canvas, "BackboneMiddle", "Frame"))
	assertImage(requiredChild(canvas, "BackboneBottom", "Frame"))
	requiredChild(canvas, "SettingsIcon", "ImageLabel")
	requiredChild(canvas, "Title", "TextLabel")

	local function bindAudioRow(name)
		local row = requiredChild(canvas, name .. "Row", "ImageLabel")
		requiredChild(row, name .. "Icon", "ImageLabel")
		requiredChild(row, name .. "Prefix", "TextLabel")
		local status = requiredChild(row, name .. "Status", "TextLabel")
		local toggle = requiredChild(row, name .. "Toggle", "TextButton")
		local pressScale = requiredChild(toggle, "PressScale", "UIScale")
		local onBackground = requiredChild(toggle, "OnBackground", "ImageLabel")
		local offBackground = requiredChild(toggle, "OffBackground", "ImageLabel")
		local toggleText = requiredChild(toggle, name .. "ToggleText", "TextLabel")
		local knob = requiredChild(toggle, name .. "Knob", "Frame")
		assertImage(knob)
		return {
			status = status,
			toggle = toggle,
			pressScale = pressScale,
			onBackground = onBackground,
			offBackground = offBackground,
			toggleText = toggleText,
			knob = knob,
		}
	end

	local music = bindAudioRow("Music")
	local sfx = bindAudioRow("Sfx")

	local speedRow = requiredChild(canvas, "MoveSpeedRow", "ImageLabel")
	requiredChild(speedRow, "MoveSpeedPrefix", "TextLabel")
	local speedValue = requiredChild(speedRow, "MoveSpeedValue", "TextLabel")
	local sliderArea = requiredChild(speedRow, "SliderArea", "Frame")
	assertImage(requiredChild(sliderArea, "TrackLeftCap", "Frame"))
	assertImage(requiredChild(sliderArea, "TrackMiddle", "Frame"))
	assertImage(requiredChild(sliderArea, "TrackRightCap", "Frame"))
	local fillLeftClip = requiredChild(sliderArea, "FillLeftCap", "Frame")
	assertImage(fillLeftClip)
	local fillMiddleClip = requiredChild(sliderArea, "FillMiddle", "Frame")
	local fillMiddleImage = requiredChild(fillMiddleClip, "Image", "ImageLabel")
	local sliderKnob = requiredChild(sliderArea, "SliderKnob", "TextButton")
	assertImage(sliderKnob)

	local aquariumRow = requiredChild(canvas, "AquariumTeleportRow", "ImageLabel")
	requiredChild(aquariumRow, "FishBowlIcon", "ImageLabel")
	requiredChild(aquariumRow, "AquariumTitle", "TextLabel")
	local teleportButton = requiredChild(aquariumRow, "TeleportButton", "ImageButton")
	local teleportScale = requiredChild(teleportButton, "PressScale", "UIScale")

	local player = Players.LocalPlayer
	local fishingRemotes = ReplicatedStorage:WaitForChild("FishingRemotes")
	local teleportRemote = fishingRemotes:WaitForChild("TeleportTo")
	local movementRemotes = ReplicatedStorage:FindFirstChild("Remotes")
	local moveSpeedRemote = movementRemotes and movementRemotes:FindFirstChild("SetMoveSpeed")

	local function updateScale()
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)
		local fitScale = math.min(
			viewport.X * 0.74 / BASE_WIDTH,
			viewport.Y * 0.74 / BASE_HEIGHT
		)
		responsiveScale.Scale = math.clamp(
			fitScale * SETTINGS_SIZE_MULTIPLIER,
			0.25,
			0.75
		)
	end

	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
	end
	updateScale()

	local activeTweens = setmetatable({}, { __mode = "k" })

	local function playTween(instance, tweenInfo, goal)
		local currentTween = activeTweens[instance]
		if currentTween then
			currentTween:Cancel()
		end

		local tween = TweenService:Create(instance, tweenInfo, goal)
		activeTweens[instance] = tween
		tween.Completed:Connect(function()
			if activeTweens[instance] == tween then
				activeTweens[instance] = nil
			end
		end)
		tween:Play()
		return tween
	end

	local closePosition = UDim2.fromOffset(1270, 60)
	local closeSize = UDim2.fromOffset(100, 100)
	local closeBusy = false

	local function resetCloseButton(animated)
		if not animated then
			local currentTween = activeTweens[closeButton]
			if currentTween then
				currentTween:Cancel()
				activeTweens[closeButton] = nil
			end
			closeButton.Position = closePosition
			closeButton.Size = closeSize
			closeButton.Rotation = 0
			closeButton.ImageColor3 = Color3.new(1, 1, 1)
			return
		end

		playTween(closeButton, RELEASE_TWEEN, {
			Position = closePosition,
			Size = closeSize,
			Rotation = 0,
			ImageColor3 = Color3.new(1, 1, 1),
		})
	end

	closeButton.MouseEnter:Connect(function()
		if closeBusy then
			return
		end
		playTween(closeButton, TOGGLE_FADE_TWEEN, {
			Position = UDim2.fromOffset(1257, 49),
			Size = UDim2.fromOffset(106, 106),
			ImageColor3 = Color3.fromRGB(255, 244, 190),
		})
	end)

	closeButton.MouseLeave:Connect(function()
		if not closeBusy then
			resetCloseButton(true)
		end
	end)

	local musicEnabled = true
	local sfxEnabled = true

	local function isMusic(sound)
		local name = string.lower(sound.Name)
		return string.find(name, "music")
			or string.find(name, "theme")
			or string.find(name, "bgm")
	end

	local function originalVolume(sound)
		local saved = sound:GetAttribute("FishyFishOriginalVolume")
		if type(saved) ~= "number" then
			saved = sound.Volume
			sound:SetAttribute("FishyFishOriginalVolume", saved)
		end
		return saved
	end

	local function applyAudio()
		SoundService:SetAttribute("FishyFishMusicEnabled", musicEnabled)
		SoundService:SetAttribute("FishyFishSFXEnabled", sfxEnabled)
		for _, object in ipairs(SoundService:GetDescendants()) do
			if object:IsA("Sound") then
				local volume = originalVolume(object)
				if isMusic(object) then
					object.Volume = musicEnabled and volume or 0
				else
					object.Volume = sfxEnabled and volume or 0
				end
			end
		end
	end

	local function setLabelState(label, textValue, colorValue, animate)
		local serial = (label:GetAttribute("SettingsAnimationSerial") or 0) + 1
		label:SetAttribute("SettingsAnimationSerial", serial)

		if not animate then
			label.Text = textValue
			label.TextColor3 = colorValue
			label.TextTransparency = 0
			label.TextStrokeTransparency = 0.25
			return
		end

		playTween(label, PRESS_TWEEN, {
			TextTransparency = 1,
			TextStrokeTransparency = 1,
		})
		task.delay(0.065, function()
			if label:GetAttribute("SettingsAnimationSerial") ~= serial then
				return
			end
			label.Text = textValue
			label.TextColor3 = colorValue
			playTween(label, TOGGLE_FADE_TWEEN, {
				TextTransparency = 0,
				TextStrokeTransparency = 0.25,
			})
		end)
	end

	local function refreshSingleToggle(toggleRefs, enabled, animate)
		local knobPosition
		toggleRefs.toggleText.AnchorPoint = Vector2.new(0, 0)
		toggleRefs.toggleText.TextTruncate = Enum.TextTruncate.None

		if enabled then
			knobPosition = UDim2.new(1, -78, 0.5, -39)
			toggleRefs.toggleText.Position = UDim2.fromOffset(22, 0)
			toggleRefs.toggleText.Size = UDim2.fromOffset(108, 96)
			toggleRefs.toggleText.TextXAlignment = Enum.TextXAlignment.Left
		else
			knobPosition = UDim2.new(0, 2, 0.5, -39)
			toggleRefs.toggleText.Position = UDim2.fromOffset(0, 0)
			toggleRefs.toggleText.Size = UDim2.new(1, -12, 1, 0)
			toggleRefs.toggleText.TextXAlignment = Enum.TextXAlignment.Right
		end

		if animate then
			playTween(toggleRefs.onBackground, TOGGLE_FADE_TWEEN, {
				ImageTransparency = enabled and 0 or 1,
			})
			playTween(toggleRefs.offBackground, TOGGLE_FADE_TWEEN, {
				ImageTransparency = enabled and 1 or 0,
			})
			playTween(toggleRefs.knob, TOGGLE_MOVE_TWEEN, {
				Position = knobPosition,
			})
		else
			toggleRefs.onBackground.ImageTransparency = enabled and 0 or 1
			toggleRefs.offBackground.ImageTransparency = enabled and 1 or 0
			toggleRefs.knob.Position = knobPosition
		end

		setLabelState(
			toggleRefs.toggleText,
			enabled and "ON" or "OFF",
			Color3.new(1, 1, 1),
			animate
		)
		setLabelState(
			toggleRefs.status,
			enabled and "ON" or "OFF",
			enabled and Color3.fromRGB(65, 215, 255) or Color3.fromRGB(255, 75, 75),
			animate
		)
	end

	local function refreshToggle(toggleRefs, isMusicRow, animate)
		refreshSingleToggle(
			toggleRefs,
			isMusicRow and musicEnabled or sfxEnabled,
			animate
		)
	end

	local function bindToggleInput(toggleRefs, isMusicRow)
		toggleRefs.toggle.MouseButton1Down:Connect(function()
			playTween(toggleRefs.pressScale, PRESS_TWEEN, { Scale = 0.96 })
		end)
		toggleRefs.toggle.MouseButton1Up:Connect(function()
			playTween(toggleRefs.pressScale, RELEASE_TWEEN, { Scale = 1 })
		end)
		toggleRefs.toggle.MouseLeave:Connect(function()
			playTween(toggleRefs.pressScale, RELEASE_TWEEN, { Scale = 1 })
		end)
		toggleRefs.toggle.Activated:Connect(function()
			if isMusicRow then
				musicEnabled = not musicEnabled
			else
				sfxEnabled = not sfxEnabled
			end

			playTween(toggleRefs.pressScale, PRESS_TWEEN, { Scale = 0.94 })
			task.delay(0.07, function()
				playTween(toggleRefs.pressScale, RELEASE_TWEEN, { Scale = 1 })
			end)
			applyAudio()
			refreshToggle(toggleRefs, isMusicRow, true)
		end)
	end

	bindToggleInput(music, true)
	bindToggleInput(sfx, false)

	local currentSpeed = DEFAULT_SPEED
	local dragging = false
	local activeTouch = nil
	local fillSourceSize = Vector2.new(1274, 155)

	local function renderSpeed(speed)
		currentSpeed = math.clamp(
			math.round(tonumber(speed) or DEFAULT_SPEED),
			MIN_SPEED,
			MAX_SPEED
		)
		local alpha = (currentSpeed - MIN_SPEED) / (MAX_SPEED - MIN_SPEED)
		local usableKnobWidth = TRACK_WIDTH - KNOB_SIZE
		local knobX = TRACK_X + math.floor(usableKnobWidth * alpha + 0.5)
		local knobCenterX = knobX + KNOB_HALF
		local visibleFillWidth = math.max(
			0,
			math.floor(knobCenterX - FILL_X + 0.5)
		)
		local middleWidth = math.max(0, visibleFillWidth - FILL_CAP_WIDTH)

		fillLeftClip.Visible = visibleFillWidth &gt; 0
		fillMiddleClip.Visible = middleWidth &gt; 0
		fillMiddleClip.Size = UDim2.fromOffset(middleWidth, FILL_HEIGHT)

		if middleWidth &gt; 0 then
			local fullImageWidth = middleWidth * fillSourceSize.X / 1118
			local fullImageHeight = FILL_HEIGHT * fillSourceSize.Y / 135
			fillMiddleImage.Position = UDim2.fromOffset(
				-(78 / fillSourceSize.X) * fullImageWidth,
				-(10 / fillSourceSize.Y) * fullImageHeight
			)
			fillMiddleImage.Size = UDim2.fromOffset(fullImageWidth, fullImageHeight)
		end

		sliderKnob.Position = UDim2.fromOffset(
			knobX,
			TRACK_Y + math.floor(38 / 2) - KNOB_HALF
		)
		speedValue.Text = tostring(currentSpeed)
	end

	local function updateFromX(x)
		local absoluteScale = responsiveScale.Scale
		local absoluteTrackStart = sliderArea.AbsolutePosition.X
			+ ((TRACK_X + KNOB_HALF) * absoluteScale)
		local absoluteUsableWidth = (TRACK_WIDTH - KNOB_SIZE) * absoluteScale
		if absoluteUsableWidth &lt;= 0 then
			return
		end
		local alpha = math.clamp(
			(x - absoluteTrackStart) / absoluteUsableWidth,
			0,
			1
		)
		renderSpeed(MIN_SPEED + ((MAX_SPEED - MIN_SPEED) * alpha))
	end

	local function beginSlider(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end
		dragging = true
		if input.UserInputType == Enum.UserInputType.Touch then
			activeTouch = input
		end
		updateFromX(input.Position.X)
	end

	sliderArea.InputBegan:Connect(beginSlider)
	sliderKnob.InputBegan:Connect(beginSlider)
	UserInputService.InputChanged:Connect(function(input)
		if not dragging then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromX(input.Position.X)
		elseif input.UserInputType == Enum.UserInputType.Touch and input == activeTouch then
			updateFromX(input.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if not dragging then
			return
		end
		local mouseEnd = input.UserInputType == Enum.UserInputType.MouseButton1
		local touchEnd = input.UserInputType == Enum.UserInputType.Touch and input == activeTouch
		if not mouseEnd and not touchEnd then
			return
		end

		dragging = false
		activeTouch = nil
		if moveSpeedRemote and moveSpeedRemote:IsA("RemoteEvent") then
			moveSpeedRemote:FireServer(currentSpeed)
		else
			warn("[SettingsPanelHud] SetMoveSpeed remote is unavailable; keeping the saved speed locally")
		end
	end)

	local teleportBusy = false
	local function releaseTeleportButton()
		playTween(teleportScale, RELEASE_TWEEN, { Scale = 1 })
	end

	teleportButton.MouseButton1Down:Connect(function()
		if not teleportBusy then
			playTween(teleportScale, PRESS_TWEEN, { Scale = 0.94 })
		end
	end)
	teleportButton.MouseButton1Up:Connect(releaseTeleportButton)
	teleportButton.MouseLeave:Connect(releaseTeleportButton)
	teleportButton.Activated:Connect(function()
		if teleportBusy then
			return
		end
		teleportBusy = true
		playTween(teleportScale, PRESS_TWEEN, { Scale = 0.91 })
		teleportRemote:FireServer({
			kind = "PlayerAquarium",
			userId = player.UserId,
		})
		task.delay(0.075, function()
			releaseTeleportButton()
			task.delay(0.08, function()
				refs.setSettingsVisible(false)
			end)
		end)
		task.delay(0.8, function()
			teleportBusy = false
		end)
	end)

	refs.setSettingsVisible = function(visible)
		overlay.Visible = visible == true
		if overlay.Visible then
			closeBusy = false
			teleportBusy = false
			teleportScale.Scale = 1
			resetCloseButton(false)
			renderSpeed(player:GetAttribute("MoveSpeed") or DEFAULT_SPEED)
			refreshToggle(music, true, false)
			refreshToggle(sfx, false, false)
		end
	end

	closeButton.Activated:Connect(function()
		if closeBusy then
			return
		end
		closeBusy = true
		playTween(closeButton, PRESS_TWEEN, {
			Position = UDim2.fromOffset(1268, 60),
			Size = UDim2.fromOffset(84, 84),
			Rotation = -7,
			ImageColor3 = Color3.fromRGB(255, 223, 100),
		})
		task.delay(0.075, function()
			playTween(closeButton, RELEASE_TWEEN, {
				Position = UDim2.fromOffset(1257, 49),
				Size = UDim2.fromOffset(106, 106),
				Rotation = 3,
				ImageColor3 = Color3.new(1, 1, 1),
			})
			task.delay(0.12, function()
				resetCloseButton(true)
				task.delay(0.055, function()
					refs.setSettingsVisible(false)
					closeBusy = false
				end)
			end)
		end)
	end)

	SoundService.DescendantAdded:Connect(function(object)
		if object:IsA("Sound") then
			task.defer(applyAudio)
		end
	end)
	player:GetAttributeChangedSignal("MoveSpeed"):Connect(function()
		local value = player:GetAttribute("MoveSpeed")
		if value ~= nil then
			renderSpeed(value)
		end
	end)

	refreshToggle(music, true, false)
	refreshToggle(sfx, false, false)
	renderSpeed(player:GetAttribute("MoveSpeed") or DEFAULT_SPEED)
	overlay.Visible = false
end

return SettingsPanelHud
</string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="719">
              <Properties>
                <string name="Name">TopButtonsHud</string>
                <string name="Source">local TweenService = game:GetService("TweenService")

local TopButtonsHud = {}

local SETTINGS_ICON = "rbxassetid://124685242228377"
local QUESTS_ICON = "rbxassetid://102051949478203"
local SHOP_ICON = "rbxassetid://140502313228532"
local DAILY_REWARDS_ICON = "rbxassetid://78408484505332"

local ICON_NORMAL_SIZE = UDim2.fromScale(0.82, 0.82)
local ICON_PRESSED_SIZE = UDim2.fromScale(0.74, 0.74)
local SHADOW_NORMAL_SIZE = UDim2.fromScale(0.82, 0.82)
local SHADOW_PRESSED_SIZE = UDim2.fromScale(0.76, 0.76)
local SHADOW_TRANSPARENCY = 0.55
local SHADOW_PRESSED_TRANSPARENCY = 0.43

local function requiredChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(
		child and child:IsA(className),
		string.format(
			"[TopButtonsHud] Expected %s.%s to be a %s",
			parent:GetFullName(),
			name,
			className
		)
	)
	return child
end

local function bindButtonTree(button)
	local pressScale = requiredChild(button, "PressScale", "UIScale")
	local shadow = requiredChild(button, "IconShadow", "Frame")
	requiredChild(shadow, "UICorner", "UICorner")
	local icon = requiredChild(button, "Icon", "ImageLabel")
	return pressScale, shadow, icon
end

function TopButtonsHud.create(deps, refs)
	assert(deps.authoredUiV2, "[TopButtonsHud] AuthoredUiV2 is required")
	assert(deps.findAuthoredHost, "[TopButtonsHud] findAuthoredHost is required")

	local topHudButtons = deps.findAuthoredHost("TopButtonsFrame", "GuiObject")
	assert(topHudButtons, "[TopButtonsHud] Missing authored TopButtonsFrame")

	-- All four always-on buttons share the authored, screen-centered row in
	-- TopHudGui. Controllers bind behavior only; they never create or reparent it.
	requiredChild(topHudButtons, "TopHudScale", "UIScale")
	requiredChild(topHudButtons, "TopButtonsSizeConstraint", "UISizeConstraint")
	requiredChild(topHudButtons, "UIListLayout", "UIListLayout")

	local settingsButton = requiredChild(topHudButtons, "SettingsButton", "TextButton")
	local settingsPressScale, settingsShadow, settingsIcon = bindButtonTree(settingsButton)
	local questsButton = requiredChild(topHudButtons, "QuestsButton", "TextButton")
	local questsPressScale, questsShadow, questsIcon = bindButtonTree(questsButton)
	local shopButton = requiredChild(topHudButtons, "ShopButton", "TextButton")
	local shopPressScale, shopShadow, shopIcon = bindButtonTree(shopButton)
	local dailyRewardsButton = requiredChild(topHudButtons, "TopLoginRewardButton", "TextButton")
	local dailyRewardsPressScale, dailyRewardsShadow, dailyRewardsIcon = bindButtonTree(dailyRewardsButton)

	settingsIcon.Image = SETTINGS_ICON
	questsIcon.Image = QUESTS_ICON
	shopIcon.Image = SHOP_ICON
	dailyRewardsIcon.Image = DAILY_REWARDS_ICON
	settingsIcon.Visible = true
	questsIcon.Visible = true
	shopIcon.Visible = true
	dailyRewardsIcon.Visible = true

	local function bindPressFeedback(button, pressScale, icon, shadow)
		local pressTweenInfo = TweenInfo.new(
			0.07,
			Enum.EasingStyle.Quad,
			Enum.EasingDirection.Out
		)
		local releaseTweenInfo = TweenInfo.new(
			0.16,
			Enum.EasingStyle.Back,
			Enum.EasingDirection.Out
		)
		local isPressed = false

		local function tweenPressed(pressed)
			if isPressed == pressed then
				return
			end

			isPressed = pressed
			local tweenInfo = pressed and pressTweenInfo or releaseTweenInfo

			TweenService:Create(pressScale, tweenInfo, {
				Scale = pressed and 0.88 or 1,
			}):Play()
			TweenService:Create(icon, tweenInfo, {
				Position = pressed and UDim2.fromScale(0.5, 0.56) or UDim2.fromScale(0.5, 0.5),
				Size = pressed and ICON_PRESSED_SIZE or ICON_NORMAL_SIZE,
			}):Play()
			TweenService:Create(shadow, tweenInfo, {
				Size = pressed and SHADOW_PRESSED_SIZE or SHADOW_NORMAL_SIZE,
				BackgroundTransparency = pressed
					and SHADOW_PRESSED_TRANSPARENCY
					or SHADOW_TRANSPARENCY,
			}):Play()
		end

		button.MouseButton1Down:Connect(function()
			tweenPressed(true)
		end)
		button.MouseButton1Up:Connect(function()
			tweenPressed(false)
		end)
		button.MouseLeave:Connect(function()
			tweenPressed(false)
		end)
		button.Activated:Connect(function()
			tweenPressed(false)
		end)
	end

	bindPressFeedback(settingsButton, settingsPressScale, settingsIcon, settingsShadow)
	bindPressFeedback(questsButton, questsPressScale, questsIcon, questsShadow)
	bindPressFeedback(shopButton, shopPressScale, shopIcon, shopShadow)
	bindPressFeedback(dailyRewardsButton, dailyRewardsPressScale, dailyRewardsIcon, dailyRewardsShadow)

	refs.settingsButton = settingsButton
	refs.questsButton = questsButton
	refs.shopButton = shopButton
	refs.dailyRewardsButton = dailyRewardsButton

	-- The reference HUD has no quest notification badge. Retain the update
	-- hooks as no-ops so quest state can refresh without creating UI at runtime.
	function refs.updateQuestBadgeCount(_count) end

	function refs.clearQuestBadge()
		-- Intentionally empty: the authored reference HUD has no badge.
	end

	topHudButtons.Visible = true
end

return TopButtonsHud
</string>
              </Properties>
            </Item>
            <Item class="ModuleScript" referent="720">
              <Properties>
                <string name="Name">XPBarHud</string>
                <string name="Source">local XPBarHud = {}

local function requiredChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(
		child and child:IsA(className),
		string.format(
			"[XPBarHud] Expected %s.%s to be a %s",
			parent:GetFullName(),
			name,
			className
		)
	)
	return child
end

function XPBarHud.create(deps, refs, formatNumber, maxLevel)
	assert(deps.authoredUiV2, "[XPBarHud] AuthoredUiV2 is required")
	assert(deps.findAuthoredHost, "[XPBarHud] findAuthoredHost is required")

	local xpContainer = deps.findAuthoredHost("FishingXPText", "GuiObject")
	assert(xpContainer, "[XPBarHud] Missing authored FishingXPText")

	requiredChild(xpContainer, "LeftStatsScale", "UIScale")
	requiredChild(xpContainer, "XPSizeConstraint", "UISizeConstraint")
	local combinedText = requiredChild(xpContainer, "XPCombinedText", "TextLabel")
	requiredChild(combinedText, "UITextSizeConstraint", "UITextSizeConstraint")
	requiredChild(combinedText, "XPTextOutline", "UIStroke")
	local progressText = requiredChild(xpContainer, "LegacyXPProgressText", "TextLabel")
	local legacyFill = requiredChild(xpContainer, "LegacyXPFill", "Frame")

	xpContainer.Visible = true
	progressText.Visible = false
	legacyFill.Visible = false

	refs.xpLevelText = combinedText
	refs.xpProgressText = progressText
	refs.xpBarFrame = xpContainer
	refs.xpText = combinedText
	refs.xpFill = legacyFill

	function refs.updateXP(data)
		if not data then
			combinedText.Text = "Level: 1 [0/40]"
			progressText.Text = "0 / 40 XP"
			return
		end

		local level = math.clamp(math.floor(tonumber(data.Level) or 1), 1, maxLevel)
		local progressXP = math.max(0, math.floor(tonumber(data.LevelProgressXP) or 0))
		local nextXP = math.max(0, math.floor(tonumber(data.NextLevelXP) or 0))
		local isMax = level &gt;= maxLevel or nextXP &lt;= 0

		if isMax then
			combinedText.Text = string.format("Level: %d [MAX]", level)
			progressText.Text = "MAX"
		else
			combinedText.Text = string.format(
				"Level: %d [%s/%s]",
				level,
				formatNumber(progressXP),
				formatNumber(nextXP)
			)
			progressText.Text = string.format(
				"%s / %s XP",
				formatNumber(progressXP),
				formatNumber(nextXP)
			)
		end
	end
end

return XPBarHud
</string>
              </Properties>
            </Item>
          </Item>
          <Item class="ModuleScript" referent="721">
            <Properties>
              <string name="Name">IslandState</string>
              <string name="Source">local IslandState = {}

function IslandState.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.normalizeIslandId(areaId)
		if areaId == "Home" or areaId == "AquariumArea" then
			return "AquariumHub"
		elseif areaId == "Lobby" or areaId == "SeasideIsland" then
			return areaId
		end

		local legacyMap = GameConfig.LegacyBiomeIdToIslandId or {}
		if legacyMap[areaId] then
			return legacyMap[areaId]
		elseif GameConfig.normalizeIslandId then
			return GameConfig.normalizeIslandId(areaId) or areaId
		end

		if areaId == "BeginnerPond" then
			return "LilyshoreIsland"
		elseif areaId == "River" then
			return "RiverbendIsland"
		elseif areaId == "Ocean" then
			return "CoralCoastIsland"
		end

		return areaId
	end

	function helpers.getUnlockedIslands()
		local state = getState()
		return (state and (state.UnlockedIslands or state.UnlockedBiomes)) or {}
	end

	function helpers.getCurrentIslandId()
		local state = getState()
		return helpers.normalizeIslandId(state and (state.CurrentIsland or state.CurrentBiome))
	end

	function helpers.getActualIslandId()
		local state = getState()
		return helpers.normalizeIslandId(state and (state.ActualIsland or state.ActualBiome))
	end

	return helpers
end

return IslandState
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="722">
            <Properties>
              <string name="Name">LeaderboardHelpers</string>
              <string name="Source">local LeaderboardHelpers = {}

function LeaderboardHelpers.getPlayerLeaderstat(targetPlayer, statName)
	local leaderstats = targetPlayer:FindFirstChild("leaderstats")
	local stat = leaderstats and leaderstats:FindFirstChild(statName)
	if stat and stat:IsA("ValueBase") then
		return stat.Value
	end

	return 0
end

function LeaderboardHelpers.formatCompactNumber(value)
	value = tonumber(value) or 0
	if value &gt;= 1000000 then
		return string.format("%.1fM", value / 1000000):gsub("%.0M", "M")
	elseif value &gt;= 1000 then
		return string.format("%.1fK", value / 1000):gsub("%.0K", "K")
	end

	return tostring(value)
end

return LeaderboardHelpers
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="723">
            <Properties>
              <string name="Name">LegacyRightUiCleanup</string>
              <string name="Source">local LegacyRightUiCleanup = {}

local LEGACY_RIGHT_UI_NAMES = {
	RightSideUI = true,
	RightPanel = true,
	Sidebar = true,
	MainMenu = true,
	MenuPanel = true,
}

function LegacyRightUiCleanup.create(deps)
	local scriptFullName = deps.scriptFullName
	local oldRightUiDisabledPrinted = false
	local cleanup = {}

	function cleanup.printOldRightUiDisabled()
		if not oldRightUiDisabledPrinted then
			print("Old right UI disabled")
			oldRightUiDisabledPrinted = true
		end
	end

	function cleanup.findLegacyRightUiContainer(gui)
		local oldMainPanel = gui:FindFirstChild("MainPanel", true)
		if oldMainPanel and oldMainPanel:FindFirstChild("Tabs", true) then
			return oldMainPanel
		end

		for _, descendant in ipairs(gui:GetDescendants()) do
			if LEGACY_RIGHT_UI_NAMES[descendant.Name] and descendant:IsA("GuiObject") then
				return descendant
			end
		end

		return nil
	end

	function cleanup.isLegacyRightUi(gui)
		return gui:IsA("ScreenGui") and cleanup.findLegacyRightUiContainer(gui) ~= nil
	end

	function cleanup.disableLegacyRightUi(gui)
		if not cleanup.isLegacyRightUi(gui) then
			return
		end

		local legacyRightUi = cleanup.findLegacyRightUiContainer(gui)
		if not legacyRightUi then
			return
		end

		print("ACTIVE OLD RIGHT UI SCRIPT FOUND:", scriptFullName)
		pcall(function()
			legacyRightUi.Visible = false
		end)
		legacyRightUi:Destroy()
		cleanup.printOldRightUiDisabled()
	end

	function cleanup.removeLegacyAquariumViewerTool(instance)
		if instance:IsA("Tool") and instance.Name == "Aquarium Viewer" then
			instance:Destroy()
		end
	end

	function cleanup.watchLegacyAquariumViewerTools(container)
		if not container then
			return
		end

		for _, child in ipairs(container:GetChildren()) do
			cleanup.removeLegacyAquariumViewerTool(child)
		end

		container.ChildAdded:Connect(cleanup.removeLegacyAquariumViewerTool)
	end

	return cleanup
end

return LegacyRightUiCleanup
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="724">
            <Properties>
              <string name="Name">PanelMarkers</string>
              <string name="Source">local PanelMarkers = {}

function PanelMarkers.setup(screenGui)
	local openPanelEvent = screenGui:WaitForChild("OpenFishingPanel")
	assert(openPanelEvent:IsA("BindableEvent"), "FishingGui.OpenFishingPanel must be an authored BindableEvent")

	local panelsFolder = screenGui:WaitForChild("Panels")
	assert(panelsFolder:IsA("Folder"), "FishingGui.Panels must be an authored Folder")

	local function ensurePanelMarker(panelName)
		local panel = panelsFolder:FindFirstChild(panelName)
		assert(panel and panel:IsA("Frame"), string.format(
			"FishingGui.Panels.%s must be an authored Frame",
			panelName
		))
		return panel
	end

	ensurePanelMarker("BagPanel")
	ensurePanelMarker("FishdexPanel")

	return {
		openPanelEvent = openPanelEvent,
		panelsFolder = panelsFolder,
		ensurePanelMarker = ensurePanelMarker,
	}
end

return PanelMarkers
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="725">
            <Properties>
              <string name="Name">PlayerGuiDebug</string>
              <string name="Source">local PlayerGuiDebug = {}

local function getGuiVisibleState(instance)
	if instance:IsA("ScreenGui") then
		return instance.Enabled
	elseif instance:IsA("GuiObject") then
		return instance.Visible
	end

	return "n/a"
end

function PlayerGuiDebug.create(deps)
	local playerGui = deps.playerGui
	local screenGui = deps.screenGui

	local debugTools = {}

	function debugTools.printPlayerGuiChildren()
		for _, child in ipairs(playerGui:GetChildren()) do
			print("PlayerGui child:", child.Name, child.ClassName, getGuiVisibleState(child))
		end
	end

	function debugTools.printFishingGuiChildren()
		for _, child in ipairs(screenGui:GetChildren()) do
			print("FishingGui child:", child.Name, child.ClassName, getGuiVisibleState(child))
		end

		for _, descendant in ipairs(screenGui:GetDescendants()) do
			if descendant.Name == "CoinsHud"
				or descendant.Name == "FishingXPBar"
				or descendant.Name == "TopButtonsFrame"
				or descendant.Name == "SettingsButton"
				or descendant.Name == "QuestsButton"
				or descendant.Name == "ShopButton"
				or descendant.Name == "AutoFishButton"
				or descendant.Name == "TapButton"
			then
				print("FishingGui HUD descendant:", descendant.Name, descendant.ClassName, getGuiVisibleState(descendant))
			end
		end
	end

	function debugTools.printPlayerGuiScreenGuis(context)
		local names = {}
		for _, child in ipairs(playerGui:GetChildren()) do
			if child:IsA("ScreenGui") then
				table.insert(names, child.Name .. " [" .. child:GetFullName() .. "]")
			end
		end
		table.sort(names)
		print("PlayerGui ScreenGui children after spawn:", context, #names &gt; 0 and table.concat(names, ", ") or "(none)")
	end

	return debugTools
end

return PlayerGuiDebug
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="726">
            <Properties>
              <string name="Name">QuestHelpers</string>
              <string name="Source">local QuestHelpers = {}

function QuestHelpers.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.formatQuestReward(reward)
		local parts = {}
		reward = type(reward) == "table" and reward or {}

		if (tonumber(reward.coins) or 0) &gt; 0 then
			table.insert(parts, tostring(reward.coins) .. " Coins")
		end
		if (tonumber(reward.xp) or 0) &gt; 0 then
			table.insert(parts, tostring(reward.xp) .. " Fishing XP")
		end
		if type(reward.bait) == "table" then
			for _, baitId in ipairs(GameConfig.BaitOrder) do
				local amount = tonumber(reward.bait[baitId]) or 0
				if amount &gt; 0 then
					local bait = GameConfig.Baits[baitId]
					table.insert(parts, tostring(amount) .. " " .. (bait and bait.displayName or baitId))
				end
			end
		end
		if type(reward.decorations) == "table" then
			for _, amount in pairs(reward.decorations) do
				amount = tonumber(amount) or 0
				if amount &gt; 0 then
					table.insert(parts, amount &gt; 1 and (tostring(amount) .. " Aquarium Decorations") or "Aquarium Decoration")
				end
			end
		end

		if #parts == 0 then
			return "Reward ready"
		end

		return table.concat(parts, " | ")
	end

	function helpers.getQuestPeriod(periodName)
		local state = getState()
		local quests = state and state.Quests
		return quests and quests[periodName] or nil
	end

	return helpers
end

return QuestHelpers
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="727">
            <Properties>
              <string name="Name">QuestModernUI</string>
              <string name="Source">-- QuestModernUI
-- ModuleScript location:
-- StarterGui &gt; FishingGui &gt; FishingClient &gt; QuestModernUI
--
-- This module binds the authored Daily / Weekly / Monthly quest UI.
-- It reads the existing quest state from FishingRemotes and uses
-- the existing QuestAction remote to claim completed rewards.

local QuestModernUI = {}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")
local Lighting = game:GetService("Lighting")
local UserInputService = game:GetService("UserInputService")

local ASSETS = {
	MainWindow = "rbxassetid://75381184130055",
	HeaderPanel = "rbxassetid://139422887890221",
	QuestCard = "rbxassetid://93889386487602",

	-- Exact tab artwork supplied by the user.
	TabNormal = "rbxassetid://101135473927300",
	TabSelected = "rbxassetid://106120450577925",
	DailyWeeklyTabIcon = "rbxassetid://86912435019607",
	MonthlyTabIcon = "rbxassetid://78189475055056",

	CloseButton = "rbxassetid://119322438066977",

	QuestIcon1 = "rbxassetid://76825236524029",
	QuestIcon2 = "rbxassetid://105499819099238",
	QuestIcon3 = "rbxassetid://88355071605279",
	QuestIcon4 = "rbxassetid://101869041913042",

	HeaderDecoration = "rbxassetid://75908657886403",
	RewardBox = "rbxassetid://117715064456350",
	CornerDecoration = "rbxassetid://86731176898277",

	ProgressTrack = "rbxassetid://133345960968161",
	ProgressGreenFill = "rbxassetid://125033823798319",

	-- The supplied scrollbar image contains both track and thumb artwork.
	Scrollbar = "rbxassetid://73367138577137",

	StatusBlue = "rbxassetid://96566593336613",
	StatusGreen = "rbxassetid://109147124391851",

	MoneyIcon = "rbxassetid://133418085425740",
	XPIcon = "rbxassetid://102202681165196",
}

-- These source rectangles remove the transparent padding from the
-- original uploaded images. Do not change these unless the source
-- PNG files are re-uploaded with different dimensions.
local DEFAULT_SOURCE_CANVAS_SIZE = Vector2.new(1187, 1326)
local TAB_SOURCE_CANVAS_SIZE = Vector2.new(1448, 1086)
local PANEL_SOURCE_CANVAS_SIZE = Vector2.new(1672, 941)
local SCROLLBAR_SOURCE_CANVAS_SIZE = Vector2.new(1448, 1086)

local CROPS = {
	HeaderPanel = {
		canvas = PANEL_SOURCE_CANVAS_SIZE,
		offset = Vector2.new(22, 279),
		size = Vector2.new(1628, 376),
	},
	QuestCard = {
		canvas = PANEL_SOURCE_CANVAS_SIZE,
		offset = Vector2.new(14, 218),
		size = Vector2.new(1650, 466),
	},

	CloseButton = {
		offset = Vector2.new(375, 422),
		size = Vector2.new(427, 439),
	},
	QuestIcon1 = {
		offset = Vector2.new(343, 391),
		size = Vector2.new(492, 513),
	},
	QuestIcon2 = {
		offset = Vector2.new(317, 382),
		size = Vector2.new(547, 554),
	},
	QuestIcon3 = {
		offset = Vector2.new(302, 366),
		size = Vector2.new(582, 592),
	},
	QuestIcon4 = {
		offset = Vector2.new(375, 420),
		size = Vector2.new(435, 455),
	},
	-- IMPORTANT: use the original tab assets directly with no crop.
	-- The previous crop rectangles were cutting off the rounded ends,
	-- which is why the tabs looked like squared rectangles.
	TabNormal = nil,
	TabSelected = nil,
	ScrollbarTrack = {
		canvas = SCROLLBAR_SOURCE_CANVAS_SIZE,
		offset = Vector2.new(683, 29),
		size = Vector2.new(65, 1021),
	},
	ScrollbarThumb = {
		canvas = SCROLLBAR_SOURCE_CANVAS_SIZE,
		offset = Vector2.new(701, 77),
		size = Vector2.new(30, 825),
	},
	ScrollbarChannel = {
		canvas = SCROLLBAR_SOURCE_CANVAS_SIZE,
		offset = Vector2.new(701, 914),
		size = Vector2.new(30, 90),
	},
	HeaderDecoration = {
		offset = Vector2.new(424, 504),
		size = Vector2.new(342, 174),
	},
	RewardBox = {
		offset = Vector2.new(373, 543),
		size = Vector2.new(440, 232),
	},
	MoneyIcon = {
		offset = Vector2.new(539, 618),
		size = Vector2.new(58, 64),
	},
	XPIcon = {
		offset = Vector2.new(565, 624),
		size = Vector2.new(51, 56),
	},
	CornerDecoration = {
		offset = Vector2.new(1000, 1080),
		size = Vector2.new(187, 246),
	},
}

-- =========================
-- EASY UI TUNING VALUES
-- =========================

local BASE_WIDTH = 1187
local BASE_HEIGHT = 1326
-- Exact recovered v1615 post-fit scale. Keeping this in the behavior module
-- makes the authored Explorer panel and the original runtime presentation use
-- the same responsive size on every viewport.
local QUEST_UI_SIZE_MULTIPLIER = 0.72

-- Keep the quest cards below the lowered header panel.
local LIST_Y = 382
local CARD_HEIGHT = 238
local CARD_GAP = 12

-- Quest UI background blur
local QUEST_BLUR_SIZE = 10
local QUEST_BLUR_TWEEN_TIME = 0.18

-- Quest list scrolling
local QUEST_SCROLL_WHEEL_STEP = 150
local QUEST_SCROLL_BOTTOM_PADDING = 120

local AUTO_CLAIM_COMPLETED_QUESTS = true

local PERIODS = { "Daily", "Weekly", "Monthly" }

local PERIOD_LABELS = {
	Daily = "Daily",
	Weekly = "Weekly",
	Monthly = "Monthly",
}

local PERIOD_TITLES = {
	Daily = "Daily Quests",
	Weekly = "Weekly Quests",
	Monthly = "Monthly Quests",
}

local function requireChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(child, string.format("Quest authored node %s.%s is missing", parent:GetFullName(), name))
	assert(
		child:IsA(className),
		string.format(
			"Quest authored node %s.%s must be %s, got %s",
			parent:GetFullName(),
			name,
			className,
			child.ClassName
		)
	)
	return child
end

local function cloneTemplate(templates, name, className)
	local template = requireChild(templates, name, className)
	return template:Clone()
end

local function makeText(parent, name, text, textSize, color, font)
	local label = requireChild(parent, name, "TextLabel")
	label.BackgroundTransparency = 1
	label.BorderSizePixel = 0
	label.Font = font or Enum.Font.FredokaOne
	label.Text = text or ""
	label.TextColor3 = color or Color3.new(1, 1, 1)
	label.TextSize = textSize or 24
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 0.25
	label.ZIndex = 205
	label.Visible = true
	return label
end

local function makeArtwork(parent, imageId, zIndex, crop)
	local artwork = requireChild(parent, "Artwork", "ImageLabel")
	artwork.BackgroundTransparency = 1
	artwork.BorderSizePixel = 0
	artwork.Image = imageId
	artwork.ScaleType = Enum.ScaleType.Stretch
	artwork.ZIndex = zIndex or 200
	artwork.Visible = true

	if crop then
		-- Crop by normalized layout. Each asset can provide its real source
		-- canvas size, so tab/scrollbar images are not clipped with the old
		-- 1187 x 1326 coordinates.
		local canvas = crop.canvas or DEFAULT_SOURCE_CANVAS_SIZE
		artwork.Position = UDim2.fromScale(
			-crop.offset.X / crop.size.X,
			-crop.offset.Y / crop.size.Y
		)
		artwork.Size = UDim2.fromScale(
			canvas.X / crop.size.X,
			canvas.Y / crop.size.Y
		)
	else
		artwork.Position = UDim2.fromScale(0, 0)
		artwork.Size = UDim2.fromScale(1, 1)
	end

	return artwork
end

local function applyArtworkCrop(artwork, imageId, crop)
	if not artwork then
		return
	end

	artwork.Image = imageId
	artwork.ImageColor3 = Color3.new(1, 1, 1)
	artwork.ImageTransparency = 0
	artwork.ScaleType = Enum.ScaleType.Stretch

	if crop then
		local canvas = crop.canvas or DEFAULT_SOURCE_CANVAS_SIZE
		artwork.Position = UDim2.fromScale(
			-crop.offset.X / crop.size.X,
			-crop.offset.Y / crop.size.Y
		)
		artwork.Size = UDim2.fromScale(
			canvas.X / crop.size.X,
			canvas.Y / crop.size.Y
		)
	else
		artwork.Position = UDim2.fromScale(0, 0)
		artwork.Size = UDim2.fromScale(1, 1)
	end
end

local function getArtwork(guiObject)
	if not guiObject then
		return nil
	end

	if guiObject:IsA("ImageLabel") or guiObject:IsA("ImageButton") then
		return guiObject
	end

	return guiObject:FindFirstChild("Artwork")
end

local function setArtworkColor(guiObject, color)
	local artwork = getArtwork(guiObject)
	if artwork then
		artwork.ImageColor3 = color
	end
end

local function setArtworkTransparency(guiObject, transparency)
	local artwork = getArtwork(guiObject)
	if artwork then
		artwork.ImageTransparency = transparency
	end
end

local function makeImage(parent, name, imageId, position, size, zIndex, crop)
	local holder = requireChild(parent, name, "Frame")
	holder.BackgroundTransparency = 1
	holder.BorderSizePixel = 0
	holder.Position = position
	holder.Size = size
	holder.ClipsDescendants = crop ~= nil
	holder.ZIndex = zIndex or 200
	holder.Visible = true

	makeArtwork(holder, imageId, zIndex or 200, crop)
	return holder
end

local function addPressFeedback(button, bind)
	local originalSize = button.Size
	local originalPosition = button.Position
	local artwork = getArtwork(button)

	local pressedSize = UDim2.new(
		originalSize.X.Scale,
		originalSize.X.Offset - 6,
		originalSize.Y.Scale,
		originalSize.Y.Offset - 6
	)

	local pressedPosition = UDim2.new(
		originalPosition.X.Scale,
		originalPosition.X.Offset + 3,
		originalPosition.Y.Scale,
		originalPosition.Y.Offset + 3
	)

	local currentButtonTween
	local currentArtworkTween

	local function tweenTo(pressed)
		if currentButtonTween then
			currentButtonTween:Cancel()
		end
		if currentArtworkTween then
			currentArtworkTween:Cancel()
		end

		currentButtonTween = TweenService:Create(
			button,
			TweenInfo.new(0.07, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{
				Size = pressed and pressedSize or originalSize,
				Position = pressed and pressedPosition or originalPosition,
			}
		)
		currentButtonTween:Play()

		if artwork then
			currentArtworkTween = TweenService:Create(
				artwork,
				TweenInfo.new(0.07, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{
					ImageTransparency = pressed and 0.16 or 0,
				}
			)
			currentArtworkTween:Play()
		end
	end

	bind(button.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			tweenTo(true)
		end
	end)

	bind(button.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			tweenTo(false)
		end
	end)

	bind(button.MouseLeave, function()
		tweenTo(false)
	end)
end

local function getUtcNowTable(now)
	return os.date("!*t", now or DateTime.now().UnixTimestamp)
end

local function getNextResetTimestamp(periodName, now)
	now = now or DateTime.now().UnixTimestamp
	local utc = getUtcNowTable(now)

	if periodName == "Daily" then
		local startOfToday = DateTime.fromUniversalTime(
			utc.year,
			utc.month,
			utc.day,
			0,
			0,
			0
		).UnixTimestamp

		return startOfToday + 86400
	end

	if periodName == "Weekly" then
		local startOfToday = DateTime.fromUniversalTime(
			utc.year,
			utc.month,
			utc.day,
			0,
			0,
			0
		).UnixTimestamp

		-- os.date wday: Sunday = 1, Monday = 2.
		local daysUntilMonday = (9 - utc.wday) % 7
		if daysUntilMonday == 0 then
			daysUntilMonday = 7
		end

		return startOfToday + (daysUntilMonday * 86400)
	end

	local nextYear = utc.year
	local nextMonth = utc.month + 1
	if nextMonth &gt; 12 then
		nextMonth = 1
		nextYear += 1
	end

	return DateTime.fromUniversalTime(
		nextYear,
		nextMonth,
		1,
		0,
		0,
		0
	).UnixTimestamp
end

local function formatRemainingTime(totalSeconds)
	totalSeconds = math.max(0, math.floor(totalSeconds))

	local days = math.floor(totalSeconds / 86400)
	local hours = math.floor((totalSeconds % 86400) / 3600)
	local minutes = math.floor((totalSeconds % 3600) / 60)
	local seconds = totalSeconds % 60

	if days &gt; 0 then
		return string.format("%dd %02dh %02dm %02ds", days, hours, minutes, seconds)
	end

	return string.format("%02dh %02dm %02ds", hours, minutes, seconds)
end

local function getObjectiveIconKey(quest, index)
	-- Keep the first four quest-card icons in the exact visual order:
	-- 1 = blue fish, 2 = red fish, 3 = fishing rod, 4 = treasure chest.
	if index == 1 then
		return "QuestIcon1"
	elseif index == 2 then
		return "QuestIcon2"
	elseif index == 3 then
		return "QuestIcon3"
	elseif index == 4 then
		return "QuestIcon4"
	end

	-- For any additional quests, fall back to objective-based icons.
	local objectiveType = quest and quest.objectiveType

	if objectiveType == "catch_any"
		or objectiveType == "discover_biome_species" then
		return "QuestIcon1"
	end

	if objectiveType == "catch_specific_fish"
		or objectiveType == "catch_rarity" then
		return "QuestIcon2"
	end

	if objectiveType == "perfect_cast" then
		return "QuestIcon3"
	end

	if objectiveType == "login"
		or objectiveType == "daily_login"
		or objectiveType == "play_session" then
		return "QuestIcon4"
	end

	local fallback = ((index - 1) % 4) + 1
	return "QuestIcon" .. tostring(fallback)
end

local function getQuestTable(state)
	if type(state) ~= "table" then
		return nil
	end

	return state.Quests or state.QuestState
end

local function textLooksQuestRelated(text)
	if type(text) ~= "string" then
		return false
	end

	local lower = string.lower(text)
	return lower:find("daily quests", 1, true) ~= nil
		or lower == "daily"
		or lower == "weekly"
		or lower == "monthly"
		or lower:find("resets automatically", 1, true) ~= nil
		or lower:find("complete", 1, true) ~= nil
end

local function looksLikeLegacyQuestUi(guiObject, modernRoot)
	if not guiObject or guiObject == modernRoot then
		return false
	end

	if guiObject:IsDescendantOf(modernRoot) then
		return false
	end

	local lowerName = string.lower(guiObject.Name or "")
	if lowerName:find("quest", 1, true) then
		return true
	end

	for _, descendant in ipairs(guiObject:GetDescendants()) do
		local descendantName = string.lower(descendant.Name or "")
		if descendantName:find("quest", 1, true) then
			return true
		end

		if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
			if textLooksQuestRelated(descendant.Text) then
				return true
			end
		end
	end

	return false
end

local function hideLegacyQuestUi(parentGui, modernRoot, store)
	for _, child in ipairs(parentGui:GetChildren()) do
		if child:IsA("GuiObject") and looksLikeLegacyQuestUi(child, modernRoot) then
			-- Save the original visibility only once.
			-- The old quest panel can be rebuilt after the modern UI opens,
			-- so this function may run repeatedly while the modern UI is visible.
			if store[child] == nil then
				store[child] = child.Visible
			end

			child.Visible = false
		end
	end
end

local function restoreLegacyQuestUi(store)
	for guiObject in pairs(store) do
		if guiObject and guiObject.Parent and guiObject:IsA("GuiObject") then
			guiObject.Visible = false
		end
		store[guiObject] = nil
	end
end

function QuestModernUI.create(config)
	assert(type(config) == "table", "QuestModernUI.create requires a config table")
	assert(config.parent, "QuestModernUI.create requires config.parent")

	if QuestModernUI.activeController
		and QuestModernUI.activeController.root
		and QuestModernUI.activeController.root.Parent
	then
		return QuestModernUI.activeController
	end

	local player = Players.LocalPlayer
	local remotes = config.remotes
		or ReplicatedStorage:WaitForChild("FishingRemotes")

	local stateUpdated = remotes:WaitForChild("StateUpdated")
	local getState = remotes:WaitForChild("GetState")
	local questAction = remotes:WaitForChild("QuestAction")

	local controller = {
		activePeriod = "Daily",
		state = config.initialState,
		claimRequests = {},
		lastResetRefreshAt = 0,
		backpackWasEnabled = false,
		hiddenLegacyQuestGuis = {},
		blurTween = nil,
		legacySuppressConnection = nil,
		legacySuppressElapsed = 0,
		authoredUi = config.authoredUi == true,
		boundConnections = {},
	}

	local function bind(signal, callback)
		local connection = signal:Connect(callback)
		table.insert(controller.boundConnections, connection)
		return connection
	end

	-- Keep the old Roblox Backpack / inventory hotbar hidden permanently.
	pcall(function()
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
	end)

	assert(controller.authoredUi, "QuestModernUI requires the authored StarterGui hierarchy")
	local authoredHost = requireChild(config.parent, "ModernQuestUI", "Frame")
	local overlay = requireChild(authoredHost, "QuestCanvas", "Frame")
	local templates = requireChild(authoredHost, "Templates", "Folder")
	controller.root = overlay
	controller.host = authoredHost
	controller.templates = templates
	controller.root.Visible = false
	controller.host.Visible = false

	local questBlur = Lighting:FindFirstChild("FishyFishQuestUiBlur")
	if not questBlur then
		questBlur = requireChild(authoredHost, "FishyFishQuestUiBlur", "BlurEffect")
		questBlur.Parent = Lighting
	end

	questBlur.Enabled = false
	questBlur.Size = 0
	controller.questBlur = questBlur

	local function setQuestBlurVisible(visible)
		if controller.blurTween then
			controller.blurTween:Cancel()
			controller.blurTween = nil
		end

		if visible then
			questBlur.Enabled = true
			controller.blurTween = TweenService:Create(
				questBlur,
				TweenInfo.new(
					QUEST_BLUR_TWEEN_TIME,
					Enum.EasingStyle.Quad,
					Enum.EasingDirection.Out
				),
				{ Size = QUEST_BLUR_SIZE }
			)
			controller.blurTween:Play()
		else
			local closingTween = TweenService:Create(
				questBlur,
				TweenInfo.new(
					QUEST_BLUR_TWEEN_TIME,
					Enum.EasingStyle.Quad,
					Enum.EasingDirection.Out
				),
				{ Size = 0 }
			)

			controller.blurTween = closingTween
			closingTween.Completed:Connect(function()
				if controller.blurTween == closingTween
					and not controller.root.Visible then
					questBlur.Enabled = false
				end
			end)
			closingTween:Play()
		end
	end

	controller.setQuestBlurVisible = setQuestBlurVisible

	local function stopLegacyQuestSuppression()
		if controller.legacySuppressConnection then
			controller.legacySuppressConnection:Disconnect()
			controller.legacySuppressConnection = nil
		end
		controller.legacySuppressElapsed = 0
	end

	local function startLegacyQuestSuppression()
		stopLegacyQuestSuppression()
		if controller.authoredUi then
			return
		end

		-- Hide once immediately.
		hideLegacyQuestUi(
			config.parent,
			controller.root,
			controller.hiddenLegacyQuestGuis
		)

		-- FishingClient can rebuild the old quest panel after the modern UI
		-- has already opened. Keep suppressing it while this UI is visible.
		controller.legacySuppressConnection = RunService.RenderStepped:Connect(function(deltaTime)
			controller.legacySuppressElapsed += deltaTime
			if controller.legacySuppressElapsed &lt; 0.08 then
				return
			end
			controller.legacySuppressElapsed = 0

			hideLegacyQuestUi(
				config.parent,
				controller.root,
				controller.hiddenLegacyQuestGuis
			)
		end)
	end

	controller.startLegacyQuestSuppression = startLegacyQuestSuppression
	controller.stopLegacyQuestSuppression = stopLegacyQuestSuppression

	local scale = requireChild(overlay, "ResponsiveScale", "UIScale")
	controller.scale = scale

	local function updateResponsiveScale()
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1920, 1080)

		local fit = math.min(
			(viewport.X * 0.97) / BASE_WIDTH,
			(viewport.Y * 0.94) / BASE_HEIGHT
		)

		scale.Scale = math.clamp(
			fit * QUEST_UI_SIZE_MULTIPLIER,
			0.26,
			1
		)
	end

	updateResponsiveScale()

	local camera = workspace.CurrentCamera
	if camera then
		controller.viewportConnection = camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateResponsiveScale)
	end

	local background = requireChild(overlay, "MainWindow", "Frame")
	controller.background = background

	-- Tabs
	-- The actual selected/unselected images are created here in QuestModernUI.
	-- QuestModernClient no longer paints any rectangles over these buttons.
	controller.tabButtons = {}
	controller.tabLabels = {}
	controller.tabArtworks = {}
	controller.tabVisualHolders = {}

	for _, periodName in ipairs(PERIODS) do
		local button = requireChild(overlay, periodName .. "Tab", "ImageButton")
		local visualHolder = requireChild(button, "TabVisual", "Frame")
		local artwork = requireChild(visualHolder, "Artwork", "ImageLabel")
		local label = requireChild(button, "Label", "TextLabel")
		requireChild(button, periodName .. "Icon", "ImageLabel")

		bind(button.MouseButton1Click, function()
			controller.activePeriod = periodName
			controller.list.CanvasPosition = Vector2.zero
			controller:Render()
		end)

		controller.tabButtons[periodName] = button
		controller.tabLabels[periodName] = label
		controller.tabArtworks[periodName] = artwork
		controller.tabVisualHolders[periodName] = visualHolder
	end

	local closeButton = requireChild(overlay, "CloseButton", "ImageButton")
	addPressFeedback(closeButton, bind)
	controller.closeButton = closeButton

	bind(closeButton.MouseButton1Click, function()
		controller:SetVisible(false)

		if config.onClose then
			config.onClose()
		end
	end)

	-- Header
	local header = requireChild(overlay, "HeaderPanel", "Frame")
	controller.header = header

	local headerTitle = requireChild(header, "HeaderTitle", "TextLabel")
	controller.headerTitle = headerTitle

	local completedText = requireChild(header, "CompletedText", "TextLabel")
	controller.completedText = completedText

	requireChild(header, "Separator", "TextLabel")
	requireChild(header, "ResetText", "TextLabel")

	local clockHolder = requireChild(header, "Clock", "Frame")
	controller.clockHolder = clockHolder

	requireChild(clockHolder, "ClockCircle", "Frame")
	local clockHand = requireChild(clockHolder, "ClockHand", "Frame")
	controller.clockHand = clockHand

	requireChild(clockHolder, "ClockCenter", "Frame")

	local timerText = requireChild(header, "TimerText", "TextLabel")
	controller.timerText = timerText

	requireChild(header, "HeaderDecoration", "Frame")

	-- Scroll area
	local list = requireChild(overlay, "QuestList", "ScrollingFrame")
	-- The previous UI used only the supplied custom scrollbar artwork. Keep the
	-- native Roblox bar disabled in both the authored model and at runtime.
	list.ScrollBarThickness = 0
	list.ScrollBarImageTransparency = 1
	list.VerticalScrollBarInset = Enum.ScrollBarInset.None
	controller.list = list

	local scrollInputCatcher = requireChild(overlay, "ScrollInputCatcher", "TextButton")
	controller.scrollInputCatcher = scrollInputCatcher

	local listLayout = requireChild(list, "QuestListLayout", "UIListLayout")
	controller.listLayout = listLayout

	-- Custom scrollbar using the supplied image.
	local scrollbarTrack = requireChild(overlay, "ScrollbarTrack", "Frame")
	controller.scrollbarTrack = scrollbarTrack

	-- Cover the sample thumb baked into the full scrollbar artwork.
	local scrollbarChannel = requireChild(scrollbarTrack, "ScrollbarChannel", "Frame")
	controller.scrollbarChannel = scrollbarChannel

	local scrollbarThumb = requireChild(overlay, "ScrollbarThumb", "Frame")
	controller.scrollbarThumb = scrollbarThumb

	-- The thin pale line is actually the clipped right edge of every
	-- QuestCard image, not the scrollbar track. Mask only that 4 px edge.
	local questCardRightEdgeMask = requireChild(overlay, "QuestCardRightEdgeMask", "Frame")
	questCardRightEdgeMask.Visible = true
	controller.questCardRightEdgeMask = questCardRightEdgeMask

	-- Bottom-right decoration.
	-- This asset was supplied separately, so it is used without ImageRect cropping.
	local cornerDecoration = requireChild(overlay, "CornerDecoration", "Frame")
	controller.cornerDecoration = cornerDecoration

	local function updateScrollbar()
		local contentHeight = math.max(
			listLayout.AbsoluteContentSize.Y,
			list.AbsoluteCanvasSize.Y
		)
		local viewportHeight = math.max(1, list.AbsoluteWindowSize.Y)

		if contentHeight &lt;= viewportHeight + 1 then
			scrollbarThumb.Visible = false
			setArtworkTransparency(scrollbarTrack, 0.45)
			return
		end

		scrollbarThumb.Visible = true
		setArtworkTransparency(scrollbarTrack, 0)

		local trackHeight = scrollbarTrack.AbsoluteSize.Y
		if trackHeight &lt;= 0 then
			return
		end

		local ratio = math.clamp(viewportHeight / contentHeight, 0.08, 1)
		local thumbHeight = math.max(48, math.floor(trackHeight * ratio))
		local maxThumbTravel = math.max(0, trackHeight - thumbHeight)

		local maxCanvasY = math.max(1, contentHeight - viewportHeight)
		local scrollRatio = math.clamp(list.CanvasPosition.Y / maxCanvasY, 0, 1)
		local thumbY = math.floor(maxThumbTravel * scrollRatio)

		scrollbarThumb.Position = UDim2.fromOffset(
			1146,
			LIST_Y + thumbY
		)
		scrollbarThumb.Size = UDim2.fromOffset(14, thumbHeight)
	end

	controller.updateScrollbar = updateScrollbar

	local function getMaxCanvasY()
		return math.max(
			0,
			list.AbsoluteCanvasSize.Y - list.AbsoluteWindowSize.Y
		)
	end

	local function setCanvasY(newY)
		list.CanvasPosition = Vector2.new(
			0,
			math.clamp(newY, 0, getMaxCanvasY())
		)
	end

	local function updateCanvasForQuestCount(questCount)
		questCount = math.max(0, math.floor(tonumber(questCount) or 0))

		local contentHeight = 0
		if questCount &gt; 0 then
			contentHeight = (questCount * CARD_HEIGHT)
				+ ((questCount - 1) * CARD_GAP)
				+ QUEST_SCROLL_BOTTOM_PADDING
		end

		list.CanvasSize = UDim2.fromOffset(0, contentHeight)
		task.defer(updateScrollbar)
	end

	controller.updateCanvasForQuestCount = updateCanvasForQuestCount

	bind(listLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
		task.defer(updateScrollbar)
	end)

	bind(list:GetPropertyChangedSignal("CanvasPosition"), updateScrollbar)
	bind(list:GetPropertyChangedSignal("AbsoluteWindowSize"), updateScrollbar)

	-- Mouse wheel: the transparent catcher guarantees the event is received
	-- even when the cursor is over a quest card.
	local wheelDirectionMultiplier = nil

	bind(scrollInputCatcher.InputChanged, function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseWheel then
			return
		end

		local delta = tonumber(input.Position.Z) or 0
		if delta == 0 then
			return
		end

		-- macOS natural scrolling can reverse the wheel sign.
		-- On the first wheel event at the top, assume the player is trying
		-- to move down and remember the correct direction for this session.
		if wheelDirectionMultiplier == nil then
			if list.CanvasPosition.Y &lt;= 1 then
				wheelDirectionMultiplier = delta &gt; 0 and 1 or -1
			else
				wheelDirectionMultiplier = -1
			end
		end

		setCanvasY(
			list.CanvasPosition.Y
				+ (delta * wheelDirectionMultiplier * QUEST_SCROLL_WHEEL_STEP)
		)
	end)

	-- Click/touch and drag anywhere inside the quest list.
	local activeListInput = nil
	local listDragStartY = 0
	local listDragStartCanvasY = 0

	bind(scrollInputCatcher.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			activeListInput = input
			listDragStartY = input.Position.Y
			listDragStartCanvasY = list.CanvasPosition.Y
		end
	end)

	controller.listDragChangedConnection = UserInputService.InputChanged:Connect(function(input)
		if not activeListInput then
			return
		end

		local currentY = nil

		if activeListInput.UserInputType == Enum.UserInputType.Touch then
			if input ~= activeListInput then
				return
			end
			currentY = input.Position.Y
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			currentY = input.Position.Y
		end

		if currentY == nil then
			return
		end

		setCanvasY(
			listDragStartCanvasY
			- (currentY - listDragStartY)
		)
	end)

	controller.listDragEndedConnection = UserInputService.InputEnded:Connect(function(input)
		if input == activeListInput
			or input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeListInput = nil
		end
	end)

	-- Drag the blue scrollbar thumb.
	local activeThumbInput = nil
	local thumbDragStartY = 0
	local thumbDragStartCanvasY = 0

	bind(scrollbarThumb.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			activeThumbInput = input
			thumbDragStartY = input.Position.Y
			thumbDragStartCanvasY = list.CanvasPosition.Y
		end
	end)

	controller.thumbDragChangedConnection = UserInputService.InputChanged:Connect(function(input)
		if not activeThumbInput then
			return
		end

		local currentY = nil

		if activeThumbInput.UserInputType == Enum.UserInputType.Touch then
			if input ~= activeThumbInput then
				return
			end
			currentY = input.Position.Y
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			currentY = input.Position.Y
		end

		if currentY == nil then
			return
		end

		local trackHeight = math.max(1, scrollbarTrack.AbsoluteSize.Y)
		local thumbHeight = math.max(1, scrollbarThumb.AbsoluteSize.Y)
		local maxThumbTravel = math.max(1, trackHeight - thumbHeight)

		setCanvasY(
			thumbDragStartCanvasY
				+ (
					(currentY - thumbDragStartY)
					/ maxThumbTravel
					* getMaxCanvasY()
				)
		)
	end)

	controller.thumbDragEndedConnection = UserInputService.InputEnded:Connect(function(input)
		if input == activeThumbInput
			or input.UserInputType == Enum.UserInputType.MouseButton1 then
			activeThumbInput = nil
		end
	end)

	-- Clicking the scrollbar track jumps directly to that part of the list.
	bind(scrollbarTrack.InputBegan, function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end

		local localY = input.Position.Y - scrollbarTrack.AbsolutePosition.Y
		local ratio = math.clamp(
			localY / math.max(1, scrollbarTrack.AbsoluteSize.Y),
			0,
			1
		)

		setCanvasY(getMaxCanvasY() * ratio)
	end)

	local function refreshStateFromServer()
		local success, result = pcall(function()
			return getState:InvokeServer()
		end)

		if success and type(result) == "table" then
			controller.state = result
			controller:Render()
		end
	end

	controller.refreshStateFromServer = refreshStateFromServer

	function controller:SetState(newState)
		self.state = newState

		if self.root.Visible then
			self:Render()
		end
	end

	function controller:GetPeriod()
		local questTable = getQuestTable(self.state)
		return questTable and questTable[self.activePeriod] or nil
	end

	function controller:UpdateTabs()
		for _, periodName in ipairs(PERIODS) do
			local selected = periodName == self.activePeriod
			local artwork = self.tabArtworks[periodName]
			local visualHolder = self.tabVisualHolders[periodName]
			local label = self.tabLabels[periodName]

			visualHolder.Size = UDim2.fromScale(1, 1)
			visualHolder.Position = UDim2.fromScale(0.5, 0.5)
			applyArtworkCrop(
				artwork,
				selected and ASSETS.TabSelected or ASSETS.TabNormal,
				nil
			)
			artwork.Position = UDim2.fromScale(0, 0)
			artwork.Size = UDim2.fromScale(1, 1)
			artwork.ScaleType = Enum.ScaleType.Stretch

			label.TextColor3 = selected
				and Color3.fromRGB(255, 255, 255)
				or Color3.fromRGB(225, 225, 228)
			label.TextStrokeTransparency = selected and 0.08 or 0.28
		end
	end

	function controller:UpdateHeader()
		local period = self:GetPeriod()
		local quests = period and period.quests or {}

		local completedCount = 0
		for _, quest in ipairs(quests) do
			if quest.completed == true
				or (tonumber(quest.progress) or 0) &gt;= math.max(1, tonumber(quest.target) or 1) then
				completedCount += 1
			end
		end

		self.headerTitle.Text = PERIOD_TITLES[self.activePeriod]
		self.completedText.Text = string.format(
			"%d/%d complete",
			completedCount,
			#quests
		)
	end

	function controller:UpdateTimer()
		local now = DateTime.now().UnixTimestamp
		local resetAt = getNextResetTimestamp(self.activePeriod, now)
		local remaining = resetAt - now

		self.timerText.Text = formatRemainingTime(remaining)

		if remaining &lt;= 0 and os.clock() - self.lastResetRefreshAt &gt; 2 then
			self.lastResetRefreshAt = os.clock()
			task.defer(refreshStateFromServer)
		end
	end

	function controller:ClearCards()
		for _, child in ipairs(self.list:GetChildren()) do
			if child:IsA("GuiObject") then
				child:Destroy()
			end
		end
	end

	function controller:MakeRewardBox(card, x, iconKey, value, suffix)
		local rewardBox = makeImage(
			card,
			iconKey .. "RewardBox",
			ASSETS.RewardBox,
			UDim2.fromOffset(x, 134),
			UDim2.fromOffset(132, 70),
			204,
			CROPS.RewardBox
		)

		local icon = makeImage(
			rewardBox,
			"Icon",
			ASSETS[iconKey],
			UDim2.fromOffset(8, 10),
			UDim2.fromOffset(46, 48),
			206,
			CROPS[iconKey]
		)

		local valueText = makeText(
			rewardBox,
			"Value",
			tostring(math.floor(tonumber(value) or 0)),
			29,
			Color3.fromRGB(255, 255, 255)
		)
		valueText.Position = UDim2.fromOffset(54, 4)
		valueText.Size = UDim2.fromOffset(72, suffix and 34 or 60)
		valueText.TextXAlignment = Enum.TextXAlignment.Center
		valueText.ZIndex = 207

		if suffix then
			local suffixText = makeText(
				rewardBox,
				"Suffix",
				suffix,
				20,
				Color3.fromRGB(120, 216, 255),
				Enum.Font.GothamBold
			)
			suffixText.Position = UDim2.fromOffset(54, 35)
			suffixText.Size = UDim2.fromOffset(72, 24)
			suffixText.TextXAlignment = Enum.TextXAlignment.Center
			suffixText.TextStrokeTransparency = 0.15
			suffixText.ZIndex = 207
		end
	end

	function controller:MakeQuestCard(quest, index, period)
		local card = cloneTemplate(self.templates, "QuestCardTemplate", "Frame")
		card.Name = "QuestCard_" .. tostring(quest.id or index)
		card.LayoutOrder = index
		card.Visible = true
		card.Parent = self.list

		local iconKey = getObjectiveIconKey(quest, index)
		local icon = makeImage(
			card,
			"QuestIcon",
			ASSETS[iconKey],
			UDim2.fromOffset(24, 26),
			UDim2.fromOffset(166, 166),
			203,
			CROPS[iconKey]
		)

		local title = makeText(
			card,
			"QuestTitle",
			quest.title or "Quest",
			38,
			Color3.fromRGB(255, 255, 255)
		)
		title.Position = UDim2.fromOffset(220, 24)
		title.Size = UDim2.fromOffset(535, 52)
		title.TextTruncate = Enum.TextTruncate.AtEnd
		title.ZIndex = 204

		local description = makeText(
			card,
			"QuestDescription",
			quest.description or "",
			25,
			Color3.fromRGB(78, 205, 255),
			Enum.Font.GothamBold
		)
		description.Position = UDim2.fromOffset(220, 74)
		description.Size = UDim2.fromOffset(535, 52)
		description.TextWrapped = true
		description.TextStrokeTransparency = 0.4
		description.ZIndex = 204

		local target = math.max(1, math.floor(tonumber(quest.target) or 1))
		local progress = math.clamp(
			math.floor(tonumber(quest.progress) or 0),
			0,
			target
		)
		local complete = quest.completed == true or progress &gt;= target

		local track = makeImage(
			card,
			"ProgressTrack",
			ASSETS.ProgressTrack,
			UDim2.fromOffset(220, 145),
			UDim2.fromOffset(516, 52),
			203
		)
		track.ClipsDescendants = true

		local fillHolder = requireChild(track, "FillHolder", "Frame")
		local greenFill = requireChild(fillHolder, "GreenFill", "Frame")
		local blueFill = requireChild(fillHolder, "BlueFill", "Frame")

		local ratio = math.clamp(progress / target, 0, 1)

		if complete then
			greenFill.Visible = true
			blueFill.Visible = false
		else
			greenFill.Visible = false
			blueFill.Visible = true
			blueFill.Size = UDim2.new(ratio, 0, 1, 0)
		end

		local progressText = makeText(
			track,
			"ProgressText",
			string.format("%d/%d", progress, target),
			31,
			Color3.fromRGB(255, 255, 255)
		)
		progressText.Size = UDim2.fromScale(1, 1)
		progressText.TextXAlignment = Enum.TextXAlignment.Center
		progressText.TextStrokeTransparency = 0
		progressText.ZIndex = 206

		local statusImage = complete and ASSETS.StatusGreen or ASSETS.StatusBlue
		local status = makeImage(
			card,
			"StatusBadge",
			statusImage,
			UDim2.fromOffset(785, 24),
			UDim2.fromOffset(261, 62),
			203
		)

		local statusLabel = makeText(
			status,
			"StatusText",
			complete and "✓  Completed" or "In Progress",
			28,
			complete
				and Color3.fromRGB(85, 255, 35)
				or Color3.fromRGB(0, 224, 255),
			Enum.Font.GothamBold
		)
		statusLabel.Size = UDim2.fromScale(1, 1)
		statusLabel.TextXAlignment = Enum.TextXAlignment.Center
		statusLabel.TextStrokeTransparency = 0.15
		statusLabel.ZIndex = 205

		local rewardsLabel = makeText(
			card,
			"RewardsLabel",
			"Rewards",
			25,
			Color3.fromRGB(72, 210, 255),
			Enum.Font.GothamBold
		)
		rewardsLabel.Position = UDim2.fromOffset(785, 96)
		rewardsLabel.Size = UDim2.fromOffset(250, 34)
		rewardsLabel.TextStrokeTransparency = 0.35
		rewardsLabel.ZIndex = 204

		local reward = quest.reward or {}
		self:MakeRewardBox(
			card,
			785,
			"MoneyIcon",
			reward.coins or 0,
			nil
		)
		self:MakeRewardBox(
			card,
			925,
			"XPIcon",
			reward.xp or 0,
			"XP"
		)

		if complete
			and not quest.claimed
			and AUTO_CLAIM_COMPLETED_QUESTS then
			local periodKey = period and period.periodKey or "unknown"
			local claimKey = table.concat({
				self.activePeriod,
				tostring(periodKey),
				tostring(quest.id),
			}, ":")

			if not self.claimRequests[claimKey] then
				self.claimRequests[claimKey] = true

				task.delay(0.25, function()
					questAction:FireServer(
						"Claim",
						self.activePeriod,
						quest.id
					)
				end)

				task.delay(5, function()
					self.claimRequests[claimKey] = nil
				end)
			end
		end

		return card
	end

	function controller:RenderCards()
		self:ClearCards()

		local period = self:GetPeriod()
		local quests = period and period.quests or {}

		if #quests == 0 then
			local empty = cloneTemplate(self.templates, "EmptyQuestTemplate", "TextLabel")
			empty.Name = "EmptyText"
			empty.Visible = true
			empty.Parent = self.list
			self.updateCanvasForQuestCount(1)
			return
		end

		for index, quest in ipairs(quests) do
			self:MakeQuestCard(quest, index, period)
		end

		self.updateCanvasForQuestCount(#quests)
	end

	function controller:Render()
		if not self.root.Parent then
			return
		end

		self:UpdateTabs()
		self:UpdateHeader()
		self:UpdateTimer()
		self:RenderCards()
	end

	function controller:SetVisible(visible)
		visible = visible == true
		self.root.Visible = visible
		self.host.Visible = visible
		self.setQuestBlurVisible(visible)

		-- The game's custom hotbar is used instead of Roblox's default Backpack UI.
		-- Keep CoreGui Backpack disabled both while opening and closing Quest UI.
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
		end)

		self.backpackWasEnabled = false

		if visible then
			self.startLegacyQuestSuppression()

			self:Render()
			task.defer(self.updateScrollbar)
		else
			self.stopLegacyQuestSuppression()
			restoreLegacyQuestUi(self.hiddenLegacyQuestGuis)
		end
	end

	function controller:IsVisible()
		return self.host.Visible and self.root.Visible
	end

	function controller:Destroy()
		self.stopLegacyQuestSuppression()

		if self.blurTween then
			self.blurTween:Cancel()
			self.blurTween = nil
		end

		if self.questBlur then
			self.questBlur.Size = 0
			self.questBlur.Enabled = false
		end

		-- Never restore Roblox's default Backpack UI.
		pcall(function()
			StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
		end)
		self.backpackWasEnabled = false

		restoreLegacyQuestUi(self.hiddenLegacyQuestGuis)

		for _, connection in ipairs(self.boundConnections) do
			connection:Disconnect()
		end
		table.clear(self.boundConnections)

		if self.stateConnection then
			self.stateConnection:Disconnect()
		end

		if self.timerConnection then
			self.timerConnection:Disconnect()
		end

		if self.viewportConnection then
			self.viewportConnection:Disconnect()
		end

		if self.listDragChangedConnection then
			self.listDragChangedConnection:Disconnect()
		end

		if self.listDragEndedConnection then
			self.listDragEndedConnection:Disconnect()
		end

		if self.thumbDragChangedConnection then
			self.thumbDragChangedConnection:Disconnect()
		end

		if self.thumbDragEndedConnection then
			self.thumbDragEndedConnection:Disconnect()
		end

		if self.root then
			self.root.Visible = false
		end
		if self.host then
			self.host.Visible = false
		end
		QuestModernUI.activeController = nil
	end

	if config.manageRemoteState ~= false then
		controller.stateConnection = stateUpdated.OnClientEvent:Connect(function(newState)
			controller:SetState(newState)
		end)
	end

	controller.timerConnection = RunService.RenderStepped:Connect(function()
		if not controller.root.Visible then
			return
		end

		controller.clockHand.Rotation = (os.clock() * 120) % 360

		local second = math.floor(os.clock())
		if controller.lastTimerSecond ~= second then
			controller.lastTimerSecond = second
			controller:UpdateTimer()
		end
	end)

	if config.manageRemoteState ~= false then
		task.spawn(refreshStateFromServer)
	end

	print("[QuestModernUI] Header/card margins rebalanced and top tabs enlarged/lowered.")

	QuestModernUI.activeController = controller
	return controller
end

return QuestModernUI
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="728">
            <Properties>
              <string name="Name">RarityCatchController</string>
              <string name="Source">local RarityCatchController = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local FishingSFX = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("FishingSFX"))

local BLUE_GAUGE_ASSET = "rbxassetid://138976342109765"
local PURPLE_GAUGE_ASSET = "rbxassetid://139485689258376"
local ORANGE_GAUGE_ASSET = "rbxassetid://127598747171041"
local RED_GAUGE_ASSET = "rbxassetid://97502541593370"

local RAGE_WARNING_DURATION = 3
local INITIAL_DRAIN_DURATION = 0.65
local STAGE_DRAIN_DURATION = 0.55

local RAGE_STAGES = {
	{
		name = "Epic",
		goal = 30,
		asset = PURPLE_GAUGE_ASSET,
		topColor = Color3.fromRGB(222, 137, 255),
		bottomColor = Color3.fromRGB(119, 52, 226),
	},
	{
		name = "Legendary",
		goal = 50,
		asset = ORANGE_GAUGE_ASSET,
		topColor = Color3.fromRGB(255, 207, 92),
		bottomColor = Color3.fromRGB(235, 102, 27),
	},
	{
		name = "Mythic",
		goal = 100,
		asset = RED_GAUGE_ASSET,
		topColor = Color3.fromRGB(255, 126, 116),
		bottomColor = Color3.fromRGB(218, 34, 52),
	},
}

local RARITY_STAGE_COUNTS = {
	Epic = 1,
	Legendary = 2,
	Mythic = 3,
}

local function normalizeRarity(rarity)
	if rarity == "Mythical" then
		return "Mythic"
	end

	return rarity or "Common"
end

local function isRageRarity(rarity)
	return RARITY_STAGE_COUNTS[rarity] ~= nil
end

local function setGradient(gradient, topColor, bottomColor)
	-- The legacy progress fill owns this gradient in the authored
	-- FishingMinigame model. The modern gauge is rendered from its three image
	-- slices, so its transparent ProgressFill intentionally has no gradient.
	if not gradient then
		return
	end

	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, topColor),
		ColorSequenceKeypoint.new(1, bottomColor),
	})
end

local function isReelInput(input)
	return input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch
		or input.KeyCode == Enum.KeyCode.Space
end

local function isKeyboardTapInput(input)
	return input.KeyCode == Enum.KeyCode.Space
		or input.KeyCode == Enum.KeyCode.ButtonA
end

function RarityCatchController.start(options)
	local prompt = options.prompt or {}
	local gameConfig = options.GameConfig
	local legacyUi = options.ui
	local modernUi = options.modernUi
	local ui = legacyUi
	if modernUi then
		ui = setmetatable({
			catchButton = legacyUi.catchButton,
			timingBar = legacyUi.timingBar,
			zone = legacyUi.zone,
			marker = legacyUi.marker,
			fishingGameContent = modernUi.panel,
			catchBar = modernUi.catchBar,
			fishMarker = modernUi.fishMarker,
			progressTrack = modernUi.progressTrack,
			progressFill = modernUi.progressFill,
			minigameText = modernUi.headerText,
			minigameFishInfo = modernUi.statusText,
			minigameProgressText = modernUi.progressText,
			minigameInstruction = modernUi.instructionText,
		}, { __index = legacyUi })
	end
	local runService = options.RunService
	local inputService = options.UserInputService
	local showToast = options.showToast
	local tapButton = options.tapButton
	assert(tapButton and tapButton:IsA("GuiButton"), "RarityCatchController requires the current Tap button")
	local tapButtonIsTextButton = tapButton:IsA("TextButton")
	local tapButtonOriginalText = tapButtonIsTextButton and tapButton.Text or nil
	local tapButtonOriginalAutoButtonColor = tapButton.AutoButtonColor
	local tapButtonOriginalActive = tapButton.Active
	local tapButtonOriginalVisible = tapButton.Visible
	local tapButtonParent = tapButton.Parent
	local tapButtonParentWasVisible = tapButtonParent
		and tapButtonParent:IsA("GuiObject")
		and tapButtonParent.Visible
		or nil
	local tapButtonParentForceVisible = tapButtonParent
		and tapButtonParent:GetAttribute("ForceFishingTapVisible")
		or nil
	local tapSiblingVisibility = {}
	if tapButtonParent then
		for _, sibling in ipairs(tapButtonParent:GetChildren()) do
			if sibling ~= tapButton and sibling:IsA("GuiObject") then
				tapSiblingVisibility[sibling] = sibling.Visible
			end
		end
	end
	local fish = prompt.fish or {}
	local rarity = normalizeRarity(fish.rarity)
	local isAutoFish = prompt.autoFish == true
	local minigameConfig = prompt.minigame
		or gameConfig.getFishingMinigameConfig(rarity, options.state and options.state.EquippedRod or "WoodenRod")
	local difficulty = minigameConfig.difficulty
		or gameConfig.FishingMinigame.RarityDifficulty.Common

	-- Uncommon deliberately uses Common movement and only fills more slowly.
	if rarity == "Uncommon" then
		difficulty = gameConfig.FishingMinigame.RarityDifficulty.Common
	end

	local promptBait = prompt.bait or {}
	local promptBaitId = promptBait.id
		or (options.state and options.state.EquippedBait)
		or gameConfig.BasicBaitId
	local promptBaitData = options.getBaitData(promptBaitId)
	local promptBaitName = promptBait.name or promptBaitData.displayName
	local promptBaitText = "Bait: "
		.. promptBaitName
		.. " ("
		.. options.getBaitCountText(promptBaitId, promptBait.remaining)
		.. ")"
	local castText = prompt.cast and prompt.cast.displayName
		and ("\nCast: " .. prompt.cast.displayName)
		or ""
	if modernUi then
		modernUi.baitText.Text = string.format(
			'&lt;font color="#38D9FF"&gt;Bait:&lt;/font&gt; %s (%s)',
			promptBaitName,
			options.getBaitCountText(promptBaitId, promptBait.remaining)
		)
		modernUi.castText.Text = prompt.cast and prompt.cast.displayName
			and string.format('&lt;font color="#38D9FF"&gt;Cast:&lt;/font&gt; %s', prompt.cast.displayName)
			or '&lt;font color="#38D9FF"&gt;Cast:&lt;/font&gt; --'
	end

	local random = Random.new(math.floor((os.clock() * 100000) % 2147483647))
	local standardProgressBackground = ui.progressFill.BackgroundColor3
	local standardProgressGradient = ui.progressFill:FindFirstChild("ProgressFillGradient")
	if standardProgressGradient then
		assert(
			standardProgressGradient:IsA("UIGradient"),
			"ProgressFillGradient must be an authored UIGradient"
		)
	elseif not modernUi then
		error("Legacy FishingMinigame is missing its authored ProgressFillGradient")
	end
	local standardProgressGradientColor = standardProgressGradient and standardProgressGradient.Color or nil
	local session = {
		cancelled = false,
		finished = false,
		startedAt = os.clock(),
		inputSequence = 0,
		holding = false,
		phase = "WAITING",
		phaseNumber = 0,
		stageCount = RARITY_STAGE_COUNTS[rarity] or 0,
		progress = math.clamp(tonumber(minigameConfig.startProgress) or 0.34, 0.08, 0.86),
		phaseProgress = 0,
		tapCount = 0,
		tapGoal = 0,
		lastTapAt = 0,
		stageCompleting = false,
		rageSequenceStarted = false,
		rareReversalTriggered = false,
		forcedReverseUntil = 0,
		forcedReverseDirection = 0,
	}
	local connections = {}

	function session.emitInput(kind, holding)
		if isAutoFish or type(options.onInputEvent) ~= "function" then
			return
		end

		session.inputSequence += 1
		options.onInputEvent({
			sequence = session.inputSequence,
			kind = kind,
			holding = holding == true,
			elapsed = math.max(0, os.clock() - session.startedAt),
		})
	end

	function session.setHolding(holding)
		holding = holding == true
		if session.holding == holding then
			return
		end

		session.holding = holding
		FishingSFX.setReelingHolding(holding)
		session.emitInput("Hold", holding)
	end

	local function setTapButtonText(text)
		if tapButtonIsTextButton then
			tapButton.Text = text
		end
	end

	local function setCurrentTapEnabled(enabled)
		setTapButtonText(enabled and "Tap" or "Fishing...")
		tapButton.AutoButtonColor = enabled
		tapButton.Active = enabled
		tapButton.Visible = enabled

		if tapButtonParent then
			for sibling in pairs(tapSiblingVisibility) do
				if sibling.Parent == tapButtonParent then
					sibling.Visible = false
				end
			end
			tapButtonParent:SetAttribute("ForceFishingTapVisible", enabled)
			if tapButtonParent:IsA("GuiObject") then
				tapButtonParent.Visible = enabled
			end
		end
	end

	local function setModernGaugeAsset(assetId)
		if modernUi and modernUi.setGaugeAsset then
			modernUi.setGaugeAsset(assetId)
		end
	end

	local function setGaugeAmount(amount)
		amount = math.clamp(tonumber(amount) or 0, 0, 1)
		if modernUi and modernUi.setProgress then
			modernUi.setProgress(amount)
		else
			ui.progressFill.AnchorPoint = Vector2.new(0, 1)
			ui.progressFill.Position = UDim2.new(0, 0, 1, 0)
			ui.progressFill.Size = UDim2.new(1, 0, amount, 0)
		end
	end

	local function useStandardGauge()
		setModernGaugeAsset(BLUE_GAUGE_ASSET)
		setGaugeAmount(session.progress)
		ui.progressFill.BackgroundColor3 = standardProgressBackground

		if standardProgressGradient then
			standardProgressGradient.Color = standardProgressGradientColor
		end
	end

	local function getCurrentStage()
		return RAGE_STAGES[session.phaseNumber]
	end

	local function usePhaseGauge()
		local stage = getCurrentStage()
		if not stage then
			return
		end

		setModernGaugeAsset(stage.asset)
		setGaugeAmount(session.phaseProgress)
		ui.progressFill.BackgroundColor3 = stage.bottomColor
		setGradient(standardProgressGradient, stage.topColor, stage.bottomColor)

	end

	local function disconnectAll()
		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end
		table.clear(connections)
	end

	local function setInstruction(instruction, legacyInstruction)
		ui.minigameInstruction.Text = modernUi and instruction or legacyInstruction
	end

	local function resetFishingOnlyVisuals()
		if modernUi and modernUi.restoreRagePresentation then
			modernUi.restoreRagePresentation()
		end
		if modernUi and modernUi.setFishSilhouette then
			modernUi.setFishSilhouette(false)
		end

		if tapButtonIsTextButton and tapButtonOriginalText ~= nil then
			tapButton.Text = tapButtonOriginalText
		end
		tapButton.AutoButtonColor = tapButtonOriginalAutoButtonColor
		tapButton.Active = tapButtonOriginalActive
		tapButton.Visible = tapButtonOriginalVisible
		if tapButtonParent then
			for sibling, wasVisible in pairs(tapSiblingVisibility) do
				if sibling.Parent == tapButtonParent then
					sibling.Visible = wasVisible
				end
			end
			tapButtonParent:SetAttribute("ForceFishingTapVisible", tapButtonParentForceVisible)
			if tapButtonParentWasVisible ~= nil and tapButtonParent:IsA("GuiObject") then
				tapButtonParent.Visible = tapButtonParentWasVisible
			end
		end
		-- Hide the old floating header. The black top banner owns the waiting/reel messages.
		if ui.minigameText and ui.minigameText:IsA("GuiObject") then
			ui.minigameText.Visible = false
		end

		ui.catchButton.Visible = false
		ui.catchButton.Active = false
		ui.catchBar.Visible = true
		ui.fishMarker.Visible = true
		session.progress = math.clamp(session.progress, 0, 1)
		useStandardGauge()
	end

	local function cleanup()
		if session.cancelled or session.finished then
			return
		end

		session.cancelled = true
		FishingSFX.stopReeling()
		disconnectAll()
		resetFishingOnlyVisuals()
	end

	local function finish(success)
		if session.cancelled or session.finished then
			return
		end

		session.setHolding(false)
		session.finished = true
		FishingSFX.stopReeling()
		if success == true then
			FishingSFX.playCatchReveal(rarity, isAutoFish)
		end
		disconnectAll()
		resetFishingOnlyVisuals()
		options.onFinish(
			success == true,
			isAutoFish,
			math.max(0, os.clock() - session.startedAt)
		)
	end

	local function isSessionAlive()
		return not session.cancelled and not session.finished
	end

	local function animateGauge(fromAmount, toAmount, duration, applyAmount)
		local startedAt = os.clock()
		duration = math.max(0.01, tonumber(duration) or 0.01)

		while isSessionAlive() do
			local alpha = math.clamp((os.clock() - startedAt) / duration, 0, 1)
			local eased = 1 - ((1 - alpha) * (1 - alpha))
			local amount = fromAmount + ((toAmount - fromAmount) * eased)
			applyAmount(amount)

			if alpha &gt;= 1 then
				return true
			end
			runService.RenderStepped:Wait()
		end

		return false
	end

	local completeTapStage

	local function beginTapPhase(phaseNumber)
		local stage = RAGE_STAGES[phaseNumber]
		if not stage or not isSessionAlive() then
			return
		end

		FishingSFX.stopReeling()
		session.phase = "TAP"
		session.phaseNumber = phaseNumber
		session.phaseProgress = 0
		session.tapCount = 0
		session.tapGoal = stage.goal
		session.lastTapAt = 0
		session.stageCompleting = false

		ui.catchBar.Visible = false
		ui.fishMarker.Visible = false
		usePhaseGauge()
		setCurrentTapEnabled(true)

		ui.minigameText.Text = string.format("%s Stage - Tap!", stage.name)
		ui.minigameProgressText.Text = string.format("Taps 0 / %d", stage.goal)
		setInstruction(
			string.format("Tap %d times to fill the gauge.", stage.goal),
			promptBaitText .. castText .. string.format("\nTap %d times to fill the gauge.", stage.goal)
		)
	end

	completeTapStage = function()
		if session.stageCompleting or session.phase ~= "TAP" then
			return
		end

		session.stageCompleting = true
		setCurrentTapEnabled(false)

		if session.phaseNumber &lt; session.stageCount then
			local currentPhase = session.phaseNumber
			session.phase = "STAGE_DRAIN"
			task.spawn(function()
				local completed = animateGauge(1, 0, STAGE_DRAIN_DURATION, function(amount)
					session.phaseProgress = amount
					usePhaseGauge()
				end)
				if completed and isSessionAlive() then
					beginTapPhase(currentPhase + 1)
				end
			end)
		else
			session.phase = "COMPLETE"
			ui.minigameText.Text = "Caught!"
			task.delay(0.18, function()
				if isSessionAlive() then
					finish(true)
				end
			end)
		end
	end

	local function registerTap()
		if session.phase ~= "TAP" or session.cancelled or session.finished then
			return
		end

		local now = os.clock()
		-- Keep a small margin above the server's 65 ms validation floor.
		if now - session.lastTapAt &lt; 0.07 then
			return
		end
		session.lastTapAt = now
		session.emitInput("Tap", session.holding)
		session.tapCount = math.min(session.tapGoal, session.tapCount + 1)
		session.phaseProgress = session.tapGoal &gt; 0
			and (session.tapCount / session.tapGoal)
			or 0
		usePhaseGauge()
		ui.minigameProgressText.Text = string.format(
			"Taps %d / %d",
			session.tapCount,
			session.tapGoal
		)

		if session.tapCount &gt;= session.tapGoal then
			completeTapStage()
		end
	end

	local function startRageSequence()
		if not isRageRarity(rarity)
			or session.rageSequenceStarted
			or not isSessionAlive()
		then
			return
		end

		session.rageSequenceStarted = true
		session.phase = "RAGE_WARNING"
		session.setHolding(false)
		session.progress = 1
		useStandardGauge()
		setCurrentTapEnabled(false)
		ui.catchBar.Visible = false
		ui.fishMarker.Visible = false

		if modernUi and modernUi.beginRagePresentation then
			modernUi.beginRagePresentation()
		end

		task.spawn(function()
			local warningCompleted = true
			if modernUi and modernUi.showRageWarning then
				warningCompleted = modernUi.showRageWarning(
					RAGE_WARNING_DURATION,
					isSessionAlive
				)
			else
				local warningEnd = os.clock() + RAGE_WARNING_DURATION
				while isSessionAlive() and os.clock() &lt; warningEnd do
					task.wait(0.05)
				end
				warningCompleted = isSessionAlive()
			end

			if not warningCompleted or not isSessionAlive() then
				return
			end

			session.phase = "INITIAL_DRAIN"
			local drained = animateGauge(1, 0, INITIAL_DRAIN_DURATION, function(amount)
				session.progress = amount
				useStandardGauge()
			end)
			if not drained or not isSessionAlive() then
				return
			end

			session.phase = "GAUGE_FOCUS"
			if modernUi and modernUi.focusGauge then
				local focused = modernUi.focusGauge(isSessionAlive)
				if not focused or not isSessionAlive() then
					return
				end
			end

			-- The gauge has finished moving, enlarging, and rotating into place.
			-- Reuse FishingClient's existing black banner for a short TAP prompt.
			if type(showToast) == "function" then
				showToast("Press the Tap button!", 2)
			end

			beginTapPhase(1)
		end)
	end

	ui.catchButton.Visible = false
	ui.catchButton.Active = false
	ui.timingBar.Visible = false
	ui.zone.Visible = false
	ui.marker.Visible = false
	ui.fishingGameContent.Visible = true
	ui.catchBar.Visible = true
	ui.fishMarker.Visible = true
	options.setFishIcon(fish)
	if modernUi and modernUi.setFishSilhouette then
		modernUi.setFishSilhouette(isRageRarity(rarity))
	elseif modernUi and modernUi.fishImage then
		modernUi.fishImage.ImageColor3 = isRageRarity(rarity)
			and Color3.fromRGB(0, 0, 0)
			or Color3.fromRGB(255, 255, 255)
	end
	setCurrentTapEnabled(false)
	useStandardGauge()

	ui.minigameText.Text = isAutoFish and "AutoFish is waiting for a bite..." or "Waiting for a bite..."
	ui.minigameFishInfo.Text = "Something is biting..."
	ui.minigameProgressText.Text = "Progress --"
	setInstruction(
		isAutoFish and "AutoFish is handling this catch." or "The fish is biting...",
		promptBaitText .. castText
	)
	options.forcePureWhiteText(ui.minigameText)

	table.insert(connections, tapButton.Activated:Connect(registerTap))

	-- Explicit button press/release handling for phones and tablets.
	-- UserInputService below remains as the fallback for mouse, touch, and Space.
	table.insert(connections, tapButton.InputBegan:Connect(function(input)
		if session.phase == "REEL" and isReelInput(input) then
			session.setHolding(true)
		end
	end))
	table.insert(connections, tapButton.InputEnded:Connect(function(input)
		if session.phase == "REEL" and isReelInput(input) then
			session.setHolding(false)
		end
	end))
	table.insert(connections, tapButton.MouseLeave:Connect(function()
		if session.phase == "REEL" then
			session.setHolding(false)
		end
	end))

	table.insert(connections, inputService.InputBegan:Connect(function(input, gameProcessedEvent)
		if gameProcessedEvent and input.UserInputType == Enum.UserInputType.Keyboard then
			return
		end

		if session.phase == "REEL" and isReelInput(input) then
			session.setHolding(true)
		elseif session.phase == "TAP" and isKeyboardTapInput(input) then
			registerTap()
		end
	end))
	table.insert(connections, inputService.InputEnded:Connect(function(input)
		if session.phase == "REEL" and isReelInput(input) then
			session.setHolding(false)
		end
	end))

	task.delay(tonumber(prompt.biteDelay) or 0, function()
		if session.cancelled or session.finished then
			return
		end

		local barSize = math.clamp(tonumber(minigameConfig.barSize) or 0.24, 0.16, 0.58)
		local maxBarTop = 1 - barSize
		local barTop = math.clamp(0.70, 0, maxBarTop)
		local barVelocity = 0
		local fishY = random:NextNumber(0.20, 0.80)
		local fishTarget = random:NextNumber(0.15, 0.85)
		local fishVelocity = 0
		local gameStartedAt = os.clock()
		local nextDecisionAt = gameStartedAt
			+ random:NextNumber(difficulty.turnIntervalMin or 1, difficulty.turnIntervalMax or 2)
		local pauseUntil = 0
		local burstUntil = 0
		local minSuccessDuration = tonumber(minigameConfig.minSuccessDuration) or 1.75
		local gainMultiplier = rarity == "Uncommon" and 0.88 or 1

		local function chooseFishTarget(fromY, preferFarTarget)
			if preferFarTarget then
				local jumpMin = tonumber(difficulty.jumpMin) or 0.12
				local jumpMax = math.max(jumpMin, tonumber(difficulty.jumpMax) or jumpMin)
				local direction = random:NextInteger(0, 1) == 0 and -1 or 1
				local distance = random:NextNumber(jumpMin, jumpMax)
				local target = fromY + (direction * distance)

				if target &lt; 0.08 or target &gt; 0.92 then
					target = fromY - (direction * distance)
				end

				return math.clamp(target, 0.08, 0.92)
			end

			return random:NextNumber(0.08, 0.92)
		end

		local function getRareMovementDirection()
			local currentDirection = fishVelocity &gt; 0.01 and 1 or (fishVelocity &lt; -0.01 and -1 or 0)
			if currentDirection == 0 then
				currentDirection = fishTarget &gt;= fishY and 1 or -1
			end

			return currentDirection
		end

		local function hasRoomForRareReversal()
			local reverseDirection = -getRareMovementDirection()
			local availableDistance = reverseDirection &lt; 0 and (fishY - 0.04) or (0.96 - fishY)
			return availableDistance &gt;= 0.12
		end

		local function triggerRareReversal(now)
			if rarity ~= "Rare" or session.rareReversalTriggered then
				return
			end

			session.rareReversalTriggered = true
			session.forcedReverseDirection = -getRareMovementDirection()
			session.forcedReverseUntil = now + 0.32
			local reverseSpeed = math.max((tonumber(difficulty.moveSpeed) or 0.25) * 2.4, 0.72)
			fishVelocity = session.forcedReverseDirection * reverseSpeed
			fishTarget = math.clamp(fishY + (session.forcedReverseDirection * 0.42), 0.06, 0.94)
			pauseUntil = 0
			burstUntil = 0
			nextDecisionAt = session.forcedReverseUntil + 0.10
		end

		FishingSFX.playBiteAlert()
		FishingSFX.startReeling(isAutoFish)
		session.phase = "REEL"
		session.setHolding(false)

		-- The fish has actually bitten. Replace the persistent waiting banner,
		-- then automatically hide the banner after two seconds.
		if not isAutoFish and type(showToast) == "function" then
			showToast("Keep the fish inside the green bar!", 2)
		end

		-- Show the circular TAP button during the normal reel minigame.
		-- Holding it raises the green catch bar; releasing it lets the bar fall.
		-- AutoFish keeps the button hidden because no manual input is needed.
		setCurrentTapEnabled(not isAutoFish)

		ui.catchBar.Size = modernUi and UDim2.fromScale(0.82, barSize) or UDim2.new(1, -32, barSize, 0)
		ui.catchBar.Position = UDim2.new(0.5, 0, barTop, 0)
		ui.fishMarker.Position = UDim2.new(0.5, 0, fishY, 0)
		useStandardGauge()
		ui.minigameText.Text = isAutoFish and "AutoFish is reeling..." or "Keep the fish inside the green bar!"
		ui.minigameFishInfo.Text = string.format(
			"%s [%s]\nValue: %d | XP: %d",
			fish.name or "Fish",
			rarity,
			fish.value or 0,
			fish.xp or 0
		)
		ui.minigameProgressText.Text = string.format("Progress %d%%", math.floor(session.progress * 100 + 0.5))
		local reelInstruction = isAutoFish
			and "AutoFish is handling this catch."
			or "Hold mouse, tap, or Space to lift the green bar. Release to let it fall."
		setInstruction(reelInstruction, promptBaitText .. castText .. "\n" .. reelInstruction)
		options.forcePureWhiteText(ui.minigameText)

		table.insert(connections, runService.RenderStepped:Connect(function(deltaTime)
			if session.cancelled or session.finished then
				return
			end

			if session.phase ~= "REEL" then
				return
			end

			local now = os.clock()
			local elapsed = now - gameStartedAt

			if now &gt;= nextDecisionAt then
				local pauseChance = difficulty.pauseChance or 0
				local jumpChance = difficulty.jumpChance or 0
				local burstChance = difficulty.burstChance or 0

				fishTarget = chooseFishTarget(fishY, jumpChance &gt; 0 and random:NextNumber() &lt; jumpChance)

				if pauseChance &gt; 0 and random:NextNumber() &lt; pauseChance then
					pauseUntil = now + random:NextNumber(difficulty.pauseMin or 0.12, difficulty.pauseMax or 0.45)
				end

				if burstChance &gt; 0 and random:NextNumber() &lt; burstChance then
					burstUntil = now + random:NextNumber(difficulty.burstMin or 0.18, difficulty.burstMax or 0.38)
				end

				nextDecisionAt = now
					+ random:NextNumber(difficulty.turnIntervalMin or 1, difficulty.turnIntervalMax or 2)
			end

			local targetVelocity = 0
			if now &lt; session.forcedReverseUntil then
				targetVelocity = session.forcedReverseDirection
					* math.max((tonumber(difficulty.moveSpeed) or 0.25) * 2.4, 0.72)
			elseif now &gt;= pauseUntil then
				local distance = fishTarget - fishY
				local targetSlack = tonumber(difficulty.targetSlack) or 0.025
				if math.abs(distance) &lt; targetSlack then
					fishTarget = chooseFishTarget(fishY, false)
					distance = fishTarget - fishY
				end

				local direction = distance &gt;= 0 and 1 or -1
				local jitter = random:NextNumber(-(difficulty.jitter or 0), difficulty.jitter or 0)
				local speed = tonumber(difficulty.moveSpeed) or 0.25
				if now &lt; burstUntil then
					speed *= tonumber(difficulty.burstMultiplier) or 1.35
				end

				targetVelocity = (direction * speed) + jitter
			end

			local fishAcceleration = tonumber(difficulty.acceleration) or 6
			local velocityBlend = math.min(1, fishAcceleration * deltaTime)
			fishVelocity += (targetVelocity - fishVelocity) * velocityBlend
			fishY += fishVelocity * deltaTime

			if fishY &lt;= 0.04 then
				fishY = 0.04
				fishVelocity = math.abs(fishVelocity) * 0.35
				fishTarget = math.max(fishTarget, 0.16)
			elseif fishY &gt;= 0.96 then
				fishY = 0.96
				fishVelocity = -math.abs(fishVelocity) * 0.35
				fishTarget = math.min(fishTarget, 0.84)
			end

			if isAutoFish then
				local targetTop = math.clamp(fishY - (barSize / 2), 0, maxBarTop)
				barTop += (targetTop - barTop) * math.min(1, deltaTime * 5)
				session.progress = math.clamp(
					session.progress + (minigameConfig.progressGainPerSecond or 0.34) * deltaTime,
					0,
					1
				)
			else
				local barAcceleration = session.holding
					and -(minigameConfig.lift or 2.75)
					or (minigameConfig.gravity or 1.8)
				barVelocity += barAcceleration * deltaTime
				barVelocity = math.clamp(
					barVelocity,
					-(minigameConfig.maxBarVelocity or 1.65),
					minigameConfig.maxBarVelocity or 1.65
				)
				barVelocity *= math.pow(minigameConfig.damping or 0.90, deltaTime * 60)
				barTop += barVelocity * deltaTime

				if barTop &lt;= 0 then
					barTop = 0
					barVelocity = math.abs(barVelocity) * (minigameConfig.bounceDamping or 0.36)
				elseif barTop &gt;= maxBarTop then
					barTop = maxBarTop
					barVelocity = -math.abs(barVelocity) * (minigameConfig.bounceDamping or 0.36)
				end

				local fishInsideBar = fishY &gt;= barTop and fishY &lt;= barTop + barSize
				if fishInsideBar then
					session.progress += (minigameConfig.progressGainPerSecond or 0.34)
						* gainMultiplier
						* deltaTime
				else
					session.progress -= (minigameConfig.progressDrainPerSecond or 0.16) * deltaTime
				end
				session.progress = math.clamp(session.progress, 0, 1)
				-- Progress may reach 0, but the catch never fails and there is no time limit.
			end

			if rarity == "Rare" and not session.rareReversalTriggered and session.progress &gt;= 0.85 then
				if hasRoomForRareReversal() then
					triggerRareReversal(now)
				else
					-- Hold just below the threshold until the opposite dash has room to be visible.
					session.progress = math.min(session.progress, 0.849)
				end
			end

			if rarity == "Rare" and now &lt; session.forcedReverseUntil and session.progress &gt;= 1 then
				session.progress = 0.995
			end

			ui.catchBar.Position = UDim2.new(0.5, 0, barTop, 0)
			ui.fishMarker.Position = UDim2.new(0.5, 0, fishY, 0)
			useStandardGauge()
			ui.minigameProgressText.Text = string.format(
				"Progress %d%%",
				math.floor(session.progress * 100 + 0.5)
			)

			if isRageRarity(rarity) and session.progress &gt;= 1 then
				startRageSequence()
			elseif isAutoFish
				and not isRageRarity(rarity)
				and elapsed &gt;= (prompt.visualTime or 3)
			then
				ui.minigameText.Text = "AutoFish caught it!"
				finish(true)
			elseif not isAutoFish and session.progress &gt;= 1 and elapsed &gt;= minSuccessDuration then
				ui.minigameText.Text = "Caught!"
				finish(true)
			end
		end))
	end)

	return cleanup
end

return RarityCatchController
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="729">
            <Properties>
              <string name="Name">RemoteActions</string>
              <string name="Source">local RemoteActions = {}

function RemoteActions.create(deps)
	local Remotes = deps.Remotes
	local BaitAction = deps.BaitAction
	local QuestAction = deps.QuestAction
	local ShopAction = deps.ShopAction

	local actions = {}

	function actions.fireBaitAction(action, baitId)
		if not BaitAction then
			BaitAction = Remotes:FindFirstChild("BaitAction")
		end

		if BaitAction then
			BaitAction:FireServer(action, baitId)
		else
			warn("BaitAction remote was not available; bait shop actions are disabled until remotes resync.")
		end
	end

	function actions.fireQuestAction(action, periodName, questId)
		if not QuestAction then
			QuestAction = Remotes:FindFirstChild("QuestAction")
		end

		if QuestAction then
			QuestAction:FireServer(action, periodName, questId)
		else
			warn("QuestAction remote was not available; quest claiming is disabled until remotes resync.")
		end
	end

	function actions.fireShopAction(action, category, itemKey, payload)
		if not ShopAction then
			ShopAction = Remotes:FindFirstChild("ShopAction")
		end

		if ShopAction then
			ShopAction:FireServer(action, category, itemKey, payload)
		else
			warn("ShopAction remote was not available; shop actions are disabled until remotes resync.")
		end
	end

	return actions
end

return RemoteActions
