function fishyFishRenderAquariumDesignerControls()
	local monetization = fishyFishGetMonetizationState()
	local ownsDesigner = fishyFishOwnsGamePass("AquariumDesigner")
	local currentDesign = monetization.AquariumPreviewDesign or monetization.AquariumDesign or MonetizationConfig.AquariumDesigner.defaultDesign
	local canEditAquarium = state.AquariumView and state.AquariumView.CanEdit == true

	local summary = makeCard(mainPanelUI.content, 96)
	fishyFishMakeShopIcon(summary, ownsDesigner and "OPEN" or "LOCK", ownsDesigner and Color3.fromRGB(58, 174, 205) or Color3.fromRGB(96, 106, 122))
	local heading = guiPrimitives.makeText(summary, "Aquarium Designer", 16, Color3.fromRGB(255, 255, 255), true)
	heading.Position = UDim2.new(0, 76, 0, 8)
	heading.Size = UDim2.new(1, -194, 0, 22)
	local status = "Select My Aquarium in the Hub to edit."
	if canEditAquarium then
		status = ownsDesigner and "Owned | Preview, apply, and save premium designs." or "Preview is free. Apply premium designs after buying the pass."
	end
	local detail = guiPrimitives.makeText(summary, status, 12, Color3.fromRGB(190, 204, 220), false)
	detail.Position = UDim2.new(0, 76, 0, 34)
	detail.Size = UDim2.new(1, -194, 0, 34)
	detail.TextWrapped = true
	local cancel = guiPrimitives.makeButton(summary, monetization.AquariumPreviewActive and "Cancel" or "Preview", canEditAquarium and (monetization.AquariumPreviewActive and Color3.fromRGB(230, 126, 48) or Color3.fromRGB(86, 98, 115)) or Color3.fromRGB(86, 98, 115))
	cancel.Position = UDim2.new(1, -104, 0, 31)
	cancel.Size = UDim2.new(0, 88, 0, 34)
	cancel.AutoButtonColor = canEditAquarium
	cancel.MouseButton1Click:Connect(function()
		if canEditAquarium then
			remoteActions.fireShopAction("CancelAquariumPreview", "Aquarium")
		end
	end)

	local function renderDesignOption(kind, id, item, labelPrefix)
		local premium = item.premium == true
		local card = makeCard(mainPanelUI.content, 124)
		fishyFishMakeShopIcon(card, premium and "LOCK" or "FREE", premium and Color3.fromRGB(255, 181, 36) or Color3.fromRGB(58, 174, 205))
		local name = guiPrimitives.makeText(card, (labelPrefix or "") .. item.name, 15, Color3.fromRGB(255, 255, 255), true)
		name.Position = UDim2.new(0, 76, 0, 8)
		name.Size = UDim2.new(1, -96, 0, 22)
		local desc = guiPrimitives.makeText(card, premium and "Premium aquarium option" or "Standard aquarium option", 12, Color3.fromRGB(190, 204, 220), false)
		desc.Position = UDim2.new(0, 76, 0, 34)
		desc.Size = UDim2.new(1, -96, 0, 18)
		local selected = currentDesign[kind] == id
		local statusText = guiPrimitives.makeText(card, selected and "Selected" or (premium and "Requires Designer Pass" or "Available"), 12, selected and Color3.fromRGB(112, 255, 156) or Color3.fromRGB(143, 160, 180), false)
		statusText.Position = UDim2.new(0, 76, 0, 58)
		statusText.Size = UDim2.new(1, -96, 0, 18)

		local preview = guiPrimitives.makeButton(card, canEditAquarium and "Preview" or "View Only", canEditAquarium and Color3.fromRGB(53, 130, 246) or Color3.fromRGB(86, 98, 115))
		preview.Position = UDim2.new(1, -196, 0, 82)
		preview.Size = UDim2.new(0, 84, 0, 32)
		preview.TextSize = 12
		preview.AutoButtonColor = canEditAquarium
		preview.MouseButton1Click:Connect(function()
			if canEditAquarium then
				remoteActions.fireShopAction("PreviewAquariumDesign", "Aquarium", kind, fishyFishCopyAquariumDesignWith({ [kind] = id }))
			end
		end)

		local apply = guiPrimitives.makeButton(card, "Apply", canEditAquarium and Color3.fromRGB(28, 160, 92) or Color3.fromRGB(86, 98, 115))
		apply.Position = UDim2.new(1, -104, 0, 82)
		apply.Size = UDim2.new(0, 88, 0, 32)
		apply.TextSize = 12
		apply.AutoButtonColor = canEditAquarium
		apply.MouseButton1Click:Connect(function()
			if canEditAquarium then
				remoteActions.fireShopAction("ApplyAquariumDesign", "Aquarium", kind, fishyFishCopyAquariumDesignWith({ [kind] = id }))
			end
		end)
	end

	local themeHeader = guiPrimitives.makeText(mainPanelUI.content, "Themes", 16, Color3.fromRGB(255, 255, 255), true)
	themeHeader.Size = UDim2.new(1, -8, 0, 28)
	for _, themeId in ipairs(MonetizationConfig.AquariumDesigner.themeOrder) do
		renderDesignOption("theme", themeId, MonetizationConfig.AquariumDesigner.themes[themeId])
	end

	local signCard = makeCard(mainPanelUI.content, 104)
	fishyFishMakeShopIcon(signCard, "TEXT", Color3.fromRGB(255, 181, 36))
	local signTitle = guiPrimitives.makeText(signCard, "Display Sign Text", 15, Color3.fromRGB(255, 255, 255), true)
	signTitle.Position = UDim2.new(0, 76, 0, 8)
	signTitle.Size = UDim2.new(1, -194, 0, 22)
	local signBox = Instance.new("TextBox")
	signBox.Position = UDim2.new(0, 76, 0, 38)
	signBox.Size = UDim2.new(1, -194, 0, 32)
	signBox.BackgroundColor3 = Color3.fromRGB(38, 45, 57)
	signBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	signBox.PlaceholderText = "Custom sign text"
	signBox.Text = currentDesign.signText or ""
	signBox.Font = Enum.Font.Gotham
	signBox.TextSize = 13
	signBox.ClearTextOnFocus = false
	signBox.Parent = signCard
	guiPrimitives.addCorner(signBox, 6)
	guiPrimitives.addStroke(signBox, Color3.fromRGB(60, 72, 90), 1)
	local applySign = guiPrimitives.makeButton(signCard, "Apply", canEditAquarium and Color3.fromRGB(28, 160, 92) or Color3.fromRGB(86, 98, 115))
	applySign.Position = UDim2.new(1, -104, 0, 72)
	applySign.Size = UDim2.new(0, 88, 0, 26)
	applySign.TextSize = 12
	applySign.AutoButtonColor = canEditAquarium
	applySign.MouseButton1Click:Connect(function()
		if canEditAquarium then
			remoteActions.fireShopAction("ApplyAquariumDesign", "Aquarium", "signText", fishyFishCopyAquariumDesignWith({ signText = signBox.Text }))
		end
	end)
end

do
	local moduleScript = script:FindFirstChild("ShopModernUI")
	if moduleScript then
		local ok, module = pcall(require, moduleScript)
		if ok and type(module) == "table" and type(module.render) == "function" then
			shopModernUI = module
		else
			warn("ShopModernUI could not be loaded; using the legacy shop renderer.", module)
		end
	end
end

local function renderShopTab()
	if shopModernUI then
		if not shopModernContext then
			shopModernContext = {
				parent = mainPanelUI.content,
				panel = mainPanelUI.panel,
				panelTitle = mainPanelUI.panelTitle,
				panelClose = mainPanelUI.panelClose,
				MonetizationConfig = MonetizationConfig,
				fireShopAction = remoteActions.fireShopAction,
				makeText = guiPrimitives.makeText,
				addCorner = guiPrimitives.addCorner,
				addStroke = guiPrimitives.addStroke,
				onSelectedTabChanged = function(tabName)
					if VALID_SHOP_TABS[tabName] then
						activeShopTab = tabName
					end
				end,
				close = function()
					panelCollapsed = true
					updatePanelCollapsed()
				end,
			}
		end

		shopModernContext.state = state
		if type(shopModernUI.setSelectedTab) == "function" then
			shopModernUI.setSelectedTab(activeShopTab)
		end
		shopModernUI.render(shopModernContext)
		return
	end

	fishyFishRenderShopSubTabs()

	if activeShopTab == "Passes" then
		fishyFishRenderShopGamePasses()
	elseif activeShopTab == "Items" then
		fishyFishRenderShopBait()
	elseif activeShopTab == "Coins" then
		fishyFishRenderShopCoins()
	elseif activeShopTab == "Upgrades" then
		fishyFishRenderShopStorage()
	end
end

local function renderLeaderboardTab()
	local function makeLeaderboardCard(height, strokeColor, strokeThickness, strokeTransparency)
		local wrapper = Instance.new("Frame")
		wrapper.Name = "LeaderboardCardRow"
		wrapper.Size = UDim2.new(1, 0, 0, height)
		wrapper.BackgroundTransparency = 1
		wrapper.Parent = mainPanelUI.content

		local card = Instance.new("Frame")
		card.Name = "LeaderboardCard"
		card.Position = UDim2.new(0, 6, 0, 1)
		card.Size = UDim2.new(1, -12, 1, -2)
		card.BackgroundColor3 = Color3.fromRGB(27, 33, 43)
		card.Parent = wrapper
		guiPrimitives.addCorner(card, 8)
		local stroke = guiPrimitives.addStroke(card, strokeColor or Color3.fromRGB(60, 72, 90), strokeThickness or 1)
		stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		if strokeTransparency ~= nil then
			stroke.Transparency = strokeTransparency
		end
		return card, stroke
	end

	local onlinePlayers = Services.Players:GetPlayers()
	table.sort(onlinePlayers, function(left, right)
		local leftCaught = tonumber(Modules.LeaderboardHelpers.getPlayerLeaderstat(left, "Fish Caught")) or 0
		local rightCaught = tonumber(Modules.LeaderboardHelpers.getPlayerLeaderstat(right, "Fish Caught")) or 0
		if leftCaught ~= rightCaught then
			return leftCaught &gt; rightCaught
		end

		return string.lower(left.DisplayName or left.Name) &lt; string.lower(right.DisplayName or right.Name)
	end)

	local summary = makeLeaderboardCard(80)
	local heading = guiPrimitives.makeText(summary, "Leaderboard", 17, Color3.fromRGB(255, 255, 255), true)
	heading.Position = UDim2.new(0, 18, 0, 8)
	heading.Size = UDim2.new(1, -30, 0, 24)

	local detail = guiPrimitives.makeText(summary, string.format("Sorted by fish-caught leaderboard | %d player%s online", #onlinePlayers, #onlinePlayers == 1 and "" or "s"), 13, Color3.fromRGB(190, 204, 220), false)
	detail.Position = UDim2.new(0, 18, 0, 38)
	detail.Size = UDim2.new(1, -36, 0, 20)

	local header = makeLeaderboardCard(38)
	local rankHeader = guiPrimitives.makeText(header, "#", 12, Color3.fromRGB(143, 160, 180), true)
	rankHeader.Position = UDim2.new(0, 16, 0, 8)
	rankHeader.Size = UDim2.new(0, 28, 0, 20)
	rankHeader.TextXAlignment = Enum.TextXAlignment.Center
	local nameHeader = guiPrimitives.makeText(header, "Player", 12, Color3.fromRGB(143, 160, 180), true)
	nameHeader.Position = UDim2.new(0, 52, 0, 8)
	nameHeader.Size = UDim2.new(0.48, -52, 0, 20)
	local coinsHeader = guiPrimitives.makeText(header, "Coins", 12, Color3.fromRGB(143, 160, 180), true)
	coinsHeader.Position = UDim2.new(0.52, 0, 0, 8)
	coinsHeader.Size = UDim2.new(0.17, 0, 0, 20)
	coinsHeader.TextXAlignment = Enum.TextXAlignment.Center
	local levelHeader = guiPrimitives.makeText(header, "Level", 12, Color3.fromRGB(143, 160, 180), true)
	levelHeader.Position = UDim2.new(0.69, 0, 0, 8)
	levelHeader.Size = UDim2.new(0.14, 0, 0, 20)
	levelHeader.TextXAlignment = Enum.TextXAlignment.Center
	local caughtHeader = guiPrimitives.makeText(header, "Fish", 12, Color3.fromRGB(143, 160, 180), true)
	caughtHeader.Position = UDim2.new(0.83, 0, 0, 8)
	caughtHeader.Size = UDim2.new(0.17, -18, 0, 20)
	caughtHeader.TextXAlignment = Enum.TextXAlignment.Center

	for rank, listedPlayer in ipairs(onlinePlayers) do
		local isSelf = listedPlayer == player
		local card = makeLeaderboardCard(62, isSelf and Color3.fromRGB(112, 255, 156) or Color3.fromRGB(60, 72, 90), isSelf and 2 or 1, isSelf and 0 or 0.45)

		local displayName = listedPlayer.DisplayName or listedPlayer.Name
		if listedPlayer:GetAttribute("FishyFishVip") == true then
			displayName = "[VIP] " .. displayName
		end
		if isSelf then
			displayName ..= " (You)"
		end

		local rankLabel = guiPrimitives.makeText(card, tostring(rank), 13, Color3.fromRGB(143, 160, 180), true)
		rankLabel.Position = UDim2.new(0, 16, 0, 20)
		rankLabel.Size = UDim2.new(0, 28, 0, 20)
		rankLabel.TextXAlignment = Enum.TextXAlignment.Center

		local name = guiPrimitives.makeText(card, displayName, 13, isSelf and Color3.fromRGB(112, 255, 156) or Color3.fromRGB(255, 255, 255), true)
		name.Position = UDim2.new(0, 52, 0, 8)
		name.Size = UDim2.new(0.48, -52, 0, 22)
		name.TextTruncate = Enum.TextTruncate.None

		local username = guiPrimitives.makeText(card, "@" .. listedPlayer.Name, 11, Color3.fromRGB(143, 160, 180), false)
		username.Position = UDim2.new(0, 52, 0, 32)
		username.Size = UDim2.new(0.48, -52, 0, 16)
		username.TextTruncate = Enum.TextTruncate.None

		local coins = guiPrimitives.makeText(card, Modules.LeaderboardHelpers.formatCompactNumber(Modules.LeaderboardHelpers.getPlayerLeaderstat(listedPlayer, "Coins")), 13, Color3.fromRGB(235, 242, 255), true)
		coins.Position = UDim2.new(0.52, 0, 0, 20)
		coins.Size = UDim2.new(0.17, 0, 0, 20)
		coins.TextXAlignment = Enum.TextXAlignment.Center

		local level = guiPrimitives.makeText(card, tostring(Modules.LeaderboardHelpers.getPlayerLeaderstat(listedPlayer, "Level")), 13, Color3.fromRGB(235, 242, 255), true)
		level.Position = UDim2.new(0.69, 0, 0, 20)
		level.Size = UDim2.new(0.14, 0, 0, 20)
		level.TextXAlignment = Enum.TextXAlignment.Center

		local caught = guiPrimitives.makeText(card, Modules.LeaderboardHelpers.formatCompactNumber(Modules.LeaderboardHelpers.getPlayerLeaderstat(listedPlayer, "Fish Caught")), 13, Color3.fromRGB(235, 242, 255), true)
		caught.Position = UDim2.new(0.83, 0, 0, 20)
		caught.Size = UDim2.new(0.17, -18, 0, 20)
		caught.TextXAlignment = Enum.TextXAlignment.Center
	end
end

renderContent = function()
	if activeTab ~= "Bag" or panelCollapsed then
		local bagModuleScript = script:FindFirstChild("BagModernUI")
		if bagModuleScript then
			local ok, bagModule = pcall(require, bagModuleScript)
			if ok and bagModule and bagModule.hide then
				bagModule.hide()
			end
		end
	end

	if activeTab == "Rods" then
		activeTab = "Bag"
	elseif activeTab == "Fish" then
		activeTab = "Fishdex"
	elseif activeTab == "Aquariums" then
		activeTab = "Aquarium"
	elseif activeTab == "Biomes" then
		activeTab = "Teleport"
	end

	if activeTab ~= "Shop" and shopModernUI and shopModernUI.hide then
		shopModernUI.hide()
	end

	if fishdexModernUI.root and activeTab ~= "Fishdex" then
		fishdexModernUI.root.Visible = false
	end
	if activeTab ~= "Fishdex" and activeTab ~= "Bag" and activeTab ~= "Quests" then
		mainPanelUI.panel.Visible = not panelCollapsed
	else
		mainPanelUI.panel.Visible = false
	end

	refreshHud()
	refreshCenterControls()
	refreshTabs()
	mainPanelUI.panelTitle.Text = activeTab

	if activeTab == "Shop" and shopModernUI and state then
		renderShopTab()
		return
	end

	guiPrimitives.clearChildren(mainPanelUI.content)

	if not state then
		cloneLegacyMainPanelTemplate("LoadingLabelTemplate", mainPanelUI.content)
		return
	end

	if activeTab == "Bag" and not panelCollapsed then
		renderBagTab()
	elseif activeTab == "Fishdex" then
		renderFishdexTab()
	elseif activeTab == "Aquarium" then
		renderAquariumTab()
	elseif activeTab == "Teleport" then
		renderTeleportTab()
	elseif activeTab == "Quests" then
		renderQuestsTab()
	elseif activeTab == "Shop" then
		renderShopTab()
	elseif activeTab == "Leaderboard" then
		renderLeaderboardTab()
	end
end

-- Hard guard for duplicate/older Bag and Fishdex panels.
-- This runs inside the real FishingClient, so it knows exactly when Bag or
-- Fishdex is the active tab and does not rely on guessing from UI names alone.
local legacyBagFishdexGuardElapsed = 0

suppressLegacyBagFishdexPanels = function()
	-- AuthoredUiV2 has one declared owner for every surface. The old global
	-- descendant scan can mistake those authored hosts for duplicates and must
	-- never mutate that tree.
	if AuthoredUi.enabled then
		return
	end

	if panelCollapsed
		or (activeTab ~= "Bag" and activeTab ~= "Fishdex")
	then
		return
	end

	-- The integrated old Bag/Fishdex panel must always stay hidden.
	mainPanelUI.panel.Visible = false

	for _, descendant in ipairs(playerGui:GetDescendants()) do
		if not descendant:IsA("GuiObject") then
			continue
		end

		local lowerName = string.lower(descendant.Name or "")
		local legacyCandidate = descendant.Name == "MainPanel"
			or lowerName == "bagpanel"
			or lowerName == "fishdexpanel"
			or lowerName == "legacybag"
			or lowerName == "legacyfishdex"
			or lowerName == "oldbag"
			or lowerName == "oldfishdex"

		if not legacyCandidate then
			continue
		end

		-- Never touch the modern roots.
		if descendant.Name == "ModernBagRoot"
			or descendant.Name == "ModernBag"
			or descendant.Name == "ModernFishdex"
		then
			continue
		end

		-- Empty marker panels under FishingGui/Panels do not render anything,
		-- but hiding them is harmless.
		descendant.Visible = false
	end
end

Services.RunService.RenderStepped:Connect(function(deltaTime)
	legacyBagFishdexGuardElapsed += deltaTime
	if legacyBagFishdexGuardElapsed &lt; 0.05 then
		return
	end
	legacyBagFishdexGuardElapsed = 0

	suppressLegacyBagFishdexPanels()

	if activeTab == "Fishdex"
		and not panelCollapsed
		and fishdexModernUI.root
	then
		fishdexModernUI.root.Visible = true
	end

	if activeTab == "Bag" and not panelCollapsed then
		local modernBag = screenGui:FindFirstChild("ModernBagRoot")
			or screenGui:FindFirstChild("ModernBag")
		if modernBag and modernBag:IsA("GuiObject") then
			modernBag.Visible = true
		end
	end
end)

function minigameUI.legacyRunMinigame(prompt)
	if minigameRunning then
		return
	end

	local isAutoFish = prompt.autoFish == true
	local clientSessionStartedAt = os.clock()
	local fish = prompt.fish or {}
	local promptBait = prompt.bait or {}
	local promptBaitId = promptBait.id or (state and state.EquippedBait) or GameConfig.BasicBaitId
	local promptBaitData = baitHelpers.getBaitData(promptBaitId)
	local promptBaitName = promptBait.name or promptBaitData.displayName
	local promptBaitText = "Bait: " .. promptBaitName .. " (" .. getBaitCountText(promptBaitId, promptBait.remaining) .. ")"
	local castText = prompt.cast and prompt.cast.displayName and ("\nCast: " .. prompt.cast.displayName) or ""
	local minigameConfig = prompt.minigame or GameConfig.getFishingMinigameConfig(fish.rarity or "Common", state and state.EquippedRod or "WoodenRod")
	local difficulty = minigameConfig.difficulty or GameConfig.FishingMinigame.RarityDifficulty.Common
	local random = Random.new(math.floor((os.clock() * 100000) % 2147483647))

	minigameRunning = true
	CastPower.running = false
	CastPower.activeConfig = nil
	setMinigameVisible(true)
	CastPower.content.Visible = false
	minigameUI.catchButton.Visible = false
	minigameUI.timingBar.Visible = false
	minigameUI.zone.Visible = false
	minigameUI.marker.Visible = false
	minigameUI.fishingGameContent.Visible = true
	setMinigameFishIcon(fish)

	minigameUI.minigameText.Text = isAutoFish and "AutoFish is waiting for a bite..." or "Waiting for a bite..."
	minigameUI.minigameFishInfo.Text = "Something is biting..."
	minigameUI.minigameProgressText.Text = "Progress --"
	minigameUI.minigameInstruction.Text = promptBaitText .. castText
	minigameUI.progressFill.Size = UDim2.new(1, 0, 0, 0)
	guiPrimitives.forcePureWhiteText(minigameUI.minigameText)

	task.wait(tonumber(prompt.biteDelay) or 0)

	if not minigameRunning then
		return
	end

	local barSize = math.clamp(tonumber(minigameConfig.barSize) or 0.24, 0.16, 0.58)
	local maxBarTop = 1 - barSize
	local barTop = math.clamp(0.70, 0, maxBarTop)
	local barVelocity = 0
	local fishY = random:NextNumber(0.20, 0.80)
	local fishTarget = random:NextNumber(0.15, 0.85)
	local fishVelocity = 0
	local progress = math.clamp(tonumber(minigameConfig.startProgress) or 0.34, 0.08, 0.86)
	local minSuccessDuration = tonumber(minigameConfig.minSuccessDuration) or 1.75
	local gameStartedAt = os.clock()
	local nextDecisionAt = gameStartedAt + random:NextNumber(difficulty.turnIntervalMin or 1, difficulty.turnIntervalMax or 2)
	local pauseUntil = 0
	local burstUntil = 0
	local holding = false
	local finished = false

	minigameUI.catchBar.Size = UDim2.new(1, -32, barSize, 0)
	minigameUI.catchBar.Position = UDim2.new(0.5, 0, barTop, 0)
	minigameUI.fishMarker.Position = UDim2.new(0.5, 0, fishY, 0)
	minigameUI.progressFill.Size = UDim2.new(1, 0, progress, 0)
	minigameUI.minigameText.Text = isAutoFish and "AutoFish is reeling..." or "Keep the fish inside the green bar!"
	minigameUI.minigameFishInfo.Text = string.format("%s [%s]\nValue: %d | XP: %d", fish.name or "Fish", fish.rarity or "Common", fish.value or 0, fish.xp or 0)
	minigameUI.minigameProgressText.Text = string.format("Progress %d%%", math.floor(progress * 100 + 0.5))
	minigameUI.minigameInstruction.Text = promptBaitText .. castText .. "\n" .. (isAutoFish and "AutoFish is handling this catch." or "Hold mouse, tap, or Space to lift the green bar. Release to let it fall.")
	guiPrimitives.forcePureWhiteText(minigameUI.minigameText)

	local renderConnection
	local inputBeganConnection
	local inputEndedConnection

	local function disconnectAll()
		if renderConnection then
			renderConnection:Disconnect()
			renderConnection = nil
		end
		if inputBeganConnection then
			inputBeganConnection:Disconnect()
			inputBeganConnection = nil
		end
		if inputEndedConnection then
			inputEndedConnection:Disconnect()
			inputEndedConnection = nil
		end
	end
	activeMinigameCleanup = disconnectAll

	local function finish(success)
		if finished then
			return
		end

		finished = true
		disconnectAll()
		activeMinigameCleanup = nil

		setMinigameVisible(false)
		minigameRunning = false
		fishingBusy = false

		if not isAutoFish then
			Remote.FinishMinigame:FireServer({
				action = "Complete",
				success = success == true,
				sessionId = prompt.sessionId,
				elapsed = math.max(0, os.clock() - clientSessionStartedAt),
			})
		end

		renderContent()
	end

	local function isCatchInput(input)
		return input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
			or input.KeyCode == Enum.KeyCode.Space
	end

	if not isAutoFish then
		inputBeganConnection = Services.UserInputService.InputBegan:Connect(function(input)
			if isCatchInput(input) then
				holding = true
			end
		end)

		inputEndedConnection = Services.UserInputService.InputEnded:Connect(function(input)
			if isCatchInput(input) then
				holding = false
			end
		end)
	end

	local function chooseFishTarget(fromY, preferFarTarget)
		if preferFarTarget then
			local jumpMin = tonumber(difficulty.jumpMin) or 0.12
			local jumpMax = math.max(jumpMin, tonumber(difficulty.jumpMax) or jumpMin)
			local direction = random:NextInteger(0, 1) == 0 and -1 or 1
			local distance = random:NextNumber(jumpMin, jumpMax)
			local target = fromY + (direction * distance)

			if target &lt; 0.08 or target &gt; 0.92 then
				target = fromY - (direction * distance)
			end

			return math.clamp(target, 0.08, 0.92)
		end

		return random:NextNumber(0.08, 0.92)
	end

	renderConnection = Services.RunService.RenderStepped:Connect(function(deltaTime)
		if not minigameRunning or finished then
			return
		end

		local now = os.clock()
		local elapsed = now - gameStartedAt

		if now &gt;= nextDecisionAt then
			local pauseChance = difficulty.pauseChance or 0
			local jumpChance = difficulty.jumpChance or 0
			local burstChance = difficulty.burstChance or 0

			fishTarget = chooseFishTarget(fishY, jumpChance &gt; 0 and random:NextNumber() &lt; jumpChance)

			if pauseChance &gt; 0 and random:NextNumber() &lt; pauseChance then
				pauseUntil = now + random:NextNumber(difficulty.pauseMin or 0.12, difficulty.pauseMax or 0.45)
			end

			if burstChance &gt; 0 and random:NextNumber() &lt; burstChance then
				burstUntil = now + random:NextNumber(difficulty.burstMin or 0.18, difficulty.burstMax or 0.38)
			end

			nextDecisionAt = now + random:NextNumber(difficulty.turnIntervalMin or 1, difficulty.turnIntervalMax or 2)
		end

		local targetVelocity = 0
		if now &gt;= pauseUntil then
			local distance = fishTarget - fishY
			local targetSlack = tonumber(difficulty.targetSlack) or 0.025
			if math.abs(distance) &lt; targetSlack then
				fishTarget = chooseFishTarget(fishY, false)
				distance = fishTarget - fishY
			end

			local direction = distance &gt;= 0 and 1 or -1
			local jitter = random:NextNumber(-(difficulty.jitter or 0), difficulty.jitter or 0)
			local speed = tonumber(difficulty.moveSpeed) or 0.25
			if now &lt; burstUntil then
				speed *= tonumber(difficulty.burstMultiplier) or 1.35
			end

			targetVelocity = (direction * speed) + jitter
		end

		local acceleration = tonumber(difficulty.acceleration) or 6
		local velocityBlend = math.min(1, acceleration * deltaTime)
		fishVelocity += (targetVelocity - fishVelocity) * velocityBlend
		fishY += fishVelocity * deltaTime

		if fishY &lt;= 0.04 then
			fishY = 0.04
			fishVelocity = math.abs(fishVelocity) * 0.35
			fishTarget = math.max(fishTarget, 0.16)
		elseif fishY &gt;= 0.96 then
			fishY = 0.96
			fishVelocity = -math.abs(fishVelocity) * 0.35
			fishTarget = math.min(fishTarget, 0.84)
		end

		if isAutoFish then
			local targetTop = math.clamp(fishY - (barSize / 2), 0, maxBarTop)
			barTop += (targetTop - barTop) * math.min(1, deltaTime * 5)
			progress = math.clamp(progress + (minigameConfig.progressGainPerSecond or 0.34) * deltaTime, 0, 1)
		else
			local acceleration = holding and -(minigameConfig.lift or 2.75) or (minigameConfig.gravity or 1.8)
			barVelocity += acceleration * deltaTime
			barVelocity = math.clamp(barVelocity, -(minigameConfig.maxBarVelocity or 1.65), minigameConfig.maxBarVelocity or 1.65)
			barVelocity *= math.pow(minigameConfig.damping or 0.90, deltaTime * 60)
			barTop += barVelocity * deltaTime

			if barTop &lt;= 0 then
				barTop = 0
				barVelocity = math.abs(barVelocity) * (minigameConfig.bounceDamping or 0.36)
			elseif barTop &gt;= maxBarTop then
				barTop = maxBarTop
				barVelocity = -math.abs(barVelocity) * (minigameConfig.bounceDamping or 0.36)
			end

			local fishInsideBar = fishY &gt;= barTop and fishY &lt;= barTop + barSize
			if fishInsideBar then
				progress += (minigameConfig.progressGainPerSecond or 0.34) * deltaTime
			else
				progress -= (minigameConfig.progressDrainPerSecond or 0.16) * deltaTime
			end
			progress = math.clamp(progress, 0, 1)
		end

		minigameUI.catchBar.Position = UDim2.new(0.5, 0, barTop, 0)
		minigameUI.fishMarker.Position = UDim2.new(0.5, 0, fishY, 0)
		minigameUI.progressFill.Size = UDim2.new(1, 0, progress, 0)
		minigameUI.minigameProgressText.Text = string.format("Progress %d%%", math.floor(progress * 100 + 0.5))

		if isAutoFish and elapsed &gt;= (prompt.visualTime or 3) then
			minigameUI.minigameText.Text = "AutoFish caught it!"
			finish(true)
		elseif not isAutoFish and progress &gt;= 1 and elapsed &gt;= minSuccessDuration then
			minigameUI.minigameText.Text = "Caught!"
			finish(true)
		end
	end)
end

local function runMinigame(prompt)
	if minigameRunning then
		return
	end

	AuthoredUi.closeQuest()
	panelCollapsed = true
	updatePanelCollapsed()

	minigameRunning = true
	CastPower.running = false
	CastPower.activeConfig = nil
	minigameUI.setFishingVisible(true)
	CastPower.content.Visible = false

	local lifecycleFinished = false
	local clientSessionStartedAt = os.clock()
	local function complete(success, isAutoFish, elapsed)
		if lifecycleFinished then
			return
		end

		lifecycleFinished = true
		activeMinigameCleanup = nil
		minigameUI.setFishingVisible(false)
		minigameRunning = false
		fishingBusy = false
		toolSwitchLock.set(false)

		if not isAutoFish then
			Remote.FinishMinigame:FireServer({
				action = "Complete",
				success = success == true,
				sessionId = prompt.sessionId,
				elapsed = tonumber(elapsed) or (os.clock() - clientSessionStartedAt),
			})
		end

		renderContent()
	end

	local ok, cleanupOrError = pcall(function()
		local controller = script:WaitForChild("RarityCatchController", 5)
		assert(controller, "RarityCatchController was not synced")
		return require(controller).start({
			prompt = prompt,
			state = state,
			GameConfig = GameConfig,
			ui = minigameUI,
			modernUi = minigameUI.modern,
			RunService = Services.RunService,
			UserInputService = Services.UserInputService,
			tapButton = centerCastButton,
			getBaitData = baitHelpers.getBaitData,
			getBaitCountText = baitHelpers.getBaitCountText,
			setFishIcon = setMinigameFishIcon,
			forcePureWhiteText = guiPrimitives.forcePureWhiteText,
			showToast = showToast,
			onInputEvent = function(evidence)
				if type(evidence) ~= "table" or prompt.autoFish == true then
					return
				end

				Remote.FinishMinigame:FireServer({
					action = "Input",
					sessionId = prompt.sessionId,
					sequence = evidence.sequence,
					kind = evidence.kind,
					holding = evidence.holding,
					elapsed = evidence.elapsed,
				})
			end,
			onFinish = complete,
		})
	end)

	if not ok then
		warn("[FishingClient] Rarity catch controller failed:", cleanupOrError)
		complete(false, prompt.autoFish == true)
		return
	end

	activeMinigameCleanup = function()
		if lifecycleFinished then
			return
		end

		lifecycleFinished = true
		cleanupOrError()
		activeMinigameCleanup = nil
	end
end

local function syncEquippedRodAttributes()
	if not state or not state.EquippedRod then
		return
	end

	local rodId = state.EquippedRod
	local rod = GameConfig.Rods and GameConfig.Rods[rodId]

	local rodName = rod and rod.displayName or tostring(rodId)
	local rodIcon = ""

	if GameConfig.getRodImage then
		rodIcon = GameConfig.getRodImage(rodId) or ""
	end

	if rodIcon ~= "" and not string.find(tostring(rodIcon), "rbxassetid://") and tonumber(rodIcon) then
		rodIcon = "rbxassetid://" .. tostring(rodIcon)
	end

	player:SetAttribute("EquippedRodId", rodId)
	player:SetAttribute("EquippedRodName", rodName)
	player:SetAttribute("EquippedRodIcon", rodIcon)

	print("[FishingClient] Equipped rod synced:", rodId, rodName, rodIcon)
end

Remote.StateUpdated.OnClientEvent:Connect(function(newState)
	state = newState
	if AuthoredUi.questController then
		AuthoredUi.questController:SetState(newState)
	end
	syncEquippedRodAttributes()

	refreshHud()
	renderContent()
	updateAquariumViewerFallbackButton()
	if biomeWarpUI.biomeWarpOverlay.Visible then
		renderBiomeWarpOptions()
	end
	if fishmongerUI.fishmongerOverlay.Visible then
		renderFishmongerSellOptions()
	end
	if rodShopUI.overlay.Visible then
		renderRodShopOptions()
	end
end)

Remote.FishingPrompt.OnClientEvent:Connect(function(prompt)
	if prompt.autoFish then
		showToast("AutoFish is catching...", 2)
	elseif prompt.cast and prompt.cast.sparkle then
		CastPower.showSparkle()
	end

	-- Manual fishing keeps the persistent "Waiting for a bite..." banner.
	-- RarityCatchController replaces it exactly when the reel phase begins.
	if not prompt.autoFish then
		local presentationTimeLeft = castPresentationUntil - os.clock()
		if presentationTimeLeft &gt; 0 then
			task.wait(presentationTimeLeft)
		end
	end
	runMinigame(prompt)
end)

Remote.Notice.OnClientEvent:Connect(function(message)
	if activeMinigameCleanup then
		activeMinigameCleanup()
		activeMinigameCleanup = nil
	end

	showToast(message)
	toolSwitchLock.set(false)
	fishingBusy = false
	minigameRunning = false
	CastPower.running = false
	CastPower.activeConfig = nil
	castPresentationUntil = 0
	CastPower.content.Visible = false
	setMinigameVisible(false)
	renderContent()
end)

Services.UserInputService.InputBegan:Connect(function(input, processed)
	local isAquariumViewerFallbackInput = input.KeyCode == Enum.KeyCode.E and state and isInAquariumHub()
	if processed and not isAquariumViewerFallbackInput then
		return
	end

	if minigameRunning or CastPower.running then
		return
	end

	if isAquariumViewerFallbackInput then
		openAquariumHub()
	elseif input.KeyCode == Enum.KeyCode.F and state and not fishingBusy and getActiveFishingBiomeId() then
		startManualFishing()
	elseif input.KeyCode == Enum.KeyCode.B then
		setTab("Bag")
	end
end)

task.spawn(function()
	local success, result = pcall(function()
		return Remote.GetState:InvokeServer()
	end)

	if success and result then
		state = result
		if AuthoredUi.questController then
			AuthoredUi.questController:SetState(result)
		end
		syncEquippedRodAttributes()
	end

	refreshHud()
	renderContent()
	updateAquariumViewerFallbackButton()
end)

player.CharacterAdded:Connect(function()
	toolSwitchLock.set(false)
end)

local locationCheckElapsed = 0
Services.RunService.RenderStepped:Connect(function(deltaTime)
	locationCheckElapsed += deltaTime
	if locationCheckElapsed &lt; 0.25 then
		return
	end
	locationCheckElapsed = 0

	local biomeId = getLocalFishingBiomeId()
	if biomeId ~= lastFishingBiomeId then
		lastFishingBiomeId = biomeId
		renderContent()
	end
	updateAquariumViewerFallbackButton()
end)
</string>
          </Properties>
          <Item class="ModuleScript" referent="708">
            <Properties>
              <string name="Name">AquariumViewerModernUI</string>
              <string name="Source">local AquariumViewerModernUI = {}

local rarityColors = {
	Common = Color3.fromRGB(25, 238, 255),
	Uncommon = Color3.fromRGB(41, 255, 71),
	Rare = Color3.fromRGB(255, 104, 208),
	Epic = Color3.fromRGB(174, 87, 255),
	Legendary = Color3.fromRGB(255, 196, 42),
}

local function descendant(root, name, className)
	local node = root:FindFirstChild(name, true)
	assert(node, ("AquariumViewerGui is missing %s"):format(name))
	if className then
		assert(node:IsA(className), ("AquariumViewerGui.%s must be a %s"):format(name, className))
	end
	return node
end

local function setPressedFeedback(button)
	if not button:IsA("GuiButton") then
		return
	end

	local original = button.Size
	button.MouseButton1Down:Connect(function()
		button.Size = UDim2.new(original.X.Scale, original.X.Offset - 4, original.Y.Scale, original.Y.Offset - 4)
	end)
	button.MouseButton1Up:Connect(function()
		button.Size = original
	end)
	button.MouseLeave:Connect(function()
		button.Size = original
	end)
end

local function clearRows(scroller)
	for _, child in ipairs(scroller:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end
end

local function fishImage(gameConfig, fish)
	if type(fish) ~= "table" or not gameConfig.getFishImage then
		return ""
	end
	return gameConfig.getFishImage(fish.imageKey or fish.id) or ""
end

local function formatNumber(value)
	local number = math.max(0, math.floor(tonumber(value) or 0))
	local text = tostring(number)
	while true do
		local formatted, replacements = text:gsub("^(%-?%d+)(%d%d%d)", "%1,%2")
		text = formatted
		if replacements == 0 then
			break
		end
	end
	return text
end

local function aquariumTotalValue(fish)
	local total = 0
	for _, entry in ipairs(fish or {}) do
		total += tonumber(entry.value) or 0
	end
	return total
end

local function bestFish(currentState, fish)
	if type(currentState.BestCatch) == "table" then
		return currentState.BestCatch
	end

	local best = nil
	for _, entry in ipairs(fish or {}) do
		if not best or (tonumber(entry.value) or 0) &gt; (tonumber(best.value) or 0) then
			best = entry
		end
	end
	return best
end

function AquariumViewerModernUI.create(context)
	local playerGui = assert(context.playerGui, "Aquarium viewer requires playerGui")
	local screenGui = playerGui:WaitForChild("AquariumViewerGui")
	-- Rojo names the top-level instance after an .rbxmx filename during a live
	-- sync. Older saved copies therefore expose this frame as `Interface`, while
	-- clean builds preserve its authored `Root` name. Support both hierarchies so
	-- the aquarium viewer cannot break the rest of FishingClient during startup.
	local root = screenGui:FindFirstChild("Root") or screenGui:FindFirstChild("Interface")
	assert(root and root:IsA("Frame"), "AquariumViewerGui is missing its Root frame")
	local uiScale = descendant(root, "DeviceScale", "UIScale")
	local myTankPage = descendant(root, "MyTankPage", "Frame")
	local explorePage = descendant(root, "ExplorePage", "Frame")
	local myTankSelected = descendant(root, "MyTankSelected", "ImageLabel")
	local exploreSelected = descendant(root, "ExploreSelected", "ImageLabel")
	local myTankList = descendant(root, "MyTankFishList", "ScrollingFrame")
	local visitorList = descendant(root, "ExploreVisitorList", "ScrollingFrame")
	local fishTemplate = descendant(root, "MyTankFishRowTemplate", "Frame")
	local visitorTemplate = descendant(root, "ExploreVisitorRowTemplate", "Frame")
	local myTankEmpty = descendant(root, "EmptyMessage", "TextLabel")
	local exploreEmpty = descendant(root, "ExploreEmptyMessage", "TextLabel")
	local searchBox = descendant(root, "SearchBox", "TextBox")
	local scrollTrack = descendant(root, "ExploreScrollTrack", "Frame")
	local scrollThumb = descendant(scrollTrack, "ExploreScrollThumb", "Frame")

	local controller = {
		state = nil,
		page = "MyTank",
		filter = "Featured",
		visible = false,
	}

	local function updateScale()
		local camera = workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(1672, 941)
		uiScale.Scale = math.clamp(math.min(viewport.X / 1672, viewport.Y / 941) * 0.97, 0.34, 1.05)
	end

	local function setPage(page)
		controller.page = page
		local myTank = page == "MyTank"
		myTankPage.Visible = myTank
		explorePage.Visible = not myTank
		myTankSelected.Visible = myTank
		exploreSelected.Visible = not myTank
	end

	local function visitVisitor(visitor)
		if type(visitor) ~= "table" or not visitor.UserId then
			return
		end
		context.Remote.TeleportTo:FireServer({
			kind = "PlayerAquarium",
			userId = visitor.UserId,
		})
	end

	local function getFilteredVisitors()
		local source = controller.state and controller.state.AquariumVisitors or {}
		local result = {}
		local query = string.lower(searchBox.Text or "")

		for _, visitor in ipairs(source) do
			local name = string.lower(visitor.DisplayName or visitor.Name or "")
			local matchesSearch = query == "" or string.find(name, query, 1, true) ~= nil
			local matchesFilter = true
			if controller.filter == "Friends" and not visitor.IsSelf then
				local ok, isFriend = pcall(context.player.IsFriendsWith, context.player, visitor.UserId)
				matchesFilter = ok and isFriend == true
			elseif controller.filter == "Random" then
				matchesFilter = not visitor.IsSelf
			end

			if matchesSearch and matchesFilter then
				table.insert(result, visitor)
			end
		end

		if controller.filter == "MostLiked" then
			table.sort(result, function(a, b)
				return (tonumber(a.TotalValue) or 0) &gt; (tonumber(b.TotalValue) or 0)
			end)
		elseif controller.filter == "Featured" then
			table.sort(result, function(a, b)
				if a.IsSelf ~= b.IsSelf then
					return a.IsSelf
				end
				return (tonumber(a.AquariumLevel) or 1) &gt; (tonumber(b.AquariumLevel) or 1)
			end)
		elseif controller.filter == "Random" then
			for index = #result, 2, -1 do
				local swap = math.random(1, index)
				result[index], result[swap] = result[swap], result[index]
			end
		end

		return result
	end

	local function updateExploreScroll()
		local contentHeight = visitorList.AbsoluteCanvasSize.Y
		local viewHeight = visitorList.AbsoluteWindowSize.Y
		local trackHeight = scrollTrack.AbsoluteSize.Y - 10
		if contentHeight &lt;= viewHeight or contentHeight &lt;= 0 then
			scrollThumb.Visible = false
			return
		end

		scrollThumb.Visible = true
		local thumbHeight = math.max(64, math.floor(trackHeight * (viewHeight / contentHeight)))
		local available = trackHeight - thumbHeight
		local maxCanvas = math.max(1, contentHeight - viewHeight)
		local ratio = math.clamp(visitorList.CanvasPosition.Y / maxCanvas, 0, 1)
		scrollThumb.Size = UDim2.new(1, -4, 0, thumbHeight)
		scrollThumb.Position = UDim2.fromOffset(2, 5 + math.floor(available * ratio))
	end

	local function renderMyTank()
		local currentState = controller.state
		if not currentState then
			return
		end

		local aquarium = currentState.Aquarium or { Level = 1, Capacity = 40, Fish = {} }
		local fish = aquarium.Fish or {}
		local level = tonumber(aquarium.Level) or 1
		local used = tonumber(aquarium.UsedCapacity)
			or context.GameConfig.getAquariumUsedSpace(fish)
		local capacity = tonumber(aquarium.Capacity)
			or context.GameConfig.AquariumCapacities[level]
			or 40
		local best = bestFish(currentState, fish)
		local nextCost = context.GameConfig.AquariumUpgradeCosts[level + 1]

		descendant(myTankPage, "LevelValue", "TextLabel").Text = tostring(level)
		descendant(myTankPage, "CapacityValue", "TextLabel").Text = string.format("%d / %d", used, capacity)
		descendant(myTankPage, "BestFishValue", "TextLabel").Text = best and (best.name or "Fish") or "None yet"
		descendant(myTankPage, "TotalValueValue", "TextLabel").Text = string.format(
			"%s &lt;font size=22&gt;coins&lt;/font&gt;",
			formatNumber(aquariumTotalValue(fish))
		)
		descendant(myTankPage, "FishCount", "TextLabel").Text = string.format("FISH  —  %d", #fish)
		descendant(myTankPage, "UpgradeText", "TextLabel").Text = nextCost
			and ("Upgrade +" .. formatNumber(nextCost))
			or "Max Level"

		clearRows(myTankList)
		for index, entry in ipairs(fish) do
			local row = fishTemplate:Clone()
			row.Name = "FishRow_" .. tostring(index)
			row.LayoutOrder = index
			row.Visible = true
			descendant(row, "FishImage", "ImageLabel").Image = fishImage(context.GameConfig, entry)
			descendant(row, "FishName", "TextLabel").Text = entry.name or "Fish"
			local rarity = descendant(row, "Rarity", "TextLabel")
			rarity.Text = entry.rarity or "Common"
			rarity.TextColor3 = rarityColors[entry.rarity] or rarityColors.Common
			descendant(row, "Value", "TextLabel").Text = formatNumber(entry.value)
			descendant(row, "SpaceUsed", "TextLabel").Text = "Space used: " .. tostring(context.GameConfig.getAquariumFishSpace(entry))
			local remove = descendant(row, "RemoveButton", "TextButton")
			remove.MouseButton1Click:Connect(function()
				context.Remote.AquariumAction:FireServer("RemoveFish", entry.serial, index)
			end)
			setPressedFeedback(remove)
			row.Parent = myTankList
		end
		myTankEmpty.Visible = #fish == 0
	end

	local function renderExplore()
		local visitors = getFilteredVisitors()
		clearRows(visitorList)

		for index, visitor in ipairs(visitors) do
			local row = visitorTemplate:Clone()
			row.Name = "AquariumRow_" .. tostring(visitor.UserId or index)
			row.LayoutOrder = index
			row.Visible = true
			local displayName = visitor.DisplayName or visitor.Name or "Player"
			if visitor.IsSelf then
				displayName ..= " (You)"
			end
			descendant(row, "PlayerName", "TextLabel").Text = displayName
			descendant(row, "OnlineStatus", "TextLabel").Text = "● Online"
			descendant(row, "AquariumName", "TextLabel").Text = string.format("Level %d Aquarium", visitor.AquariumLevel or 1)
			descendant(row, "TotalValue", "TextLabel").Text = formatNumber(visitor.TotalValue)
			local best = visitor.BestCatch
			descendant(row, "BestFish", "TextLabel").Text = best and (best.name or "Fish") or "None yet"
			local image = fishImage(context.GameConfig, best)
			descendant(row, "BestFishImage", "ImageLabel").Image = image
			descendant(row, "PreviewFish", "ImageLabel").Image = image
			descendant(row, "FishCount", "TextLabel").Text = string.format("♡ %d fish", visitor.FishCount or 0)
			local visit = descendant(row, "ViewButton", "TextButton")
			visit.MouseButton1Click:Connect(function()
				visitVisitor(visitor)
			end)
			setPressedFeedback(visit)
			row.Parent = visitorList
		end

		exploreEmpty.Visible = #visitors == 0
		task.defer(updateExploreScroll)
	end

	function controller:Render(newState)
		if newState then
			self.state = newState
		end
		if not self.state then
			return
		end
		renderMyTank()
		renderExplore()
	end

	function controller:Show(newState)
		self.visible = true
		root.Visible = true
		setPage(self.page)
		updateScale()
		self:Render(newState)
	end

	function controller:Hide()
		self.visible = false
		root.Visible = false
	end

	function controller:IsVisible()
		return root.Visible
	end

	descendant(root, "MyTankButton", "TextButton").MouseButton1Click:Connect(function()
		setPage("MyTank")
		renderMyTank()
	end)
	descendant(root, "ExploreButton", "TextButton").MouseButton1Click:Connect(function()
		setPage("Explore")
		renderExplore()
	end)
	descendant(root, "CloseButton", "ImageButton").MouseButton1Click:Connect(function()
		controller:Hide()
		if context.onClose then
			context.onClose()
		end
	end)
	descendant(myTankPage, "UpgradeButton", "TextButton").MouseButton1Click:Connect(function()
		context.Remote.AquariumAction:FireServer("Upgrade")
	end)

	local filterButtons = {
		FeaturedButton = "Featured",
		MostLikedButton = "MostLiked",
		FriendsButton = "Friends",
		RandomButton = "Random",
	}
	for buttonName, filter in pairs(filterButtons) do
		local button = descendant(explorePage, buttonName, "TextButton")
		button.MouseButton1Click:Connect(function()
			controller.filter = filter
			descendant(explorePage, "ExploreHeading", "TextLabel").Text = string.upper(filter == "MostLiked" and "Most Liked Aquariums" or (filter .. " Aquariums"))
			renderExplore()
		end)
		setPressedFeedback(button)
	end

	descendant(explorePage, "VisitRandomButton", "TextButton").MouseButton1Click:Connect(function()
		local choices = {}
		for _, visitor in ipairs(controller.state and controller.state.AquariumVisitors or {}) do
			if not visitor.IsSelf then
				table.insert(choices, visitor)
			end
		end
		if #choices == 0 then
			context.showToast("No other aquariums are online right now.")
			return
		end
		visitVisitor(choices[math.random(1, #choices)])
	end)

	searchBox:GetPropertyChangedSignal("Text"):Connect(renderExplore)
	visitorList:GetPropertyChangedSignal("CanvasPosition"):Connect(updateExploreScroll)
	visitorList:GetPropertyChangedSignal("AbsoluteCanvasSize"):Connect(updateExploreScroll)
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(updateScale)
	if workspace.CurrentCamera then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
	end

	for _, name in ipairs({ "MyTankButton", "ExploreButton", "UpgradeButton", "CloseButton" }) do
		setPressedFeedback(descendant(root, name))
	end

	updateScale()
	controller:Hide()
	return controller
end

return AquariumViewerModernUI
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="709">
            <Properties>
              <string name="Name">BagModernUI</string>
              <string name="Source">local BagModernUI = {}

local BASE_WIDTH = 1448
local BASE_HEIGHT = 1086

-- ============================================================
-- BAG 전체 UI 크기 조절
-- 1.00 = 기존 크기
-- 0.90 = 10% 작게
-- 0.80 = 20% 작게
-- 1.10 = 10% 크게
-- ============================================================
local BAG_UI_SCALE_MULTIPLIER = 0.87

-- ============================================================
-- TARGET LAYOUT TUNING
-- ============================================================
-- 상단 탭 4개를 같은 크기/간격으로 정확히 배치
-- 왼쪽 바깥 여백 = 오른쪽 바깥 여백 = 58px
local ITEM_ROW_HEIGHT = 150
local ITEM_ROW_GAP = -15

-- 아이템 행 내부 공통 정렬
-- 아이콘 프레임, 이름, 설명/스탯, 버튼이 같은 행의 중앙선에 맞도록 관리함.
local ITEM_FRAME_X = 28
local ITEM_FRAME_SIZE = 112
local ITEM_FRAME_Y = (ITEM_ROW_HEIGHT - ITEM_FRAME_SIZE) / 2

local ITEM_TEXT_X = ITEM_FRAME_X + ITEM_FRAME_SIZE + 34
local ITEM_NAME_Y = 23
local ITEM_NAME_HEIGHT = 46
local ITEM_STATS_Y = 80
local ITEM_STATS_HEIGHT = 38

local ITEM_BUTTON_WIDTH = 206
local ITEM_BUTTON_HEIGHT = 64
local ITEM_BUTTON_RIGHT_MARGIN = 34

-- Bait 전용 배치
-- 아이콘은 더 크게 보이도록 하고, 프레임보다 살짝 왼쪽으로 걸치게 배치한다.
local BAIT_FRAME_X = ITEM_FRAME_X
local BAIT_FRAME_SIZE = 94
-- 아래 간격이 더 좁아 보이던 문제를 줄이기 위해
-- 프레임을 조금 더 줄이고 살짝 위로 올림.
local BAIT_FRAME_Y = ((ITEM_ROW_HEIGHT - BAIT_FRAME_SIZE) / 2) - 3

local BAIT_ICON_SIZE = 90

-- 프레임 내부 기준 아이콘 위치
-- X 값을 키우면 오른쪽, Y 값을 키우면 아래로 이동
local BAIT_ICON_X_OFFSET = 2
local BAIT_ICON_Y_OFFSET = -2

local ASSETS = {
	Backbone = "rbxassetid://108283623894606",
	TabNormal = "rbxassetid://105953757083088",
	TabSelected = "rbxassetid://99455447655780",
	RodTabIcon = "rbxassetid://77887294460644",
	BaitTabIcon = "rbxassetid://126189479051414",
	FishTabIcon = "rbxassetid://116369556818073",
	CloseButton = "rbxassetid://74437026548245",
	EquippedButton = "rbxassetid://97877042422133",
	SelectedOutline = "rbxassetid://78993001328940",
	ItemRowBackground = "rbxassetid://78930126580653",
	FishStorageHeader = "rbxassetid://94190047330110",
	BaitItemFrame = "rbxassetid://131578062209953",
	LeftDecoration = "rbxassetid://94493748436318",
	RightDecoration = "rbxassetid://107757008760729",

	FishFrames = {
		Common = "rbxassetid://82476012961179",
		Uncommon = "rbxassetid://109344755835178",
		Rare = "rbxassetid://134980793266582",
		Epic = "rbxassetid://78420747823288",
		Legendary = "rbxassetid://108344811627544",
		Mythic = "rbxassetid://128483019144117",
	},

	RodFrames = {
		WoodenRod = "rbxassetid://115934227658772",
		IronRod = "rbxassetid://71831440264510",
		GoldenRod = "rbxassetid://76246999880343",
		EmeraldRod = "rbxassetid://110828755102690",
		OceanRod = "rbxassetid://130788881686757",
	},

	BaitImages = {
		BasicBait = "rbxassetid://87143554943451",
		FreshBait = "rbxassetid://114397365249536",
		TastyBait = "rbxassetid://89693745580563",
		LuckyBait = "rbxassetid://90876615894262",
		GlowBait = "rbxassetid://140507231143381",
		MysticBait = "rbxassetid://91652408607528",
		PondGuardianBait = "rbxassetid://117293437837187",
	},
}

local ui = {
	root = nil,
	canvas = nil,
	scale = nil,
	content = nil,
	mountParent = nil,
	authoredUi = false,
	templates = nil,
	selectedTab = "Rods",
	context = nil,
	viewportConnection = nil,
	hiddenLegacyBaitIcons = {},
	legacyBaitWatcher = nil,
	legacyBaitSearchRoot = nil,
	tabConnections = setmetatable({}, { __mode = "k" }),
}

local function findScreenGui(instance)
	local current = instance
	while current do
		if current:IsA("ScreenGui") then
			return current
		end
		current = current.Parent
	end
	return nil
end

local function cloneTemplate(name)
	assert(ui.authoredUi and ui.templates, "Bag authored templates are not mounted")
	local template = ui.templates:FindFirstChild(name)
	assert(template, string.format("Bag template %s is missing", name))
	return template:Clone()
end

local function requireChild(parent, name, className)
	local child = parent:FindFirstChild(name)
	assert(child, string.format("Bag authored node %s.%s is missing", parent:GetFullName(), name))
	assert(
		child:IsA(className),
		string.format(
			"Bag authored node %s.%s must be %s, got %s",
			parent:GetFullName(),
			name,
			className,
			child.ClassName
		)
	)
	return child
end

local function makeImage(parent, name, image, position, size, zIndex, scaleType)
	local object = requireChild(parent, name, "ImageLabel")
	object.BackgroundTransparency = 1
	object.Position = position
	object.Size = size
	object.Image = image or ""
	object.ScaleType = scaleType or Enum.ScaleType.Fit
	object.ZIndex = zIndex or 302
	object.Visible = true
	return object
end

local function makeLabel(parent, name, text, position, size, textSize, zIndex, color, alignment)
	local label = requireChild(parent, name, "TextLabel")
	label.BackgroundTransparency = 1
	label.Position = position
	label.Size = size
	label.Font = Enum.Font.FredokaOne
	label.Text = text or ""
	label.TextColor3 = color or Color3.new(1, 1, 1)
	label.TextSize = textSize or 28
	label.TextScaled = false
	label.TextWrapped = false
	label.TextXAlignment = alignment or Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.TextStrokeColor3 = Color3.new(0, 0, 0)
	label.TextStrokeTransparency = 0.35
	label.ZIndex = zIndex or 306
	label.Visible = true
	return label
end

local function addCorner(parent, radius)
	local corner = parent:FindFirstChildOfClass("UICorner")
	assert(corner, string.format("Bag authored corner is missing from %s", parent:GetFullName()))
	corner.CornerRadius = UDim.new(0, radius)
	return corner
end

local function addStroke(parent, color, thickness, transparency)
	local stroke = parent:FindFirstChildOfClass("UIStroke")
	assert(stroke, string.format("Bag authored stroke is missing from %s", parent:GetFullName()))
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or 0
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	stroke.Enabled = true
	return stroke
end

local function addTextConstraint(label, minSize, maxSize)
	local constraint = label:FindFirstChildOfClass("UITextSizeConstraint")
	assert(constraint, string.format("Bag authored text constraint is missing from %s", label:GetFullName()))
	constraint.MinTextSize = minSize
	constraint.MaxTextSize = maxSize
	return constraint
end

local function clear(parent)
	for _, child in ipairs(parent:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end


local function normalizeAssetId(value)
	if type(value) ~= "string" then
		return ""
	end

	-- rbxassetid://123, rbxthumb://...id=123..., https://.../123/... 모두 대응
	local explicitId = string.match(value, "[?&amp;]id=(%d+)")
	-- Keep the declaration separate from the legacy comment above so it is
	-- always parsed instead of being swallowed by a damaged source comment.
	local explicitId = string.match(value, "[?&amp;]id=(%d+)")
	if explicitId then
		return explicitId
	end

	local assetId = string.match(value, "rbxassetid://(%d+)")
	if assetId then
		return assetId
	end

	local longest = ""
	for digits in string.gmatch(value, "%d+") do
		if #digits &gt; #longest then
			longest = digits
		end
	end

	return longest
end

local function getBaitAssetIds(context)
	local baitAssetIds = {}

	for baitId, image in pairs(ASSETS.BaitImages) do
		local normalized = normalizeAssetId(image)
		if normalized ~= "" then
			baitAssetIds[normalized] = true
		end

		if context
			and context.GameConfig
			and context.GameConfig.getBaitImage
		then
			local configuredImage =
				context.GameConfig.getBaitImage(baitId) or ""

			local configuredId =
				normalizeAssetId(configuredImage)

			if configuredId ~= "" then
				baitAssetIds[configuredId] = true
			end
		end
	end

	return baitAssetIds
end

local function hasBagOrBaitAncestor(object, stopAt)
	local current = object

	while current and current ~= stopAt do
		local loweredName = string.lower(current.Name or "")

		if string.find(loweredName, "bag", 1, true)
			or string.find(loweredName, "bait", 1, true)
		then
			return true
		end

		current = current.Parent
	end

	return false
end

local function isDuplicateBaitImage(object, context, searchRoot)
	if not object
		or not object.Parent
		or not (
			object:IsA("ImageLabel")
				or object:IsA("ImageButton")
		)
	then
		return false
	end

	-- 현재 파란 프레임 안에서 사용하는 유일한 아이콘은 절대 삭제하지 않음.
	if object.Name == "ModernBaitIcon"
		and ui.root
		and object:IsDescendantOf(ui.root)
	then
		return false
	end

	local baitAssetIds = getBaitAssetIds(context)
	local objectAssetId =
		normalizeAssetId(object.Image or "")

	if objectAssetId == ""
		or not baitAssetIds[objectAssetId]
	then
		return false
	end

	-- Bag/Bait UI 안에 있는 동일 bait 이미지에만 적용한다.
	return hasBagOrBaitAncestor(object, searchRoot.Parent)
		or object:IsDescendantOf(context.parent)
end

local function deleteDuplicateBaitImage(object, context, searchRoot)
	if isDuplicateBaitImage(object, context, searchRoot) then
		object:Destroy()
		return true
	end

	return false
end

local function purgeDuplicateBaitIcons(context)
	-- AuthoredUiV2 has one declared Bag owner. Do not scan PlayerGui or delete
	-- images owned by authored templates and sibling surfaces.
	if ui.authoredUi then
		if ui.legacyBaitWatcher then
			ui.legacyBaitWatcher:Disconnect()
			ui.legacyBaitWatcher = nil
		end
		return
	end

	if not context or not context.parent then
		return
	end

	local searchRoot =
		context.parent:FindFirstAncestorOfClass("PlayerGui")
		or context.parent:FindFirstAncestorOfClass("ScreenGui")
		or context.parent

	ui.legacyBaitSearchRoot = searchRoot

	-- 이미 화면에 존재하는 프레임 뒤 bait 아이콘 객체를 실제로 삭제한다.
	for _, object in ipairs(searchRoot:GetDescendants()) do
		deleteDuplicateBaitImage(object, context, searchRoot)
	end

	-- 다른 코드가 중복 아이콘을 다시 만들더라도 생성 즉시 삭제한다.
	if ui.legacyBaitWatcher then
		ui.legacyBaitWatcher:Disconnect()
		ui.legacyBaitWatcher = nil
	end

	ui.legacyBaitWatcher =
		searchRoot.DescendantAdded:Connect(function(object)
			if ui.selectedTab ~= "Bait"
				or not ui.root
				or not ui.root.Visible
			then
				return
			end

			task.defer(function()
				if object and object.Parent then
					deleteDuplicateBaitImage(
						object,
						ui.context,
						searchRoot
					)
				end
			end)
		end)

	-- 기존 UI 스크립트가 한 프레임 늦게 아이콘을 다시 만드는 경우까지 제거.
	for _, delayTime in ipairs({ 0, 0.05, 0.15, 0.4 }) do
		task.delay(delayTime, function()
			if ui.selectedTab == "Bait"
				and ui.root
				and ui.root.Visible
				and ui.context
			then
				for _, object in ipairs(searchRoot:GetDescendants()) do
					deleteDuplicateBaitImage(
						object,
						ui.context,
						searchRoot
					)
				end
			end
		end)
	end
end


local function updateScale()
	if not ui.scale then
		return
	end

	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize
		or Vector2.new(1920, 1080)

	-- 화면 크기에 따라 기본 반응형 크기 계산
	local widthScale = viewport.X * 0.80 / BASE_WIDTH
	local heightScale = viewport.Y * 0.76 / BASE_HEIGHT
	local responsiveScale = math.min(widthScale, heightScale)

	-- BAG_UI_SCALE_MULTIPLIER 값으로 전체 UI 크기 조절
	ui.scale.Scale = math.clamp(
		responsiveScale * BAG_UI_SCALE_MULTIPLIER,
		0.24,
		1.05
	)
end

local function buildBase(parent)
	if ui.root
		and ui.root.Parent
		and ui.mountParent == parent
	then
		return
	end

	if ui.viewportConnection then
		ui.viewportConnection:Disconnect()
		ui.viewportConnection = nil
	end

	local screenGui = findScreenGui(parent)
	assert(screenGui, "Bag must be mounted below FishingGui")
	assert(screenGui:GetAttribute("AuthoredUiV2") == true, "Bag requires AuthoredUiV2")

	local root = requireChild(screenGui, "ModernBagRoot", "Frame")
	local canvas = requireChild(root, "Canvas", "Frame")
	local responsiveScale = requireChild(canvas, "ResponsiveScale", "UIScale")
	local templates = requireChild(root, "Templates", "Folder")
	local content = requireChild(canvas, "ItemList", "ScrollingFrame")
	local closeButton = requireChild(canvas, "CloseButton", "ImageButton")
	content.ClipsDescendants = true
	content.Active = true
	content.ScrollingEnabled = true

	ui.root = root
	ui.mountParent = parent
	ui.authoredUi = true
	ui.templates = templates
	ui.canvas = canvas
	ui.scale = responsiveScale
	ui.content = content

	closeButton.MouseButton1Click:Connect(function()
		BagModernUI.hide()
		if ui.context and ui.context.onClose then
			ui.context.onClose()
		end
	end)

	local camera = workspace.CurrentCamera
	if camera then
		ui.viewportConnection = camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
	end
	updateScale()
end

local function makeTab(id, labelText)
	local selected = ui.selectedTab == id
	local button = requireChild(ui.canvas, id .. "Tab", "ImageButton")
	local label = requireChild(button, "Label", "TextLabel")
	button.Image = selected and ASSETS.TabSelected or ASSETS.TabNormal
	label.Text = labelText

	if not ui.tabConnections[button] then
		ui.tabConnections[button] = button.MouseButton1Click:Connect(function()
			if ui.selectedTab ~= id then
				ui.selectedTab = id
				BagModernUI.refresh()
			end
		end)
	end
end

local function makeNormalButton(parent, text, enabled, callback)
	local button = requireChild(parent, "ActionButton", "TextButton")
	button.AnchorPoint = Vector2.new(1, 0.5)
	button.Position = UDim2.new(1, -ITEM_BUTTON_RIGHT_MARGIN, 0.5, 0)
	button.Size = UDim2.fromOffset(ITEM_BUTTON_WIDTH, ITEM_BUTTON_HEIGHT)
	button.BackgroundColor3 = enabled and Color3.fromRGB(4, 35, 78) or Color3.fromRGB(45, 55, 70)
	button.AutoButtonColor = enabled
	button.Font = Enum.Font.FredokaOne
	button.Text = text
	button.TextColor3 = Color3.new(1, 1, 1)
	button.TextSize = 28
	button.TextStrokeColor3 = Color3.new(0, 0, 0)
	button.TextStrokeTransparency = 0.35
	button.ZIndex = 310
	button.Visible = true
	addCorner(button, 14)
	addStroke(button, enabled and Color3.fromRGB(0, 112, 255) or Color3.fromRGB(90, 105, 125), 2, 0.08)

	if enabled and callback then
		button.MouseButton1Click:Connect(callback)
	end

	return button
end

local function makeEquippedButton(parent)
	-- 일반 Equip 버튼과 정확히 같은 함수/좌표계를 사용한다.
	-- 따라서 Rod/Bait/Fish 어디에서 사용해도 같은 자리에 고정된다.
	local button = makeNormalButton(parent, "Equipped", false, nil)
	button.Name = "EquippedButton"
	button.BackgroundColor3 = Color3.fromRGB(0, 126, 24)
	button.AutoButtonColor = false
	button.Active = false
	button.Selectable = false

	local stroke = button:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = Color3.fromRGB(39, 255, 44)
		stroke.Thickness = 2
		stroke.Transparency = 0.04
	end

	return button
end

local function makeRow(height, equipped)
	local wrapper = cloneTemplate("InventoryRowTemplate")
	assert(wrapper:IsA("Frame"), "InventoryRowTemplate must be a Frame")
	wrapper.Name = "ItemRow"
	wrapper.Size = UDim2.new(1, -4, 0, height)
	wrapper.BackgroundTransparency = 1
	wrapper.LayoutOrder = 0
	wrapper.Visible = true
	wrapper.ZIndex = 304
	wrapper.Parent = ui.content

	for _, child in ipairs(wrapper:GetChildren()) do
		if child:IsA("GuiObject") then
			child.Visible = false
		elseif child:IsA("UIStroke") then
			child.Enabled = false
		end
	end

	local background = makeImage(
		wrapper,
		"Background",
		ASSETS.ItemRowBackground,
		UDim2.fromScale(0, 0),
		UDim2.fromScale(1, 1),
		305,
		Enum.ScaleType.Stretch
	)

	if equipped then
		local selectedOutline = makeImage(
			background,
			"SelectedOutline",
			ASSETS.SelectedOutline,
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			320,
			Enum.ScaleType.Stretch
		)
		selectedOutline.Active = false
	end

	-- InventoryRowTemplate keeps its content nodes (RodFrame, BaitFrame,
	-- FishFrame, labels, and ActionButton) beside Background.  Return the
	-- wrapper so each renderer binds those authored siblings; Background is
	-- used only for the row artwork and selected outline.
	return wrapper
end

local function renderRods(context)
	local state = context.state or {}
	local gameConfig = context.GameConfig
	local ownedRods = state.OwnedRods or {}
	local rendered = 0

	for _, rodId in ipairs(gameConfig.RodOrder or {}) do
		if ownedRods[rodId] then
			rendered += 1
			local rod = gameConfig.Rods[rodId]
			local equipped = state.EquippedRod == rodId
			local row = makeRow(ITEM_ROW_HEIGHT, equipped)

			local frame = makeImage(
				row,
				"RodFrame",
				ASSETS.RodFrames[rodId] or ASSETS.RodFrames.WoodenRod,
				UDim2.fromOffset(ITEM_FRAME_X, ITEM_FRAME_Y),
				UDim2.fromOffset(ITEM_FRAME_SIZE, ITEM_FRAME_SIZE),
				307,
				Enum.ScaleType.Fit
			)

			local rodImage = gameConfig.getRodImage and gameConfig.getRodImage(rodId) or ""
			makeImage(
				frame,
				"RodIcon",
				rodImage,
				UDim2.fromScale(0.10, 0.10),
				UDim2.fromScale(0.80, 0.80),
				308,
				Enum.ScaleType.Fit
			)

			makeLabel(
				row,
				"RodName",
				rod and rod.displayName or rodId,
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_NAME_Y),
				UDim2.fromOffset(650, ITEM_NAME_HEIGHT),
				32,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)

			local speedPercent = math.floor((1 / math.max(tonumber(rod and rod.speed) or 1, 0.001)) * 100 + 0.5)
			local luckPercent = math.floor((tonumber(rod and rod.luck) or 0) * 100 + 0.5)

			makeLabel(
				row,
				"Speed",
				"Speed: " .. tostring(speedPercent) .. "%",
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_STATS_Y),
				UDim2.fromOffset(260, ITEM_STATS_HEIGHT),
				25,
				309,
				Color3.fromRGB(0, 230, 255),
				Enum.TextXAlignment.Left
			)

			makeLabel(
				row,
				"Luck",
				"Luck: +" .. tostring(luckPercent) .. "%",
				UDim2.fromOffset(430, ITEM_STATS_Y),
				UDim2.fromOffset(270, ITEM_STATS_HEIGHT),
				25,
				309,
				Color3.fromRGB(180, 255, 0),
				Enum.TextXAlignment.Left
			)

			if equipped then
				makeEquippedButton(row)
			else
				makeNormalButton(row, "Equip", true, function()
					if context.equipRod then
						context.equipRod(rodId)
					end
				end)
			end
		end
	end

	if rendered == 0 then
		local row = makeRow(ITEM_ROW_HEIGHT, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No fishing rods owned.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
	end
end

local function renderBait(context)
	-- 예전 Bag UI에서 뒤에 남아 있던 bait 아이콘을 숨긴다.
	-- 이제 화면에는 아래에서 만드는 ModernBaitIcon만 보인다.
	purgeDuplicateBaitIcons(context)

	local state = context.state or {}
	local gameConfig = context.GameConfig
	local rendered = 0

	for _, baitId in ipairs(gameConfig.BaitOrder or {}) do
		local bait = gameConfig.Baits and gameConfig.Baits[baitId]
		local count = context.getBaitCount and context.getBaitCount(baitId) or 0
		local isBasic = baitId == gameConfig.BasicBaitId
		local owned = isBasic or count &gt; 0

		if bait and owned then
			rendered += 1
			local equipped = state.EquippedBait == baitId
			local row = makeRow(ITEM_ROW_HEIGHT, equipped)

			local frame = requireChild(row, "BaitFrame", "Frame")
			frame.BackgroundColor3 = Color3.fromRGB(3, 18, 49)
			frame.BackgroundTransparency = 0
			frame.Position = UDim2.fromOffset(BAIT_FRAME_X, BAIT_FRAME_Y)
			frame.Size = UDim2.fromOffset(BAIT_FRAME_SIZE, BAIT_FRAME_SIZE)
			frame.ClipsDescendants = true
			frame.ZIndex = 307
			frame.Visible = true
			addCorner(frame, 10)
			addStroke(frame, Color3.fromRGB(0, 103, 255), 2, 0.05)

			local baitImage = ASSETS.BaitImages[baitId] or ""
			if gameConfig.getBaitImage then
				local configuredImage = gameConfig.getBaitImage(baitId) or ""
				if configuredImage ~= "" then
					baitImage = configuredImage
				end
			end

			-- 아이콘을 BaitFrame의 자식으로 넣어서
			-- 프레임 바깥으로 삐져나오는 부분을 완전히 잘라낸다.
			local centeredIconX =
				((BAIT_FRAME_SIZE - BAIT_ICON_SIZE) / 2)
				+ BAIT_ICON_X_OFFSET

			local centeredIconY =
				((BAIT_FRAME_SIZE - BAIT_ICON_SIZE) / 2)
				+ BAIT_ICON_Y_OFFSET

			local baitIcon = makeImage(
				frame,
				"ModernBaitIcon",
				baitImage,
				UDim2.fromOffset(centeredIconX, centeredIconY),
				UDim2.fromOffset(BAIT_ICON_SIZE, BAIT_ICON_SIZE),
				309,
				Enum.ScaleType.Fit
			)
			baitIcon.ClipsDescendants = true

			makeLabel(
				row,
				"BaitName",
				bait.displayName,
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_NAME_Y),
				UDim2.fromOffset(650, ITEM_NAME_HEIGHT),
				32,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)

			local quantity = isBasic and "Unlimited" or tostring(count)
			makeLabel(
				row,
				"Quantity",
				"Quantity: " .. quantity,
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_STATS_Y),
				UDim2.fromOffset(320, ITEM_STATS_HEIGHT),
				25,
				309,
				equipped and Color3.fromRGB(112, 255, 156) or Color3.fromRGB(190, 204, 220),
				Enum.TextXAlignment.Left
			)

			makeLabel(
				row,
				"Description",
				bait.description or "",
				UDim2.fromOffset(470, ITEM_STATS_Y),
				UDim2.fromOffset(410, ITEM_STATS_HEIGHT),
				21,
				309,
				Color3.fromRGB(150, 175, 205),
				Enum.TextXAlignment.Left
			)

			if equipped then
				makeEquippedButton(row)
			else
				makeNormalButton(row, "Equip", true, function()
					if context.equipBait then
						context.equipBait(baitId)
					end
				end)
			end
		end
	end

	-- 아이템 생성이 끝난 뒤 다시 검사한다.
	-- 현재 앞쪽 ModernBaitIcon만 남기고 뒤에 겹친 bait 이미지는 전부 숨긴다.
	purgeDuplicateBaitIcons(context)

	if rendered == 0 then
		local row = makeRow(ITEM_ROW_HEIGHT, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No bait owned.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
	end
end

local function renderResources(context)
	local resourceConfig = context.ResourceConfig or {}
	local resources = resourceConfig.Resources or {}
	local inventory = context.state and context.state.ResourceInventory or {}
	local rendered = 0

	local defaultDescriptions = {
		ironscrap = "Basic crafting metal.",
		goldnugget = "Valuable crafting metal.",
		emeraldshard = "Refined gem material.",
		oceanshard = "Rare ocean gem fragment.",
	}

	local function getResourceDescription(resourceId, resource)
		local configuredDescription = resource.description or resource.desc
		if configuredDescription and configuredDescription ~= "" then
			return configuredDescription
		end

		local idKey = string.lower(string.gsub(tostring(resourceId or ""), "[^%w]", ""))
		local nameKey = string.lower(string.gsub(tostring(resource.displayName or ""), "[^%w]", ""))
		return defaultDescriptions[idKey]
			or defaultDescriptions[nameKey]
			or "Crafting material."
	end

	local function getResourceImage(resourceId, resource)
		local resourceImage = resource.iconId
			or resource.imageId
			or resource.image
			or resource.icon
			or ""
		if context.getResourceImage then
			local configuredImage = context.getResourceImage(resourceId) or ""
			if configuredImage ~= "" then
				resourceImage = configuredImage
			end
		elseif resourceConfig.getResourceImage then
			local configuredImage = resourceConfig.getResourceImage(resourceId) or ""
			if configuredImage ~= "" then
				resourceImage = configuredImage
			end
		end

		local imageText = tostring(resourceImage or "")
		if tonumber(imageText) then
			imageText = "rbxassetid://" .. tostring(math.floor(tonumber(imageText)))
		end
		return imageText
	end

	for _, resourceId in ipairs(resourceConfig.ResourceOrder or {}) do
		local resource = resources[resourceId]
		if resource then
			rendered += 1
			local count = math.max(0, math.floor(tonumber(inventory[resourceId]) or 0))
			local row = makeRow(ITEM_ROW_HEIGHT, false)
			row.Name = tostring(resourceId) .. "MaterialRow"

			-- v1636 intentionally uses the same full-width item row and icon
			-- frame as the Bait tab rather than a compact resource-card grid.
			local materialFrame = requireChild(row, "BaitFrame", "Frame")
			materialFrame.Name = "MaterialFrame"
			materialFrame.BackgroundColor3 = Color3.fromRGB(3, 18, 49)
			materialFrame.BackgroundTransparency = 0
			materialFrame.Position = UDim2.fromOffset(BAIT_FRAME_X, BAIT_FRAME_Y)
			materialFrame.Size = UDim2.fromOffset(BAIT_FRAME_SIZE, BAIT_FRAME_SIZE)
			materialFrame.ClipsDescendants = true
			materialFrame.ZIndex = 307
			materialFrame.Visible = true
			addCorner(materialFrame, 10)
			addStroke(materialFrame, Color3.fromRGB(0, 103, 255), 2, 0.05)

			local centeredIconX = ((BAIT_FRAME_SIZE - BAIT_ICON_SIZE) / 2) + BAIT_ICON_X_OFFSET
			local centeredIconY = ((BAIT_FRAME_SIZE - BAIT_ICON_SIZE) / 2) + BAIT_ICON_Y_OFFSET
			local materialIcon = makeImage(
				materialFrame,
				"ModernBaitIcon",
				getResourceImage(resourceId, resource),
				UDim2.fromOffset(centeredIconX, centeredIconY),
				UDim2.fromOffset(BAIT_ICON_SIZE, BAIT_ICON_SIZE),
				309,
				Enum.ScaleType.Fit
			)
			materialIcon.Name = "ModernMaterialIcon"
			materialIcon.ClipsDescendants = true

			local materialName = makeLabel(
				row,
				"BaitName",
				resource.displayName or tostring(resourceId),
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_NAME_Y),
				UDim2.fromOffset(650, ITEM_NAME_HEIGHT),
				32,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)
			materialName.Name = "MaterialName"

			local quantityLabel = makeLabel(
				row,
				"Quantity",
				"",
				UDim2.fromOffset(ITEM_TEXT_X, ITEM_STATS_Y),
				UDim2.fromOffset(320, ITEM_STATS_HEIGHT),
				25,
				309,
				Color3.new(1, 1, 1),
				Enum.TextXAlignment.Left
			)
			quantityLabel.RichText = true
			quantityLabel.Text = string.format(
				'&lt;font color="#FFD95A"&gt;Quantity:&lt;/font&gt; &lt;font color="#FFFFFF"&gt;%d&lt;/font&gt;',
				count
			)

			makeLabel(
				row,
				"Description",
				getResourceDescription(resourceId, resource),
				UDim2.fromOffset(470, (ITEM_ROW_HEIGHT - ITEM_STATS_HEIGHT) / 2),
				UDim2.fromOffset(650, ITEM_STATS_HEIGHT),
				21,
				309,
				Color3.fromRGB(150, 175, 205),
				Enum.TextXAlignment.Left
			)
		end
	end

	if rendered == 0 then
		local row = makeRow(ITEM_ROW_HEIGHT, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No materials found.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
	end
end

local function renderFish(context)
	local state = context.state or {}
	local gameConfig = context.GameConfig
	local inventory = state.Inventory or {}
	local canEdit = state.AquariumView and state.AquariumView.CanEdit == true

	local header = cloneTemplate("FishStorageHeaderTemplate")
	assert(header:IsA("Frame"), "FishStorageHeaderTemplate must be a Frame")
	header.Name = "FishStorageHeader"
	header.Size = UDim2.new(1, -4, 0, 104)
	header.BackgroundTransparency = 1
	header.ZIndex = 304
	header.Visible = true
	header.Parent = ui.content

	local headerImage = makeImage(
		header,
		"Background",
		ASSETS.FishStorageHeader,
		UDim2.fromScale(0, 0),
		UDim2.fromScale(1, 1),
		305,
		Enum.ScaleType.Stretch
	)

	makeLabel(
		headerImage,
		"Storage",
		string.format("Fish Storage: %d / %d", #inventory, tonumber(state.BackpackSize) or 0),
		UDim2.fromOffset(34, 10),
		UDim2.fromOffset(600, 84),
		31,
		307,
		Color3.new(1, 1, 1),
		Enum.TextXAlignment.Left
	)

	makeLabel(
		headerImage,
		"Value",
		string.format("Bag Value: %d Coins", tonumber(state.InventoryValue) or 0),
		UDim2.new(1, -600, 0, 10),
		UDim2.fromOffset(550, 84),
		29,
		307,
		Color3.fromRGB(255, 220, 80),
		Enum.TextXAlignment.Right
	)

	if #inventory == 0 then
		local row = makeRow(ITEM_ROW_HEIGHT, false)
		local empty = makeLabel(
			row,
			"Empty",
			"No fish stored in your bag.",
			UDim2.fromScale(0, 0),
			UDim2.fromScale(1, 1),
			30,
			309,
			Color3.fromRGB(190, 204, 220),
			Enum.TextXAlignment.Center
		)
		empty.TextScaled = true
		addTextConstraint(empty, 18, 30)
		return
	end

	for index = #inventory, 1, -1 do
		local fish = inventory[index]
		local rarity = fish.rarity or "Common"
		if rarity == "Mythical" then
			rarity = "Mythic"
		end
		local rarityColor = (gameConfig.RarityColors and gameConfig.RarityColors[rarity]) or Color3.new(1, 1, 1)
		local row = makeRow(ITEM_ROW_HEIGHT, false)

		local frame = makeImage(
			row,
			"FishFrame",
			ASSETS.FishFrames[rarity] or ASSETS.FishFrames.Common,
			UDim2.fromOffset(ITEM_FRAME_X, ITEM_FRAME_Y),
			UDim2.fromOffset(ITEM_FRAME_SIZE, ITEM_FRAME_SIZE),
			307,
			Enum.ScaleType.Fit
		)

		local fishImage = gameConfig.getFishImage and gameConfig.getFishImage(fish.imageKey or fish.id) or ""
		makeImage(
			frame,
			"FishIcon",
			fishImage,
			UDim2.fromScale(0.12, 0.12),
			UDim2.fromScale(0.76, 0.76),
			308,
			Enum.ScaleType.Fit
		)

		makeLabel(
			row,
			"FishName",
			fish.name or tostring(fish.id),
			UDim2.fromOffset(ITEM_TEXT_X, ITEM_NAME_Y),
			UDim2.fromOffset(650, ITEM_NAME_HEIGHT),
			32,
			309,
			Color3.new(1, 1, 1),
			Enum.TextXAlignment.Left
		)

		makeLabel(
			row,
			"Rarity",
			rarity,
			UDim2.fromOffset(ITEM_TEXT_X, ITEM_STATS_Y),
			UDim2.fromOffset(220, ITEM_STATS_HEIGHT),
			25,
			309,
			rarityColor,
			Enum.TextXAlignment.Left
		)

		makeLabel(
			row,
			"Value",
			"Value: " .. tostring(tonumber(fish.value) or 0),
			UDim2.fromOffset(410, ITEM_STATS_Y),
			UDim2.fromOffset(280, ITEM_STATS_HEIGHT),
			25,
			309,
			Color3.fromRGB(255, 220, 80),
			Enum.TextXAlignment.Left
		)

		makeNormalButton(
			row,
			canEdit and "Display" or "View Only",
			canEdit,
			function()
				if canEdit and context.displayFish then
					context.displayFish(fish, index)
				end
			end
		)
	end
end

function BagModernUI.refresh()
	if not ui.root or not ui.content or not ui.context then
		return
	end

	clear(ui.content)

	-- 4개 탭 모두 같은 크기이며, 탭 사이 간격과 양쪽 바깥 여백이 일정함.
	makeTab("Rods", "Fishing Rods")
	makeTab("Bait", "Bait")
	makeTab("Fish", "Fish")
	makeTab("Materials", "Materials")

	if ui.selectedTab == "Rods" then
		renderRods(ui.context)
	elseif ui.selectedTab == "Bait" then
		purgeDuplicateBaitIcons(ui.context)
		renderBait(ui.context)
	elseif ui.selectedTab == "Fish" then
		renderFish(ui.context)
	elseif ui.selectedTab == "Materials" then
		renderResources(ui.context)
		-- Materials 내부 내용은 추후 이 위치에 렌더링하면 됨.
		-- 현재는 탭만 생성하고 콘텐츠 영역은 비워 둠.
	end

	ui.content.CanvasPosition = Vector2.new(0, 0)
end

function BagModernUI.show(context)
	assert(type(context) == "table", "BagModernUI.show requires a context table")
	assert(context.parent, "BagModernUI.show requires context.parent")
	assert(context.GameConfig, "BagModernUI.show requires context.GameConfig")
	assert(context.ResourceConfig, "BagModernUI.show requires context.ResourceConfig")

	buildBase(context.parent)
	ui.context = context
	ui.root.Visible = true

	-- Never fall back to the old Bag panel if one malformed item causes a
	-- rendering error. Keep the modern window open and show the error in Output.
	local ok, err = xpcall(BagModernUI.refresh, debug.traceback)
	if not ok then
		warn("[BagModernUI] Modern Bag render failed:\n" .. tostring(err))
		clear(ui.content)

		local errorRow = cloneTemplate("ErrorRowTemplate")
		assert(errorRow:IsA("Frame"), "ErrorRowTemplate must be a Frame")
		errorRow.Name = "ModernBagError"
		errorRow.Size = UDim2.new(1, -4, 0, 130)
		errorRow.BackgroundColor3 = Color3.fromRGB(35, 15, 24)
		errorRow.BackgroundTransparency = 0.08
		errorRow.ZIndex = 304
		errorRow.Visible = true
		errorRow.Parent = ui.content
		addCorner(errorRow, 16)
		addStroke(errorRow, Color3.fromRGB(255, 80, 100), 2, 0.08)

		local errorLabel = makeLabel(
			errorRow,
			"ErrorText",
			"Modern Bag could not render. Check Output for [BagModernUI].",
			UDim2.fromOffset(24, 18),
			UDim2.new(1, -48, 1, -36),
			24,
			309,
			Color3.fromRGB(255, 210, 220),
			Enum.TextXAlignment.Center
		)
		errorLabel.TextWrapped = true
	end
end

function BagModernUI.hide()
	if ui.legacyBaitWatcher then
		ui.legacyBaitWatcher:Disconnect()
		ui.legacyBaitWatcher = nil
	end

	if ui.root then
		ui.root.Visible = false
	end
end

print("[BagModernUI] Four-tab layout with Materials loaded.")

return BagModernUI
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="710">
            <Properties>
              <string name="Name">BaitHelpers</string>
              <string name="Source">local BaitHelpers = {}

function BaitHelpers.create(deps)
	local GameConfig = deps.GameConfig
	local getState = deps.getState
	local helpers = {}

	function helpers.getBaitData(baitId)
		return GameConfig.getBait(baitId)
	end

	function helpers.getBaitCount(baitId)
		local state = getState()
		if not state then
			return 0
		end

		baitId = baitId or GameConfig.BasicBaitId
		if baitId == GameConfig.BasicBaitId then
			return math.huge
		end

		local inventory = state.BaitInventory or {}
		return math.max(0, math.floor(tonumber(inventory[baitId]) or 0))
	end

	function helpers.getBaitCountText(baitId, count)
		if baitId == GameConfig.BasicBaitId or count == math.huge or count == -1 then
			return "Unlimited"
		end

		return tostring(count or helpers.getBaitCount(baitId)) .. " left"
	end

	function helpers.getEquippedBaitDisplay()
		local state = getState()
		local baitId = state and state.EquippedBait or GameConfig.BasicBaitId
		local bait = helpers.getBaitData(baitId)
		local remaining = state and state.EquippedBaitRemaining or -1

		return "Bait: " .. bait.displayName .. " (" .. helpers.getBaitCountText(baitId, remaining) .. ")"
	end

	function helpers.getBaitEffectText(bait)
		local parts = {}

		if (tonumber(bait.biteSpeedMultiplier) or 1) &lt; 1 then
			table.insert(parts, "faster bites")
		end
		if (tonumber(bait.rareChanceBonus) or 0) &gt; 0 then
			table.insert(parts, "+" .. tostring(math.floor((bait.rareChanceBonus or 0) * 100)) .. "% rare luck")
		end
		if (tonumber(bait.valueMultiplier) or 1) &gt; 1 then
			table.insert(parts, "+" .. tostring(math.floor(((bait.valueMultiplier or 1) - 1) * 100 + 0.5)) .. "% value")
		end
		if (tonumber(bait.xpMultiplier) or 1) &gt; 1 then
			table.insert(parts, "+" .. tostring(math.floor(((bait.xpMultiplier or 1) - 1) * 100 + 0.5)) .. "% XP")
		end

		if #parts == 0 then
			return bait.description or "Default fishing."
		end

		return table.concat(parts, " | ")
	end

	return helpers
end

return BaitHelpers
</string>
