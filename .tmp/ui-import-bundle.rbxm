local function ownsGamePass(state, passKey)
	local monetization = state and state.Monetization or {}
	local owned = monetization.OwnedGamePasses or {}
	return owned[passKey] == true
end

local robuxPriceCache = {}

local function formatRobux(item, infoType)
	local itemId = tonumber(item.id) or tonumber(item.Id)
	local fallbackPrice = tonumber(item.priceRobux) or tonumber(item.Price)
	if not itemId or itemId &lt;= 0 then
		return tostring(fallbackPrice or "?") .. " Robux"
	end
	infoType = infoType or Enum.InfoType.GamePass
	local cacheKey = tostring(infoType) .. ":" .. tostring(itemId)
	local cachedPrice = robuxPriceCache[cacheKey]
	if cachedPrice == nil then
		local success, productInfo = pcall(function()
			return MarketplaceService:GetProductInfo(itemId, infoType)
		end)
		cachedPrice = success and type(productInfo) == "table" and tonumber(productInfo.PriceInRobux) or fallbackPrice
		robuxPriceCache[cacheKey] = cachedPrice
	end
	return tostring(cachedPrice or "?") .. " Robux"
end

local function gamePassAction(context, passKey)
	if ownsGamePass(context.state, passKey) then
		return {
			text = "Owned",
			type = "BlueButton",
			enabled = false,
		}
	end

	return {
		text = "Buy",
		type = "GreenButton",
		enabled = true,
		onClick = function()
			context.fireShopAction(
				"PromptGamePass",
				"GamePass",
				passKey
			)
		end,
	}
end

local function vipRewardAction(context)
	local monetization = context.state
		and context.state.Monetization
		or {}

	if not ownsGamePass(context.state, "VipAngler") then
		return {
			text = "Unavailable",
			type = "RedButton",
			enabled = false,
		}
	end

	if monetization.VipRewardAvailable == true then
		return {
			text = "Claim",
			type = "GreenButton",
			enabled = true,
			onClick = function()
				context.fireShopAction(
					"ClaimVipReward",
					"GamePass",
					"VipAngler"
				)
			end,
		}
	end

	return {
		text = "Claimed",
		type = "BlueButton",
		enabled = false,
	}
end

local function renderPasses(context)
	local order = 1
	createImageRow(context, {
		key = "VipDailyReward",
		layoutOrder = order,
		height = 172,
		title = "VIP Daily Reward",
		description = "5 Fresh Bait + 2 Lucky Bait once per day.",
		action = vipRewardAction(context),
	})
	order += 1

	local passImages = {
		VipAngler = "VipAnglerPass",
		AquariumDesigner = "AquariumDesignerPass",
	}

	for _, passKey in ipairs({
		"VipAngler",
		"AquariumDesigner",
		}) do
		local pass = context.MonetizationConfig.GamePasses[passKey]
		if pass then
			createImageRow(context, {
				key = passImages[passKey],
				layoutOrder = order,
				height = 190,
				title = pass.name,
				description = pass.description,
				descriptionLines = 2,
				priceText = formatRobux(pass, Enum.InfoType.GamePass),
				action = gamePassAction(context, passKey),
			})
			order += 1
		end
	end
end

local function renderItems(context)
	local imageKeys = {
		SmallLuckyBaitPack = "SmallLuckyBaitPack",
		MediumLuckyBaitPack = "MediumLuckyBaitPack",
		LargeLuckyBaitPack = "LargeLuckyBaitPack",
	}
	local order = 1

	for _, productKey in ipairs(
		context.MonetizationConfig.DeveloperProductOrder or {}
		) do
		local product = context.MonetizationConfig
			.DeveloperProducts[productKey]
		if product then
			createImageRow(context, {
				key = imageKeys[productKey],
				layoutOrder = order,
				height = 190,
				title = product.name,
				description = product.description,
				priceText = formatRobux(product, Enum.InfoType.Product),
				action = {
					text = "Buy",
					type = "GreenButton",
					enabled = true,
					onClick = function()
						context.fireShopAction(
							"PromptProduct",
							"Product",
							productKey
						)
					end,
				},
			})
			order += 1
		end
	end

	for _, productKey in ipairs(
		context.MonetizationConfig.SeaStarProductOrder or {}
		) do
		local product = context.MonetizationConfig
			.DeveloperProducts[productKey]
		if product then
			createProductCard(context, {
				key = productKey,
				layoutOrder = order,
				title = product.name,
				description = product.description,
				priceText = formatRobux(product, Enum.InfoType.Product),
				onClick = function()
					context.fireShopAction(
						"PromptProduct",
						"Product",
						productKey
					)
				end,
			})
			order += 1
		end
	end
end

local function renderCoins(context)
	local imageKeys = {
		StarterCoinPack = "StarterCoinPack",
		SmallCoinPack = "SmallCoinPack",
		MediumCoinPack = "MediumCoinPack",
		LargeCoinPack = "LargeCoinPack",
		HugeCoinPack = "HugeCoinPack",
	}
	local order = 1

	for _, productKey in ipairs(
		context.MonetizationConfig.CoinProductOrder or {}
		) do
		local product = context.MonetizationConfig
			.DeveloperProducts[productKey]
		if product then
			createImageRow(context, {
				key = imageKeys[productKey],
				layoutOrder = order,
				height = 158,
				title = product.name,
				description = product.description,
				priceText = formatRobux(product, Enum.InfoType.Product),
				action = {
					text = "Buy",
					type = "GreenButton",
					enabled = true,
					onClick = function()
						context.fireShopAction(
							"PromptProduct",
							"Product",
							productKey
						)
					end,
				},
			})
			order += 1
		end
	end
end

local function renderUpgrades(context)
	createSummaryRow(
		context,
		"Fish Bag Storage",
		string.format(
			"Current capacity: %d fish",
			context.state and context.state.BackpackSize or 0
		),
		1
	)

	local imageKeys = {
		SmallBag = "SmallBagUpgrade",
		MediumBag = "MediumBagUpgrade",
		LargeBag = "LargeBagUpgrade",
	}
	local order = 2

	for _, passKey in ipairs({
		"SmallBag",
		"MediumBag",
		"LargeBag",
		}) do
		local pass = context.MonetizationConfig.GamePasses[passKey]
		if pass then
			createImageRow(context, {
				key = imageKeys[passKey],
				layoutOrder = order,
				height = 178,
				title = pass.name,
				description = pass.description,
				priceText = formatRobux(pass, Enum.InfoType.GamePass),
				action = gamePassAction(context, passKey),
			})
			order += 1
		end
	end
end

function ShopModernUI.render(context)
	assert(type(context) == "table", "ShopModernUI.render needs context")
	assert(context.parent, "ShopModernUI.render needs parent")
	assert(context.panel, "ShopModernUI.render needs panel")
	assert(context.MonetizationConfig, "ShopModernUI.render needs MonetizationConfig")
	assert(context.fireShopAction, "ShopModernUI.render needs fireShopAction")

	if not ui.active or ui.context ~= context then
		if ui.active then
			restoreOriginal()
		end
		buildShell(context)
	else
		ui.context = context
	end

	if context.panelTitle then
		context.panelTitle.Text = "SHOP"
	end

	clearRenderedChildren(context.parent)
	ui.layout = context.parent:FindFirstChildOfClass("UIListLayout")
	ui.padding = context.parent:FindFirstChildOfClass("UIPadding")
	assert(ui.layout and ui.padding, "[ShopModernUI] Authored Content layout/padding is missing")

	renderTabs(context)

	if ui.selectedTab == "Passes" then
		renderPasses(context)
	elseif ui.selectedTab == "Items" then
		renderItems(context)
	elseif ui.selectedTab == "Coins" then
		renderCoins(context)
	elseif ui.selectedTab == "Upgrades" then
		renderUpgrades(context)
	end

	task.defer(updateScrollbar)
	task.delay(0.05, updateScrollbar)
	task.delay(0.15, updateScrollbar)
end

return ShopModernUI
</string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="731">
            <Properties>
              <string name="Name">ToolHotbarBinder</string>
              <string name="Source">local ToolHotbarBinder = {}

local function bindContainerTools(container, connectTool)
	if not container then
		return
	end

	for _, child in ipairs(container:GetChildren()) do
		connectTool(child)
	end
	container.ChildAdded:Connect(connectTool)
end

function ToolHotbarBinder.start(deps)
	local player = deps.player
	local setTab = deps.setTab
	local hasPanel = deps.hasPanel
	local isToolSwitchLocked = deps.isToolSwitchLocked
	local watchLegacyAquariumViewerTools = deps.watchLegacyAquariumViewerTools

	task.spawn(function()
		local connectedHudTools = {}

		local function unequipHudTool()
			local character = player.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:UnequipTools()
			end
		end

		local function restoreFishingRod()
			local character = player.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			local backpack = player:FindFirstChild("Backpack")
			local rod = character and character:FindFirstChild("Fishing Rod")
				or (backpack and backpack:FindFirstChild("Fishing Rod"))
			if humanoid and rod and rod:IsA("Tool") then
				humanoid:EquipTool(rod)
			elseif humanoid then
				humanoid:UnequipTools()
			end
		end

		local function panelExists(tabName)
			if not hasPanel then
				return true
			end

			return hasPanel(tabName)
		end

		local function connectHudTool(tool)
			if not tool:IsA("Tool") then
				return
			end

			if connectedHudTools[tool] then
				return
			end

			if tool.Name == "Fishing Rod" then
				connectedHudTools[tool] = true
				tool.Unequipped:Connect(function()
					if isToolSwitchLocked and isToolSwitchLocked() then
						task.defer(restoreFishingRod)
					end
				end)
				tool.Destroying:Connect(function()
					connectedHudTools[tool] = nil
				end)
				return
			end

			local tabName = nil
			local foundMessage = nil
			local equippedMessage = nil
			local openingMessage = nil
			local missingMessage = nil
			local activatedMessage = nil
			local shouldUnequipAfterOpen = false
			if tool.Name == "Bag" or tool.Name == "Backpack" then
				tabName = "Bag"
				foundMessage = "Bag tool found"
				equippedMessage = "Bag tool equipped"
				openingMessage = "Opening Bag UI"
				missingMessage = "BagPanel not found"
				activatedMessage = "Bag tool activated"
				shouldUnequipAfterOpen = true
			elseif tool.Name == "Fishdex" then
				tabName = "Fishdex"
				foundMessage = "Fishdex tool found"
				equippedMessage = "Fishdex tool equipped"
				openingMessage = "Opening Fishdex UI"
				missingMessage = "FishdexPanel not found"
				activatedMessage = "Fishdex tool activated"
				shouldUnequipAfterOpen = true
			elseif tool.Name == "Aquarium Viewer" then
				tabName = "Aquarium"
			end

			if not tabName then
				return
			end

			connectedHudTools[tool] = true
			if shouldUnequipAfterOpen then
				tool.RequiresHandle = false
				tool.CanBeDropped = false
			end
			if foundMessage then
				print(foundMessage)
			end

			local lastActivatedAt = 0
			local function activateTool(source)
				local now = os.clock()
				if now - lastActivatedAt &lt; 0.2 then
					return
				end
				lastActivatedAt = now

				if shouldUnequipAfterOpen
					and isToolSwitchLocked
					and isToolSwitchLocked()
				then
					task.defer(restoreFishingRod)
					return
				end

				if source == "Equipped" and equippedMessage then
					print(equippedMessage)
					if tabName == "Bag" then
						print("Bag tool equipped/opening Bag UI")
					elseif tabName == "Fishdex" then
						print("Fishdex tool equipped/opening Fishdex UI")
					end
				elseif source == "Activated" and activatedMessage then
					print(activatedMessage)
				end

				if not panelExists(tabName) then
					if missingMessage then
						warn(missingMessage)
					end
					if shouldUnequipAfterOpen then
						unequipHudTool()
					end
					return
				end

				if openingMessage then
					print(openingMessage)
				end
				setTab(tabName)

				if shouldUnequipAfterOpen then
					unequipHudTool()
				end
			end

			-- Bag/Fishdex are opened from the numbered Roblox hotbar.
			-- A single slot press can fire both Equipped and Activated.
			-- Calling setTab from both events toggles the same panel twice,
			-- which is why Fishdex required another press to close.
			if tabName == "Bag" or tabName == "Fishdex" then
				tool.Equipped:Connect(function()
					activateTool("Equipped")
				end)
			else
				-- Preserve the existing behavior for other tools.
				tool.Equipped:Connect(function()
					activateTool("Equipped")
				end)
				tool.Activated:Connect(function()
					activateTool("Activated")
				end)
			end

			tool.Destroying:Connect(function()
				connectedHudTools[tool] = nil
			end)
		end

		local function bindContainer(container)
			if watchLegacyAquariumViewerTools then
				watchLegacyAquariumViewerTools(container)
			end
			bindContainerTools(container, connectHudTool)
		end

		local backpack = player:WaitForChild("Backpack", 10)
		bindContainer(backpack)
		bindContainer(player.Character)

		player.CharacterAdded:Connect(bindContainer)
	end)
end

return ToolHotbarBinder
