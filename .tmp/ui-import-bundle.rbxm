	for tabName in pairs(TAB_CONFIG) do
		local tab = requireAuthoredChild(modernRoot, "ImageButton", tabName)
		requireAuthoredChild(tab, "UIStroke", "SelectedStroke")
		requireAuthoredChild(tab, "ImageLabel", "TabIcon")
